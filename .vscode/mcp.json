{
  "servers": {
    "memory": {
      "type": "sse",
      "url": "http://localhost:3100/sse"
    },
    "sequentialthinking": {
      "type": "stdio",
      "command": "${workspaceFolder}/node_modules/.bin/mcp-server-sequential-thinking"
    },
    "shadcn": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "shadcn@latest", "mcp"]
    },
    "supabase": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "supabase", "mcp"]
    }
  }
}
