#!/usr/bin/env bash
# Enforce the Codex/Claude-owned Warbird precheck before any commit.

set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

echo "INFO: pre-commit gate -> scripts/guards/warbird-agent-precheck.sh"
"$ROOT_DIR/scripts/guards/warbird-agent-precheck.sh" --mode pre-commit
