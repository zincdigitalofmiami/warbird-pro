#!/usr/bin/env bash
# Enforce the Codex-owned Warbird precheck before any push.

set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

# No-feature-branches guard (CLAUDE.md Locked Rule, 2026-05-08).
# Refuses pushes to any remote ref that isn't refs/heads/main, EXCEPT
# delete-pushes (--delete) which are how you clean up stale branches.
# A delete-push from git looks like:  (delete) 0000...0000 <remote_ref> <old_sha>
# so local_sha == 40 zeroes means the user is trying to remove a remote ref —
# allow it regardless of which branch is being deleted (deleting stale
# branches is what the rule wants, not what it forbids).
# Override for an emergency with ALLOW_NON_MAIN_PUSH=1.
ZERO_SHA="0000000000000000000000000000000000000000"
if [[ "${ALLOW_NON_MAIN_PUSH:-0}" != "1" ]]; then
  while read -r local_ref local_sha remote_ref _remote_sha; do
    [[ -z "$local_ref" ]] && continue
    # Allow delete-pushes (stale branch cleanup).
    [[ "$local_sha" == "$ZERO_SHA" ]] && continue
    if [[ "$remote_ref" != "refs/heads/main" ]]; then
      echo "ERROR: pre-push refused — pushing to '$remote_ref'." >&2
      echo "       CLAUDE.md Locked Rule (2026-05-08): only main is pushable." >&2
      echo "       Fix: merge into main and push that, or delete the branch." >&2
      echo "       Override (rare): ALLOW_NON_MAIN_PUSH=1 git push ..." >&2
      exit 1
    fi
  done
fi

echo "INFO: pre-push gate -> scripts/guards/warbird-agent-precheck.sh"
"$ROOT_DIR/scripts/guards/warbird-agent-precheck.sh" --mode pre-push
