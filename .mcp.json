{
  "mcpServers": {
    "memory": {
      "type": "stdio",
      "command": "/opt/homebrew/bin/npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {
        "MEMORY_FILE_PATH": "/Volumes/Satechi Hub/warbird-pro-state/mcp-memory/memory.jsonl"
      }
    },
    "sequentialthinking": {
      "type": "stdio",
      "command": "/opt/homebrew/bin/node",
      "args": [
        "./node_modules/@modelcontextprotocol/server-sequential-thinking/dist/index.js"
      ]
    },
    "postgres-warbird": {
      "type": "stdio",
      "command": "/opt/homebrew/bin/npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://zincdigital@127.0.0.1:5432/warbird"
      ]
    }
  }
}
