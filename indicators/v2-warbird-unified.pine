plot(adxSlope,  "adx_slope_14",    display=display.none)  // AG feature: adx_slope_14
plot(er10,      "er_10",           display=display.none)  // AG feature: er_10
plot(er20,      "er_20",           display=display.none)  // AG feature: er_20
plot(vixPctRank,"vix_pct_252d",    display=display.none)  // AG feature: vix_pct_252d
plot(atrPct,    "atr_pct_20",      display=display.none)  // AG feature: atr_pct_20
plot(vixDaily,  "vix_close",       display=display.none)  // AG feature: vix_close

// Volume/microstructure features
