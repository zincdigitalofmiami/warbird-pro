plot(volDeltaPct,    "vol_delta_pct",    display=display.none)  // AG feature: vol_delta_pct
plot(nz(fibTouchVolDelta), "fib_touch_vol_delta", display=display.none)  // AG feature: fib_touch_vol_delta

// HTF confluence features
plot(float(htfConfPivot), "htf_conf_pivot", display=display.none)  // AG feature: htf_conf_pivot
plot(float(htfConf382),   "htf_conf_382",   display=display.none)  // AG feature: htf_conf_382
plot(float(htfConf618),   "htf_conf_618",   display=display.none)  // AG feature: htf_conf_618
plot(float(htfConfTotal), "htf_conf_total", display=display.none)  // AG feature: htf_conf_total

// Intermarket features
plot(float(regime),     "im_regime",      display=display.none)  // AG feature: im_regime (-1/0/1)
plot(float(scoreOn),    "im_score_on",    display=display.none)  // AG feature: im_score_on
plot(float(scoreOff),   "im_score_off",   display=display.none)  // AG feature: im_score_off
plot(float(newsPosture),"news_posture",   display=display.none)  // AG feature: news_posture (-1/0/1)

// Fib structure features
plot(fibRange,          "fib_range",      display=display.none)  // AG feature: fib_range
plot(float(dir),        "fib_direction",  display=display.none)  // AG feature: fib_direction (-1/1)
plot(float(activeFibPeriod), "fib_period", display=display.none) // AG feature: fib_period (8/13/21/34/55)

// Panel score features (PLACEHOLDER derivations — replaced by AG)
plot(tp1Prob,    "tp1_probability",      display=display.none)  // AG feature: tp1_probability
plot(tp2Prob,    "tp2_probability",      display=display.none)  // AG feature: tp2_probability
plot(trendStr,   "trend_strength",       display=display.none)  // AG feature: trend_strength
plot(corrStr,    "correlation_strength", display=display.none)  // AG feature: correlation_strength
plot(revRisk,    "reversal_risk",        display=display.none)  // AG feature: reversal_risk
plot(pulseScore, "pulse_score",          display=display.none)  // AG feature: pulse_score

//=====================
// ALERTS
//=====================
riskOnFlip = useIntermarket and regime == 1 and regime[1] != 1
riskOffFlip = useIntermarket and regime == -1 and regime[1] != -1
alertcondition(acceptEvent, "ACCEPT (AutoFib) + Regime Aligned", "Accepted through AutoFib zone with regime aligned confirmation. Close={{close}}")
alertcondition(rejectEvent, "REJECT (AutoFib) + Regime Opposed", "Rejected at AutoFib zone while intermarket regime opposed direction. Close={{close}}")
alertcondition(breakAgainstEvent, "PIVOT BREAK (against) + Regime Opposed", "Broke pivot against AutoFib direction with intermarket opposition. Close={{close}}")
alertcondition(tagT1Event, "TARGET HIT: 1.236", "Warbird TARGET 1 (1.236) tagged. Price={{close}}")
alertcondition(tagT2Event, "TARGET HIT: 1.618", "Warbird TARGET 2 (1.618) tagged. Price={{close}}")
alertcondition(tagT3Event, "TARGET HIT: 2.0",   "Warbird TARGET 3 (2.0) tagged. Price={{close}}")
alertcondition(conflictEvent, "CONFLICT: Break vs VIX/DXY", "Caution: Break in AutoFib direction while VIX/DXY disagree. Close={{close}}")
alertcondition(hawkishNewsEvent, "NEWS PROXY: Hawkish Shock", "Macro reaction proxy flipped HAWKISH (risk-off posture). Close={{close}}")
alertcondition(dovishNewsEvent, "NEWS PROXY: Dovish Shock", "Macro reaction proxy flipped DOVISH (risk-on posture). Close={{close}}")
alertcondition(riskOnFlip, "Flip to RISK-ON", "Intermarket flipped to RISK-ON.")
alertcondition(riskOffFlip, "Flip to RISK-OFF", "Intermarket flipped to RISK-OFF.")
