// Warbird v2 — Unified Fib Engine
// Canonical spec: lib/fibonacci.ts (dashboard TypeScript engine)
// Merge: v1 intermarket + v0 full levels + dashboard structural break locking
// Date: 2026-03-22
//
// NO-REPAINT AUDIT:
// - Structural break: barstate.isconfirmed gated
// - request.security(): lookahead_off on all calls
// - Structure conditions: close-based, bar-close semantics
// - Last verified: 2026-03-22
//
// REQUEST.SECURITY() BUDGET:
// Intermarket (60min): NQ, BANK, VIX, DXY, 10Y         = 5 calls
// News proxy (5min):   NQ, DXY, VIX, 10Y                = 4 calls
// VIX daily:           close + percentrank               = 2 calls
// HTF fib (1H):        [high, low] tuple                 = 1 call
// HTF fib (4H):        [high, low] tuple                 = 1 call
// HTF fib (1D):        [high, low] tuple                 = 1 call
// LTF volume (1min):   (reserved)                        = 2 calls
// TOTAL:                                                 = 16 of 40 (40%)
//@version=6
indicator("Warbird v2 — AutoFib + Intermarket", shorttitle="🦝 WB v2", overlay=true, max_lines_count=200, max_labels_count=200, max_boxes_count=50)
//=====================
// FIBONACCI ENGINE SETTINGS
//=====================
groupAFEngine = "Fibonacci Engine Settings"
fibConfluenceTolPct = input.float(0.10, "Confluence Tolerance (%)", minval=0.01, maxval=2.00, step=0.01, group=groupAFEngine)
//=====================
// CANONICAL FIB LEVELS (from lib/fibonacci.ts + FibLinesPrimitive.ts)
// DO NOT change these — they match the dashboard exactly
//=====================

// Retracement ratios
FIB_ZERO  = 0.0
FIB_236   = 0.236
FIB_382   = 0.382
FIB_PIVOT = 0.5
FIB_618   = 0.618
FIB_786   = 0.786
FIB_ONE   = 1.0

// Extension ratios
FIB_T1    = 1.236
FIB_T2    = 1.618
FIB_T3    = 2.0

// Colors (from lib/colors.ts:43-54)
COLOR_ANCHOR      = #FFFFFF    // white — 0 and 1 levels
COLOR_RETRACEMENT = #808080    // 50% white — .236, .382, .618, .786
COLOR_PIVOT       = #FF9800    // orange — .5 level
COLOR_TARGET      = #4CAF50    // green — TARGET 1, 2, 3

// Widths (from FibLinesPrimitive.ts:49-60)
WIDTH_ANCHOR      = 1
WIDTH_RETRACEMENT = 1
WIDTH_PIVOT       = 2
WIDTH_TARGET      = 2
//=====================
// STRUCTURE LOGIC
//=====================
groupLogic = "Structure Logic"
retestBars   = input.int(6, "Acceptance Retest Window (bars)", minval=1, group=groupLogic)
rejectWick   = input.bool(true, "Rejection = wick into zone then close back out", group=groupLogic)
oneShotEvent = input.bool(true, "One-shot event markers/alerts", group=groupLogic)
//=====================
// INTERMARKET CONFIRMATION
//=====================
groupIM = "Intermarket Inputs"
useIntermarket = input.bool(true, "Use Intermarket Confirmation", group=groupIM)
tfIM           = input.timeframe("60", "Intermarket Timeframe", group=groupIM)
maLen          = input.int(20, "Confirm EMA Length", minval=5, group=groupIM)
slopeBars      = input.int(1, "Slope Bars", minval=1, maxval=10, group=groupIM)
neutralBandPct = input.float(0.05, "Neutral Band Around EMA (%)", minval=0.0, step=0.01, group=groupIM)
symNQ   = input.symbol("CME_MINI:NQ1!", "NQ (risk appetite)", group=groupIM)
symBANK = input.symbol("NASDAQ:BANK", "BANK (financials)", group=groupIM)
symVIX  = input.symbol("CBOE:VIX", "VIX (volatility)", group=groupIM)
symDXY  = input.symbol("TVC:DXY", "DXY (USD)", group=groupIM)
sym10Y  = input.symbol("TVC:US10Y", "US10Y (yield)", group=groupIM)
vixMaxRiskOn  = input.float(20.40, "VIX Max (risk-on filter)", step=0.1, group=groupIM)
use10YConfirm = input.bool(false, "Include 10Y in confirmation", group=groupIM)
groupIMModel = "Intermarket Model (v2)"
imModel           = input.string("Score + Hysteresis", "Decision Model", options=["Binary Gates", "Score + Hysteresis"], group=groupIMModel)
requireAnchors    = input.bool(true, "Require NQ + BANK alignment", group=groupIMModel)
scoreThresholdPct = input.float(0.67, "Score Threshold %", minval=0.50, maxval=1.00, step=0.01, group=groupIMModel)
confirmBars       = input.int(2, "Bars Required To Flip", minval=1, maxval=10, group=groupIMModel)
cooldownBars      = input.int(3, "Flip Cooldown (bars)", minval=0, maxval=50, group=groupIMModel)
neutralizeBars    = input.int(0, "Neutralize After Inactive Bars (0=off)", minval=0, maxval=200, group=groupIMModel)
wNQ   = input.int(2, "Weight: NQ", minval=0, maxval=10, group=groupIMModel)
wBANK = input.int(2, "Weight: BANK", minval=0, maxval=10, group=groupIMModel)
wVIX  = input.int(2, "Weight: VIX", minval=0, maxval=10, group=groupIMModel)
wDXY  = input.int(1, "Weight: DXY", minval=0, maxval=10, group=groupIMModel)
w10Y  = input.int(1, "Weight: US10Y", minval=0, maxval=10, group=groupIMModel)
groupNews = "News Proxy (Automatic Reaction)"
useNewsProxy = input.bool(true, "Use Macro News Proxy", group=groupNews, tooltip="Pine cannot read TradingView news text directly. This uses post-event cross-asset shock reaction as a proxy.")
tfNews = input.timeframe("5", "Proxy Timeframe", group=groupNews)
proxyLookbackBars = input.int(3, "Proxy Lookback Bars", minval=1, maxval=30, group=groupNews)
nqShockPct = input.float(0.25, "NQ Shock Threshold (%)", minval=0.01, step=0.01, group=groupNews)
dxyShockPct = input.float(0.10, "DXY Shock Threshold (%)", minval=0.01, step=0.01, group=groupNews)
vixShockPct = input.float(4.00, "VIX Shock Threshold (%)", minval=0.10, step=0.10, group=groupNews)
y10ShockAbs = input.float(0.03, "US10Y Shock Threshold (abs)", minval=0.001, step=0.001, group=groupNews, tooltip="0.03 is roughly 3 bps.")
minProxyScore = input.int(3, "Minimum Proxy Score (1-4)", minval=1, maxval=4, group=groupNews)
proxyHoldBars = input.int(12, "Proxy Posture Hold (bars)", minval=1, maxval=200, group=groupNews)
//=====================
// VISUALS (colors/widths locked to spec — see constants above)
//=====================
groupViz = "Visuals"
targetLookbackBars = input.int(55, "Target Line Lookback Bars", minval=5, maxval=500, group=groupViz)
extendLevelsRight = input.bool(false, "Extend Levels Right", group=groupViz)
useConfluenceAnchorSpan = input.bool(true, "Anchor Span = Active Fib Window", group=groupViz)
showBg          = input.bool(false, "Background Regime Tint", group=groupViz)
//=====================
// REGIME DETECTION (from session-checkpoint research: ADX/ER/VIX-vol)
// These are computed values for sidebar + AG features, NOT chart markers
//=====================

// --- ADX(14) + signed DI spread + ADX slope ---
adxLen = 14
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)
diSpread = diPlus - diMinus                          // AG feature: di_spread_14
adxSlope = adxVal - nz(adxVal[3])                    // AG feature: adx_slope_14 (3-bar slope)

// Regime classification: trending vs ranging
// ADX > 25 = trending, ADX < 20 = ranging, 20-25 = transitional
regimeTrending = adxVal > 25
regimeRanging  = adxVal < 20

// --- Efficiency Ratio (10, 20) ---
// ER = |net move| / sum(|bar-to-bar moves|) — 1.0 = perfectly efficient, 0.0 = pure noise
er10Direction = math.abs(close - close[10])
er10Volatility = math.sum(math.abs(close - close[1]), 10)
er10 = er10Volatility != 0 ? er10Direction / er10Volatility : 0.0  // AG feature: er_10

er20Direction = math.abs(close - close[20])
er20Volatility = math.sum(math.abs(close - close[1]), 20)
er20 = er20Volatility != 0 ? er20Direction / er20Volatility : 0.0  // AG feature: er_20

// --- VIX percentile approximation (rolling 252-day) ---
// Uses daily VIX via request.security — 1 additional call
// percentrank computed inside security() so it runs on daily bars (252 = 1 year)
vixDaily = request.security("CBOE:VIX", "D", close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
vixPctRank = request.security("CBOE:VIX", "D", ta.percentrank(close, 252), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)  // AG feature: vix_pct_252d (0-100 scale)

// --- ATR percentage (normalized volatility) ---
atrRaw = ta.atr(20)
atrPct = close != 0 ? atrRaw / close * 100.0 : 0.0  // AG feature: atr_pct_20

//=====================
// HTF FIB CONFLUENCE (1H, 4H, Daily)
// Uses tuple syntax to get high+low in one request.security() call per TF
// Computes fib levels on each HTF, flags alignment with 15m levels
//=====================
groupHTF = "HTF Confluence"
htfConfTolPct = input.float(0.15, "HTF Confluence Tolerance (%)", minval=0.01, maxval=1.00, step=0.01, group=groupHTF, tooltip="How close HTF and 15m fib levels must be to count as confluent (% of range)")

// Fetch HTF high/low using tuple syntax (2 calls per TF = 6 total)
[htf1hHigh, htf1hLow] = request.security(syminfo.tickerid, "60", [ta.highest(high, 55), ta.lowest(low, 55)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
[htf4hHigh, htf4hLow] = request.security(syminfo.tickerid, "240", [ta.highest(high, 55), ta.lowest(low, 55)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
[htf1dHigh, htf1dLow] = request.security(syminfo.tickerid, "D", [ta.highest(high, 55), ta.lowest(low, 55)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

// Compute pivot (.5) level on each HTF
htf1hRange = nz(htf1hHigh - htf1hLow)
htf4hRange = nz(htf4hHigh - htf4hLow)
htf1dRange = nz(htf1dHigh - htf1dLow)

// HTF fib level helper — same canonical ratios
htfFibPrice(float htfHigh, float htfLow, float htfRng, float ratio) =>
    htfRng <= 0 ? na : htfLow + htfRng * ratio

// Compute key HTF levels (pivot, .382, .618 — the confluence-sensitive levels)
htf1hP382 = htfFibPrice(htf1hHigh, htf1hLow, htf1hRange, FIB_382)
htf1hP500 = htfFibPrice(htf1hHigh, htf1hLow, htf1hRange, FIB_PIVOT)
htf1hP618 = htfFibPrice(htf1hHigh, htf1hLow, htf1hRange, FIB_618)

htf4hP382 = htfFibPrice(htf4hHigh, htf4hLow, htf4hRange, FIB_382)
htf4hP500 = htfFibPrice(htf4hHigh, htf4hLow, htf4hRange, FIB_PIVOT)
htf4hP618 = htfFibPrice(htf4hHigh, htf4hLow, htf4hRange, FIB_618)

htf1dP382 = htfFibPrice(htf1dHigh, htf1dLow, htf1dRange, FIB_382)
htf1dP500 = htfFibPrice(htf1dHigh, htf1dLow, htf1dRange, FIB_PIVOT)
htf1dP618 = htfFibPrice(htf1dHigh, htf1dLow, htf1dRange, FIB_618)

// Check if a 15m fib level aligns with any HTF fib level
htfConfluenceCheck(float level15m) =>
    if na(level15m) or na(fibRange) or fibRange <= 0
        0
    else
        float tol = fibRange * htfConfTolPct * 0.01
        int hits = 0
        // Check against 1H levels
        if not na(htf1hP382) and math.abs(level15m - htf1hP382) <= tol
            hits += 1
        if not na(htf1hP500) and math.abs(level15m - htf1hP500) <= tol
            hits += 1
        if not na(htf1hP618) and math.abs(level15m - htf1hP618) <= tol
            hits += 1
        // Check against 4H levels
        if not na(htf4hP382) and math.abs(level15m - htf4hP382) <= tol
            hits += 1
        if not na(htf4hP500) and math.abs(level15m - htf4hP500) <= tol
            hits += 1
        if not na(htf4hP618) and math.abs(level15m - htf4hP618) <= tol
            hits += 1
        // Check against Daily levels
        if not na(htf1dP382) and math.abs(level15m - htf1dP382) <= tol
            hits += 1
        if not na(htf1dP500) and math.abs(level15m - htf1dP500) <= tol
            hits += 1
        if not na(htf1dP618) and math.abs(level15m - htf1dP618) <= tol
            hits += 1
        hits

// NOTE: htfConfluenceCheck() is called AFTER fib prices are computed (below the AUTO FIB ENGINE)

//=====================
// AUTO FIB ENGINE (RR confluence anchor, same methodology as main RR indicator)
//=====================
fib8_high = ta.highest(high, 8)
fib8_low = ta.lowest(low, 8)
fib13_high = ta.highest(high, 13)
fib13_low = ta.lowest(low, 13)
fib21_high = ta.highest(high, 21)
fib21_low = ta.lowest(low, 21)
fib34_high = ta.highest(high, 34)
fib34_low = ta.lowest(low, 34)
fib55_high = ta.highest(high, 55)
fib55_low = ta.lowest(low, 55)
fibHigh1 = fib8_high
fibLow1 = fib8_low
fibHigh2 = fib13_high
fibLow2 = fib13_low
fibHigh3 = fib21_high
fibLow3 = fib21_low
fibHigh4 = fib34_high
fibLow4 = fib34_low
fibHigh5 = fib55_high
fibLow5 = fib55_low
//=====================
// CONFLUENCE SCORING (from lib/fibonacci.ts:146-173)
// Score = confluence_count × range
// This prevents short-period narrow anchors from winning
//=====================

// Confluence ratios used for voting (lib/fibonacci.ts:30)
CONF_RATIOS_0 = 0.382
CONF_RATIOS_1 = 0.5
CONF_RATIOS_2 = 0.618

fibConfluenceScore(float h, float l) =>
    float rng = h - l
    if rng <= 0
        0.0
    else
        float tol = rng * fibConfluenceTolPct * 0.01
        int confCount = 0
        // For each of 3 confluence ratios on this anchor...
        for selfR = 0 to 2
            float selfRatio = selfR == 0 ? CONF_RATIOS_0 : selfR == 1 ? CONF_RATIOS_1 : CONF_RATIOS_2
            float selfLevel = l + rng * selfRatio
            // ...compare against 3 confluence ratios on each OTHER anchor
            for cmpR = 0 to 2
                float cmpRatio = cmpR == 0 ? CONF_RATIOS_0 : cmpR == 1 ? CONF_RATIOS_1 : CONF_RATIOS_2
                // Check all 5 period anchors
                float cmpLvl1 = fibLow1 + (fibHigh1 - fibLow1) * cmpRatio
                float cmpLvl2 = fibLow2 + (fibHigh2 - fibLow2) * cmpRatio
                float cmpLvl3 = fibLow3 + (fibHigh3 - fibLow3) * cmpRatio
                float cmpLvl4 = fibLow4 + (fibHigh4 - fibLow4) * cmpRatio
                float cmpLvl5 = fibLow5 + (fibHigh5 - fibLow5) * cmpRatio
                if math.abs(selfLevel - cmpLvl1) <= tol
                    confCount += 1
                if math.abs(selfLevel - cmpLvl2) <= tol
                    confCount += 1
                if math.abs(selfLevel - cmpLvl3) <= tol
                    confCount += 1
                if math.abs(selfLevel - cmpLvl4) <= tol
                    confCount += 1
                if math.abs(selfLevel - cmpLvl5) <= tol
                    confCount += 1
        // KEY DIFFERENCE: weight by range (lib/fibonacci.ts:168)
        float(confCount) * rng
score1 = fibConfluenceScore(fibHigh1, fibLow1)
score2 = fibConfluenceScore(fibHigh2, fibLow2)
score3 = fibConfluenceScore(fibHigh3, fibLow3)
score4 = fibConfluenceScore(fibHigh4, fibLow4)
score5 = fibConfluenceScore(fibHigh5, fibLow5)
bestScore = math.max(score1, score2, score3, score4, score5)
fibAnchorHighCandidate = (
 bestScore == score5 ? fibHigh5 :
 bestScore == score4 ? fibHigh4 :
 bestScore == score3 ? fibHigh3 :
 bestScore == score2 ? fibHigh2 : fibHigh1
 )
fibAnchorLowCandidate = (
 bestScore == score5 ? fibLow5 :
 bestScore == score4 ? fibLow4 :
 bestScore == score3 ? fibLow3 :
 bestScore == score2 ? fibLow2 : fibLow1
 )
activeFibPeriodCandidate = (
 bestScore == score5 ? 55 :
 bestScore == score4 ? 34 :
 bestScore == score3 ? 21 :
 bestScore == score2 ? 13 : 8
 )
activeHighOffsetCandidate = (
 activeFibPeriodCandidate == 55 ? ta.highestbars(high, 55) :
 activeFibPeriodCandidate == 34 ? ta.highestbars(high, 34) :
 activeFibPeriodCandidate == 21 ? ta.highestbars(high, 21) :
 activeFibPeriodCandidate == 13 ? ta.highestbars(high, 13) : ta.highestbars(high, 8)
 )
activeLowOffsetCandidate = (
 activeFibPeriodCandidate == 55 ? ta.lowestbars(low, 55) :
 activeFibPeriodCandidate == 34 ? ta.lowestbars(low, 34) :
 activeFibPeriodCandidate == 21 ? ta.lowestbars(low, 21) :
 activeFibPeriodCandidate == 13 ? ta.lowestbars(low, 13) : ta.lowestbars(low, 8)
 )
candidateHighBar = bar_index - math.abs(activeHighOffsetCandidate)
candidateLowBar = bar_index - math.abs(activeLowOffsetCandidate)
var float fibAnchorHigh = na
var float fibAnchorLow = na
var int activeFibPeriod = 55
var int anchorHighBar = na
var int anchorLowBar = na
bool structBreak = not na(fibAnchorHigh) and not na(fibAnchorLow) and
 barstate.isconfirmed and
                   (close > fibAnchorHigh or close < fibAnchorLow)
bool needsAnchor = na(fibAnchorHigh) or na(fibAnchorLow) or structBreak
var int lastBreakBar = na  // tracks bar_index of most recent breakInDir, reset on anchor change
if needsAnchor and (barstate.isconfirmed or na(fibAnchorHigh))
    fibAnchorHigh := fibAnchorHighCandidate
    fibAnchorLow := fibAnchorLowCandidate
    activeFibPeriod := activeFibPeriodCandidate
    anchorHighBar := candidateHighBar
    anchorLowBar := candidateLowBar
    lastBreakBar := na  // F1 fix: reset break tracking when anchor changes
fibRange = fibAnchorHigh - fibAnchorLow
fibMidpoint = fibAnchorLow + fibRange * 0.5
// W3/W7 fix: hysteresis band prevents rapid direction flips in chop
// Direction only flips when price crosses midpoint ± 2% of range
float hystBand = fibRange * 0.02
var bool fibBull = true
if fibRange > 0
    if close >= fibMidpoint + hystBand
        fibBull := true
    else if close <= fibMidpoint - hystBand
        fibBull := false
    // else: inside dead zone, keep previous direction
else
    fibBull := true
fibBase = fibBull ? fibAnchorLow : fibAnchorHigh
fibDir = fibBull ? 1.0 : -1.0
fibPrice(float ratio) =>
    fibRange <= 0 ? na : (fibBase + fibDir * fibRange * ratio)
// Compute all 10 canonical level prices
pZero   = fibPrice(FIB_ZERO)
p236    = fibPrice(FIB_236)
p382    = fibPrice(FIB_382)
pPivot  = fibPrice(FIB_PIVOT)
p618    = fibPrice(FIB_618)
p786    = fibPrice(FIB_786)
pOne    = fibPrice(FIB_ONE)
pT1     = fibPrice(FIB_T1)
pT2     = fibPrice(FIB_T2)
pT3     = fibPrice(FIB_T3)

// Structure logic zone: .618 to .786 (decision zone for accept/reject — same as v1)
zoneUpper = math.max(p618, p786)
zoneLower = math.min(p618, p786)

// Zone fill bounds: .382 to .618 (around pivot, from FibLinesPrimitive.ts:267-271)
zoneFillUpper = math.max(p382, p618)
zoneFillLower = math.min(p382, p618)

// --- HTF CONFLUENCE SCORES (computed after 15m fib prices exist) ---
htfConfPivot = htfConfluenceCheck(pPivot)    // AG feature: htf_conf_pivot
htfConf382   = htfConfluenceCheck(p382)      // AG feature: htf_conf_382
htfConf618   = htfConfluenceCheck(p618)      // AG feature: htf_conf_618
htfConfTotal = htfConfPivot + htfConf382 + htfConf618  // AG feature: htf_conf_total (0-27 scale)

//=====================
// VOLUME DELTA AT FIB TOUCHES
// When price touches a fib level, measure bullish vs bearish volume
// Uses close-location-value (CLV) approach: (close-low)/(high-low) weights volume
//=====================
groupVolDelta = "Volume Delta"
volDeltaLookback = input.int(5, "Volume Delta Lookback (bars)", minval=1, maxval=20, group=groupVolDelta, tooltip="How many bars around a fib touch to measure volume split")
volDeltaTolPts = input.float(2.0, "Fib Touch Tolerance (points)", minval=0.25, maxval=10.0, step=0.25, group=groupVolDelta, tooltip="How close price must get to a fib level to count as a touch")

// Close Location Value: (close-low)/(high-low) — 1.0 = closed at high (bullish), 0.0 = closed at low (bearish)
barRange = high - low
clv = barRange > 0 ? (close - low) / barRange : 0.5  // AG feature: clv

// Signed volume: CLV-weighted volume (positive = bullish bias, negative = bearish bias)
signedVol = volume * (2.0 * clv - 1.0)  // AG feature: signed_vol_proxy

// Check if current price is touching any fib level
fibTouchCheck(float level) =>
    not na(level) and math.abs(close - level) <= volDeltaTolPts

isTouchingFib = fibTouchCheck(p236) or fibTouchCheck(p382) or fibTouchCheck(pPivot) or fibTouchCheck(p618) or fibTouchCheck(p786)

// Rolling volume delta around fib touches (bullish % over lookback window)
bullVol = math.sum(volume * math.max(clv, 0), volDeltaLookback)
totalVol = math.sum(volume, volDeltaLookback)
volDeltaPct = totalVol > 0 ? bullVol / totalVol * 100.0 : 50.0  // AG feature: vol_delta_pct (50 = neutral)

// Only meaningful when near a fib level
fibTouchVolDelta = isTouchingFib ? volDeltaPct : na  // AG feature: fib_touch_vol_delta

//=====================
// INTERMARKET SERIES + REGIMES
//=====================
imClose(string symbol) =>
    request.security(symbol, tfIM, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
trendFlags(float px, float ma, int slopeBars_, float neutralPct_) =>
    float distPct = ma != 0 ? math.abs(px - ma) / ma * 100.0 : 0.0
    bool near = distPct <= neutralPct_
    bool up = not near and px > ma and px >= nz(px[slopeBars_], px)
    bool down = not near and px < ma and px <= nz(px[slopeBars_], px)
    [up, down]
nq = imClose(symNQ)
bk = imClose(symBANK)
vx = imClose(symVIX)
dx = imClose(symDXY)
y10 = imClose(sym10Y)
nqMA = ta.ema(nq, maLen)
bkMA = ta.ema(bk, maLen)
vxMA = ta.ema(vx, maLen)
dxMA = ta.ema(dx, maLen)
y10MA = ta.ema(y10, maLen)
[nqUp, nqDown] = trendFlags(nq, nqMA, slopeBars, neutralBandPct)
[bkUp, bkDown] = trendFlags(bk, bkMA, slopeBars, neutralBandPct)
[vxUp, vxDown] = trendFlags(vx, vxMA, slopeBars, neutralBandPct)
[dxUp, dxDown] = trendFlags(dx, dxMA, slopeBars, neutralBandPct)
[y10Up, y10Down] = trendFlags(y10, y10MA, slopeBars, neutralBandPct)
nqBull = nqUp
nqBear = nqDown
bkBull = bkUp
bkBear = bkDown
vxRiskOn = vxDown and vx < vixMaxRiskOn
vxRiskOff = vxUp
dxRiskOn = dxDown
dxRiskOff = dxUp
y10RiskOn = y10Down
y10RiskOff = y10Up
use10YOK_on = (not use10YConfirm) or y10RiskOn
use10YOK_off = (not use10YConfirm) or y10RiskOff
riskOnBinary = nqBull and bkBull and vxRiskOn and dxRiskOn and use10YOK_on
riskOffBinary = nqBear and bkBear and vxRiskOff and dxRiskOff and use10YOK_off
int activeW10Y = use10YConfirm ? w10Y : 0
int totalWeight = wNQ + wBANK + wVIX + wDXY + activeW10Y
int scoreNeeded = int(math.max(1.0, math.ceil(totalWeight * scoreThresholdPct)))
int scoreOn = (
    (nqBull ? wNQ : 0) +
    (bkBull ? wBANK : 0) +
    (vxRiskOn ? wVIX : 0) +
    (dxRiskOn ? wDXY : 0) +
    ((use10YConfirm and y10RiskOn) ? w10Y : 0)
)
int scoreOff = (
    (nqBear ? wNQ : 0) +
    (bkBear ? wBANK : 0) +
    (vxRiskOff ? wVIX : 0) +
    (dxRiskOff ? wDXY : 0) +
    ((use10YConfirm and y10RiskOff) ? w10Y : 0)
)
scoreOnRaw = scoreOn >= scoreNeeded
scoreOffRaw = scoreOff >= scoreNeeded
anchorsOn = nqBull and bkBull
anchorsOff = nqBear and bkBear
scoreOnCandidate = scoreOnRaw and (not requireAnchors or anchorsOn)
scoreOffCandidate = scoreOffRaw and (not requireAnchors or anchorsOff)
candidateOn = imModel == "Binary Gates" ? riskOnBinary : scoreOnCandidate
candidateOff = imModel == "Binary Gates" ? riskOffBinary : scoreOffCandidate
onExclusive = candidateOn and not candidateOff
offExclusive = candidateOff and not candidateOn
var int regime = 0
var int onStreak = 0
var int offStreak = 0
var int inactiveStreak = 0
var int lastFlipBar = na
onStreak := onExclusive ? onStreak + 1 : 0
offStreak := offExclusive ? offStreak + 1 : 0
inactiveStreak := (not candidateOn and not candidateOff) ? inactiveStreak + 1 : 0
if useIntermarket
    bool canFlip = na(lastFlipBar) or (bar_index - lastFlipBar >= cooldownBars)
    if regime == 0
        if onStreak >= confirmBars
            regime := 1
            lastFlipBar := bar_index
        else if offStreak >= confirmBars
            regime := -1
            lastFlipBar := bar_index
    else if regime == 1
        if offStreak >= confirmBars and canFlip
            regime := -1
            lastFlipBar := bar_index
    else if regime == -1
        if onStreak >= confirmBars and canFlip
            regime := 1
            lastFlipBar := bar_index
    if neutralizeBars > 0 and inactiveStreak >= neutralizeBars
        regime := 0
else
    regime := 0
riskOnBase = (not useIntermarket) or regime == 1
riskOffBase = (not useIntermarket) or regime == -1
proxyClose(string symbol) =>
    request.security(symbol, tfNews, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
nqNews = proxyClose(symNQ)
dxNews = proxyClose(symDXY)
vxNews = proxyClose(symVIX)
y10News = proxyClose(sym10Y)
nqRef = nz(nqNews[proxyLookbackBars], nqNews)
dxRef = nz(dxNews[proxyLookbackBars], dxNews)
vxRef = nz(vxNews[proxyLookbackBars], vxNews)
y10Ref = nz(y10News[proxyLookbackBars], y10News)
nqNewsPct = nqRef != 0 ? (nqNews / nqRef - 1.0) * 100.0 : 0.0
dxNewsPct = dxRef != 0 ? (dxNews / dxRef - 1.0) * 100.0 : 0.0
vxNewsPct = vxRef != 0 ? (vxNews / vxRef - 1.0) * 100.0 : 0.0
y10NewsDelta = y10News - y10Ref
hawkishProxyScore = (
    (nqNewsPct <= -nqShockPct ? 1 : 0) +
    (dxNewsPct >= dxyShockPct ? 1 : 0) +
    (vxNewsPct >= vixShockPct ? 1 : 0) +
    (y10NewsDelta >= y10ShockAbs ? 1 : 0)
)
dovishProxyScore = (
    (nqNewsPct >= nqShockPct ? 1 : 0) +
    (dxNewsPct <= -dxyShockPct ? 1 : 0) +
    (vxNewsPct <= -vixShockPct ? 1 : 0) +
    (y10NewsDelta <= -y10ShockAbs ? 1 : 0)
)
hawkishProxySignal = useNewsProxy and hawkishProxyScore >= minProxyScore and hawkishProxyScore > dovishProxyScore
dovishProxySignal = useNewsProxy and dovishProxyScore >= minProxyScore and dovishProxyScore > hawkishProxyScore
var int newsPosture = 0
var int newsPostureBar = na
if useNewsProxy
    if hawkishProxySignal
        newsPosture := -1
        newsPostureBar := bar_index
    else if dovishProxySignal
        newsPosture := 1
        newsPostureBar := bar_index
    if not na(newsPostureBar) and bar_index - newsPostureBar > proxyHoldBars
        newsPosture := 0
else
    newsPosture := 0
    newsPostureBar := na
riskOn = newsPosture == 1 ? true : newsPosture == -1 ? false : riskOnBase
riskOff = newsPosture == -1 ? true : newsPosture == 1 ? false : riskOffBase
//=====================
// STRUCTURE CONDITIONS (direction-aware)
//=====================
dir = fibBull ? 1 : -1
zoneReady = not na(zoneUpper) and not na(zoneLower) and not na(pPivot)
// W2 fix: gate all structure conditions on barstate.isconfirmed to prevent intra-bar flicker
breakInDir = zoneReady and barstate.isconfirmed ? (dir == 1 ? (close > zoneUpper and close[1] <= zoneUpper) : (close < zoneLower and close[1] >= zoneLower)) : false
// F1 fix: track break bar manually instead of ta.barssince (which persists across anchor changes)
if breakInDir
    lastBreakBar := bar_index
barsSinceBreak = na(lastBreakBar) ? int(na) : bar_index - lastBreakBar
acceptInDir = (
 zoneReady and barstate.isconfirmed and
 not na(barsSinceBreak) and barsSinceBreak > 0 and barsSinceBreak <= retestBars and
    (dir == 1 ? (low <= zoneUpper and close > zoneUpper) : (high >= zoneLower and close < zoneLower))
)
rejectAtZone = (
 zoneReady and barstate.isconfirmed and
    (rejectWick ?
        (dir == 1 ? (high >= zoneLower and close < zoneLower) : (low <= zoneUpper and close > zoneUpper)) :
        (dir == 1 ? (close < zoneLower) : (close > zoneUpper)))
)
breakAgainst = zoneReady and barstate.isconfirmed ? (dir == 1 ? (close < pPivot and close[1] >= pPivot) : (close > pPivot and close[1] <= pPivot)) : false
// W10 fix: gate target tags on isconfirmed to prevent premature alert firing
tagT1 = barstate.isconfirmed and not na(pT1) and (dir == 1 ? high >= pT1 : low <= pT1)
tagT2 = barstate.isconfirmed and not na(pT2) and (dir == 1 ? high >= pT2 : low <= pT2)
tagT3 = barstate.isconfirmed and not na(pT3) and (dir == 1 ? high >= pT3 : low <= pT3)
regimeAligned = dir == 1 ? riskOn : riskOff
regimeOpposed = dir == 1 ? riskOff : riskOn
acceptConfirmed = acceptInDir and regimeAligned
rejectConfirmed = rejectAtZone and regimeOpposed
breakAgainstConfirmed = breakAgainst and regimeOpposed
conflictBreak = breakInDir and (dir == 1 ? (vxRiskOff or dxRiskOff) : (vxRiskOn or dxRiskOn))
acceptEvent = oneShotEvent ? (acceptConfirmed and not acceptConfirmed[1]) : acceptConfirmed
rejectEvent = oneShotEvent ? (rejectConfirmed and not rejectConfirmed[1]) : rejectConfirmed
breakAgainstEvent = oneShotEvent ? (breakAgainstConfirmed and not breakAgainstConfirmed[1]) : breakAgainstConfirmed
conflictEvent = oneShotEvent ? (conflictBreak and not conflictBreak[1]) : conflictBreak
tagT1Event = oneShotEvent ? (tagT1 and not tagT1[1]) : tagT1
tagT2Event = oneShotEvent ? (tagT2 and not tagT2[1]) : tagT2
tagT3Event = oneShotEvent ? (tagT3 and not tagT3[1]) : tagT3
proxyImportance = math.max(hawkishProxyScore, dovishProxyScore)
hawkishNewsEvent = useNewsProxy and newsPosture == -1 and newsPosture[1] != -1
dovishNewsEvent = useNewsProxy and newsPosture == 1 and newsPosture[1] != 1
//=====================
// DRAW ALL 10 FIB LEVELS
//=====================

var line lineZero  = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line236   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line382   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line linePivot = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line618   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line786   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineOne   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineT1    = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineT2    = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineT3    = line.new(bar_index, close, bar_index, close, color=color(na), width=1)

var box zoneBox = box.new(bar_index, close, bar_index, close, bgcolor=color(na), border_color=color(na))

fallbackLeftBar = int(math.max(0, bar_index - targetLookbackBars))
anchorLeftBar = int(math.max(0, na(anchorHighBar) or na(anchorLowBar) ? fallbackLeftBar : math.min(anchorHighBar, anchorLowBar)))
drawLeftBar = useConfluenceAnchorSpan ? anchorLeftBar : fallbackLeftBar

drawAnchoredLine(line id, bool visible, float price, color col, int width_, int leftBar) =>
    if visible and not na(price)
        line.set_xy1(id, leftBar, price)
        line.set_xy2(id, bar_index, price)
        line.set_color(id, col)
        line.set_width(id, width_)
        line.set_style(id, line.style_solid)
        line.set_extend(id, extendLevelsRight ? extend.right : extend.none)
    else
        line.set_color(id, color(na))

drawAnchoredLine(lineZero,  true, pZero,  COLOR_ANCHOR,      WIDTH_ANCHOR,      drawLeftBar)
drawAnchoredLine(line236,   true, p236,   COLOR_RETRACEMENT, WIDTH_RETRACEMENT, drawLeftBar)
drawAnchoredLine(line382,   true, p382,   COLOR_RETRACEMENT, WIDTH_RETRACEMENT, drawLeftBar)
drawAnchoredLine(linePivot, true, pPivot, COLOR_PIVOT,       WIDTH_PIVOT,       drawLeftBar)
drawAnchoredLine(line618,   true, p618,   COLOR_RETRACEMENT, WIDTH_RETRACEMENT, drawLeftBar)
drawAnchoredLine(line786,   true, p786,   COLOR_RETRACEMENT, WIDTH_RETRACEMENT, drawLeftBar)
drawAnchoredLine(lineOne,   true, pOne,   COLOR_ANCHOR,      WIDTH_ANCHOR,      drawLeftBar)
drawAnchoredLine(lineT1,    true, pT1,    COLOR_TARGET,      WIDTH_TARGET,      drawLeftBar)
drawAnchoredLine(lineT2,    true, pT2,    COLOR_TARGET,      WIDTH_TARGET,      drawLeftBar)
drawAnchoredLine(lineT3,    true, pT3,    COLOR_TARGET,      WIDTH_TARGET,      drawLeftBar)

// Zone fill between .382 and .618 (FibLinesPrimitive.ts:267-271, PIVOT_FILL_OPACITY = 0.08)
if not na(zoneFillUpper) and not na(zoneFillLower)
    box.set_left(zoneBox, drawLeftBar)
    box.set_right(zoneBox, bar_index)
    box.set_top(zoneBox, zoneFillUpper)
    box.set_bottom(zoneBox, zoneFillLower)
    box.set_bgcolor(zoneBox, color.new(COLOR_PIVOT, 92))  // ~0.08 opacity = 92 transparency
    box.set_border_color(zoneBox, color.new(COLOR_PIVOT, 100))
else
    box.set_bgcolor(zoneBox, color(na))
    box.set_border_color(zoneBox, color(na))
bgcolor(showBg and useIntermarket ? (riskOn ? color.new(color.green, 92) : riskOff ? color.new(color.red, 92) : color.new(color.gray, 94)) : na)
// Chart markers removed — entry/exit markers will come when AG model is live
// Signal conditions (acceptEvent, rejectEvent, etc.) still computed for alerts + sidebar
//=====================
// ALERTS
//=====================
riskOnFlip = useIntermarket and regime == 1 and regime[1] != 1
riskOffFlip = useIntermarket and regime == -1 and regime[1] != -1
alertcondition(acceptEvent, "ACCEPT (AutoFib) + Regime Aligned", "Accepted through AutoFib zone with regime aligned confirmation. Close={{close}}")
alertcondition(rejectEvent, "REJECT (AutoFib) + Regime Opposed", "Rejected at AutoFib zone while intermarket regime opposed direction. Close={{close}}")
alertcondition(breakAgainstEvent, "PIVOT BREAK (against) + Regime Opposed", "Broke pivot against AutoFib direction with intermarket opposition. Close={{close}}")
alertcondition(tagT1Event, "TARGET HIT: 1.236", "Warbird TARGET 1 (1.236) tagged. Price={{close}}")
alertcondition(tagT2Event, "TARGET HIT: 1.618", "Warbird TARGET 2 (1.618) tagged. Price={{close}}")
alertcondition(tagT3Event, "TARGET HIT: 2.0",   "Warbird TARGET 3 (2.0) tagged. Price={{close}}")
alertcondition(conflictEvent, "CONFLICT: Break vs VIX/DXY", "Caution: Break in AutoFib direction while VIX/DXY disagree. Close={{close}}")
alertcondition(hawkishNewsEvent, "NEWS PROXY: Hawkish Shock", "Macro reaction proxy flipped HAWKISH (risk-off posture). Close={{close}}")
alertcondition(dovishNewsEvent, "NEWS PROXY: Dovish Shock", "Macro reaction proxy flipped DOVISH (risk-on posture). Close={{close}}")
alertcondition(riskOnFlip, "Flip to RISK-ON", "Intermarket flipped to RISK-ON.")
alertcondition(riskOffFlip, "Flip to RISK-OFF", "Intermarket flipped to RISK-OFF.")
