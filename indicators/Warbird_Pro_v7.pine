// This Pine Script code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © Kirk / ZINC Digital
// Warbird Pro v7 — MES Fib Structure + Optuna Contract Surface
// Base: v6-warbird-complete.pine (2026-04-13)
// v7 Changes (2026-04-30):
//   - CUT: Entire footprint surface (request.footprint, volume_row.*, POC/delta/imbalance/zero-print)
//   - CUT: Momentum oscillators (VF/NFE/RSI-KNN, f_rsi_knn helper, 5 plot exports)
//   - CUT: Falling Window candlestick (weakest bear, -1.5% — kept top 3 per side)
//   - CUT: Dead-code longConfirmed/shortConfirmed (never wired into entry trigger)
//   - CUT: fibTouchVolDelta (footprint-dependent)
//   - ADD: Volume proxies — signedVol, CLV, volRatio (drop-in replacements for footprint intent)
//   - ADD: EMA(6) / MA(13) crossover as direction/momentum gate + visual + features
//   - ADD: p618 labeling clarification (projection-from-origin, NOT retracement-from-extreme)
//   - INPUT: optStopAtrMult capped at 3.0 (was 3.5)
//   - INPUT: optMaxRiskAtr capped at 3.0 (was 4.5)
//   - ICT: CHoCH/FVG/LiqSweep/Contrarian → kept as feature exports only, not in entry gate
//   - FIB ANCHOR LOGIC: UNTOUCHED. Verified clean.
//
// NO-REPAINT AUDIT:
// - All structure conditions gated by barstate.isconfirmed — signals fire at bar close only
// - request.security(): lookahead_off on all calls
// - Structure conditions: close-based, bar-close semantics
// - Last verified: 2026-04-30
//
// VWAP CODE: +2=reclaim, +1=above, 0=in-band, -1=below, -2=reject. Band=5% ATR around VWAP.
//
// REQUEST BUDGET (v7):
// HTF fib (1H):        [high, low] tuple                 = 1 call
// HTF fib (4H):        [high, low] tuple                 = 1 call
// HTF fib (1D):        [high, low] tuple                 = 1 call
// NYSE A-D Line (D):   close                             = 1 call
// REMOVED: Footprint                                     = -1 call
// TOTAL:                                                 = 4 request.* paths
//
// PLOT BUDGET (v7): 50 plot + 3 alertcondition = 53/64 (11 headroom)
//
//@version=6
indicator("Warbird Pro", shorttitle="WB ", overlay=true, max_lines_count=200, max_labels_count=200, max_boxes_count=100)
import TradingView/ZigZag/7 as zigzag

//=====================
// FIBONACCI ENGINE SETTINGS
//=====================
string groupFibEngine = "Fibonacci Engine"
bool autoTuneZZ = input.bool(false, "Auto-tune ZigZag by Timeframe", group=groupFibEngine,
  tooltip="ON: 4H+ uses Deviation=4/Depth=20, 1H uses Deviation=3.5/Depth=15, 15m uses Deviation=4/Depth=20, below 15m uses Deviation=3/Depth=15. Turn OFF to set values manually.")
float fibDeviationManual = input.float(4.0, "ZigZag Deviation (manual)",
  minval=0.5, maxval=20.0, step=0.5, group=groupFibEngine,
  tooltip="Only used when Auto-tune is OFF.")
int fibDepthManual = input.int(20, "ZigZag Depth (manual)",
  minval=2, maxval=50, group=groupFibEngine,
  tooltip="Only used when Auto-tune is OFF.")
float fibConfluenceTolPct = input.float(0.05, "Confluence Tolerance (%)", minval=0.01, maxval=2.00, step=0.01, group=groupFibEngine)
float fibThresholdFloorPct = input.float(0.50, "ZigZag Threshold Floor (%)", minval=0.0, maxval=5.0, step=0.05, group=groupFibEngine,
  tooltip="Minimum percent move required by the ZigZag after ATR scaling.")
float minFibRangeAtr = input.float(0.5, "Min Fib Range (ATR)", minval=0.5, maxval=10.0, step=0.1, group=groupFibEngine)

int _tfSec = timeframe.in_seconds()
float fibDeviation = autoTuneZZ
  ? (_tfSec >= 14400 ? 4.0 : _tfSec >= 3600 ? 3.5 : _tfSec >= 900 ? 4.0 : 3.0)
  : fibDeviationManual
int fibDepth = autoTuneZZ
  ? (_tfSec >= 14400 ? 20 : _tfSec >= 3600 ? 15 : _tfSec >= 900 ? 20 : 15)
  : fibDepthManual

//=====================
// CANONICAL FIB LEVELS (from lib/fibonacci.ts + FibLinesPrimitive.ts)
// DO NOT change these — they match the dashboard exactly.
//
// LABELING CONVENTION — IMPORTANT (v7 clarification):
// All fib levels are PROJECTIONS FROM THE SWING ORIGIN, not retracements from
// the swing extreme. The fibPrice() function below computes:
//     fibPrice(ratio) = fibBase + fibDir * fibRange * ratio
// where fibBase is the swing origin (low for bull, high for bear) and fibDir
// is +1 for bull / -1 for bear. So:
//   - FIB_618 (=0.618) is the price 61.8% projected FROM origin TOWARD extreme.
//     In conventional retracement-from-extreme terminology, this equals a
//     0.382 retracement.
//   - FIB_T2 (=1.618) is a measured-move extension 61.8% beyond the swing.
// The dashboard, alerts, Pine, and all downstream tooling use this same
// projection-from-origin convention end-to-end. Do not invert.
//=====================

// Retracement ratios
float FIB_ZERO  = 0.0
float FIB_236   = 0.236
float FIB_382   = 0.382
float FIB_PIVOT = 0.5
float FIB_618   = 0.618
float FIB_786   = 0.786
float FIB_ONE   = 1.0

// Extension ratios
float FIB_T1    = 1.236
float FIB_1272  = 1.272  // exhaustion geometry gate only — not drawn on chart
float FIB_W1382 = 1.382  // intermediate waypoint
float FIB_W150  = 1.5    // intermediate waypoint
float FIB_T2    = 1.618
float FIB_W1786 = 1.786  // intermediate waypoint
float FIB_T3    = 2.0
float FIB_T4    = 2.236
float FIB_T5    = 2.618

// Colors (TradingView settings defaults)
color COLOR_ANCHOR             = #FFFFFF    // white — 0, .5, 1 levels
color COLOR_RETRACEMENT        = #808080    // mid-gray — .236, .786, waypoints
color COLOR_RETRACEMENT_ACCENT = #B83B55    // rose — .382, .618
color COLOR_PIVOT              = #B0B0B0    // gray — pivot zone fill only
color COLOR_TARGET             = #006064    // teal — targets
color COLOR_STOP               = #CB3F3B    // red — stop loss / negative extension
color COLOR_ENTRY_LABEL        = #6D6E78    // gray — entry label

// Widths (TradingView settings defaults)
int WIDTH_ANCHOR      = 1
int WIDTH_RETRACEMENT = 1
int WIDTH_PIVOT       = 3
int WIDTH_TARGET      = 2

//=====================
// STRUCTURE LOGIC
//=====================
string groupLogic = "Structure Logic"
int retestBars   = input.int(1, "Acceptance Retest Window (bars)", minval=1, group=groupLogic)
bool rejectWick   = input.bool(true, "Rejection = wick into zone then close back out", group=groupLogic)
bool oneShotEvent = input.bool(true, "One-shot event markers/alerts", group=groupLogic)

bool gateShortsInBullTrend = input.bool(true, "Gate Shorts In Bull Trend", group=groupLogic,
  tooltip="Blocks bearish accept-entry triggers when the broader trend context is bullish and rising.")
float shortTrendGateAdx = input.float(10.0, "Short Gate ADX Floor", minval=5.0, maxval=50.0, step=0.5, group=groupLogic,
  tooltip="Minimum ADX required before the bullish-trend short gate activates.")

string groupStops = "Stop Logic"
string optEntryLevelInput = input.string("0.618", "Execution Anchor", options=["0.500", "0.618", "0.786"], group=groupStops,
  tooltip="Optuna-tuned execution line. The same fib ratio is used in both directions via fibPrice().")
float optStopAtrMult = input.float(1.5, "ATR Stop Multiplier", minval=1.0, maxval=3.0, step=0.1, group=groupStops,
  tooltip="Single-family ATR stop. v7: maxval capped at 3.0.")
float optMaxRiskAtr = input.float(3.0, "Max Setup Stop ATR", minval=1.0, maxval=3.0, step=0.25, group=groupStops,
  tooltip="Reject setup triggers whose ATR stop is too wide. v7: maxval capped at 3.0 to match optStopAtrMult ceiling.")

//=====================
// EXHAUSTION GEOMETRY (v7: footprint-free; uses signed-volume + CLV proxies below)
//=====================
string groupExh = "Exhaustion"
float exhaustionLevelAtrTol = input.float(0.10, "Extension ATR Tolerance", minval=0.01, maxval=0.50, step=0.01, group=groupExh,
  tooltip="ATR-normalized tolerance around 1.272 / 1.618 extensions for exhaustion geometry gate.")
int exhaustionSwingLookbackBarsInput = input.int(10, "Exhaustion Swing Lookback", minval=3, maxval=50, group=groupExh,
  tooltip="Bars used for swing-high/swing-low detection in exhaustion gates.")
int exhaustionCooldownBarsInput = input.int(8, "Exhaustion Cooldown Bars", minval=1, maxval=50, group=groupExh,
  tooltip="Bars to suppress repeat exhaustion events after a trigger.")

//=====================
// TREND / MA / VWAP / LIQ SWEEP GATE INPUTS
// Inputs default OFF so live behavior is unchanged unless the operator or the
// Optuna campaign flips the toggles.
//=====================
string groupTrendMaGate = "Trend / MA / VWAP / Liq Sweep"
bool useMaTrendFilter = input.bool(false, "Use MA Trend Filter", group=groupTrendMaGate,
  tooltip="When ON, requires MA-trend alignment for entries (long: maFast > maSlow AND close > maFast; short: inverse).")
string maFamily = input.string("EMA", "MA Family", options=["EMA", "SMA", "WMA", "HMA", "VWMA", "DEMA", "TEMA", "RMA"], group=groupTrendMaGate,
  tooltip="Moving-average family used by the MA Trend Filter.")
int maFastLen = input.int(21, "MA Fast Length", minval=2, maxval=200, group=groupTrendMaGate)
int maSlowLen = input.int(50, "MA Slow Length", minval=5, maxval=400, group=groupTrendMaGate)
bool useVwapGate = input.bool(false, "Use VWAP Gate", group=groupTrendMaGate,
  tooltip="When ON, requires close-vs-VWAP alignment for entries (long: close > VWAP; short: close < VWAP).")
int liqSweepLookbackBarsInput = input.int(10, "Liquidity Sweep Lookback", minval=3, maxval=200, group=groupTrendMaGate,
  tooltip="Bars used to define swing high/low for liquidity-sweep detection (feature-only in v7).")

//=====================
// EMA / MA CROSSOVER (v7 NEW — folded in from operator's working layout)
// Smoother direction/momentum signal than the existing EMA9/21/50 trio.
// Required-alignment gate for entries (configurable). Visualized in white/teal.
//=====================
string groupEmaCross = "EMA / MA Crossover"
bool showEmaCrossInput = input.bool(true, "Show EMA / MA Crossover lines", group=groupEmaCross)
int lengthEmaCross = input.int(6, "EMA Length (fast)", minval=2, maxval=200, group=groupEmaCross)
int lengthMaCross = input.int(13, "MA Length (slow)", minval=2, maxval=200, group=groupEmaCross,
  tooltip="Slow line uses SMA by default — matches the working layout aesthetic.")
bool useEmaCrossEntryGate = input.bool(true, "Require EMA/MA alignment for entries", group=groupEmaCross,
  tooltip="When ON: longs require EMA(fast) >= MA(slow); shorts require EMA(fast) <= MA(slow).")
color emaCrossFastColorInput = input.color(#26A69A, "EMA fast color", inline="emacross_fast", group=groupEmaCross)
int emaCrossFastWidthInput = input.int(2, "", minval=1, maxval=5, inline="emacross_fast", group=groupEmaCross)
color emaCrossSlowColorInput = input.color(#FFFFFF, "MA slow color", inline="emacross_slow", group=groupEmaCross)
int emaCrossSlowWidthInput = input.int(2, "", minval=1, maxval=5, inline="emacross_slow", group=groupEmaCross)

//=====================
// VISUALS (colors/widths locked to spec — see constants above)
//=====================
string groupViz = "Visuals"
int targetLookbackBars = input.int(40, "Target Line Lookback Bars", minval=5, maxval=500, group=groupViz)
bool extendLevelsRight = input.bool(true, "Extend Levels Right", group=groupViz)
bool useConfluenceAnchorSpan = input.bool(true, "Anchor Span = Active Fib Window", group=groupViz)
// EMA 9 / 21 / 50 visual inputs removed in v7 — EMA(6)/MA(13) crossover is the only MA display.
// Calculations (ema9, ema21, ema50) are retained below as they feed trendBiasLong/Short.
bool showVwapInput = input.bool(true, "Show VWAP", inline="vwap", group=groupViz)
color vwapColorInput = input.color(#FF2D7A, "", inline="vwap", group=groupViz)
int vwapWidthInput = input.int(2, "", minval=1, maxval=5, inline="vwap", group=groupViz)
string fibLineStyleInput = input.string("Solid", "Fib Line Style", options=["Solid", "Dashed", "Dotted"], group=groupViz)
color fibAnchorColorInput = input.color(COLOR_ANCHOR, "Anchor Fib", inline="fib_anchor", group=groupViz)
int fibAnchorWidthInput = input.int(WIDTH_ANCHOR, "", minval=1, maxval=5, inline="fib_anchor", group=groupViz)
color fibStopColorInput = input.color(COLOR_STOP, "Neg .236", inline="fib_stop", group=groupViz)
int fibStopWidthInput = input.int(WIDTH_RETRACEMENT, "", minval=1, maxval=5, inline="fib_stop", group=groupViz)
color fibRetracementColorInput = input.color(COLOR_RETRACEMENT, ".236 / .786 / Waypoints", inline="fib_retrace", group=groupViz)
int fibRetracementWidthInput = input.int(WIDTH_RETRACEMENT, "", minval=1, maxval=5, inline="fib_retrace", group=groupViz)
color fibRetracementAccentColorInput = input.color(COLOR_RETRACEMENT_ACCENT, ".382 / .618", inline="fib_accent", group=groupViz)
int fibRetracementAccentWidthInput = input.int(WIDTH_RETRACEMENT, "", minval=1, maxval=5, inline="fib_accent", group=groupViz)
color fibPivotColorInput = input.color(COLOR_PIVOT, "Pivot Zone", inline="fib_pivot", group=groupViz)
int fibPivotWidthInput = input.int(WIDTH_PIVOT, "", minval=1, maxval=5, inline="fib_pivot", group=groupViz)
color fibTargetColorInput = input.color(color.new(COLOR_TARGET, 50), "Targets", inline="fib_target", group=groupViz)
int fibTargetWidthInput = input.int(WIDTH_TARGET, "", minval=1, maxval=5, inline="fib_target", group=groupViz)
bool showFibLevelLabelsInput = input.bool(false, "Show Fib Level Labels", group=groupViz)
bool showTradeLabelsInput = input.bool(true, "Show Entry / SL / Target Labels", group=groupViz)
int tradeLabelOffsetBarsInput = input.int(10, "Trade Label Offset (bars)", minval=0, maxval=20, group=groupViz)
string tradeLabelSizeInput = input.string("Normal", "Trade Label Size", options=["Tiny", "Small", "Normal", "Large"], group=groupViz)
color tradeLabelTextColorInput = input.color(color.white, "Trade Label Text", inline="label_text", group=groupViz)
int tradeLabelBgTransparencyInput = input.int(60, "BG Alpha", minval=0, maxval=100, inline="label_text", group=groupViz)
color entryLabelColorInput = input.color(COLOR_ENTRY_LABEL, "Entry Label", inline="label_levels", group=groupViz)
color stopLabelColorInput = input.color(COLOR_STOP, "SL Label", inline="label_levels", group=groupViz)
color targetLabelColorInput = input.color(color.new(COLOR_TARGET, 50), "Target Label", inline="label_levels", group=groupViz)
int zoneFillTransparencyInput = input.int(80, "Zone Fill Alpha", minval=0, maxval=100, group=groupViz)

string groupDebug = "Debug Diagnostics"
bool enableDebugLogs = input.bool(false, "Enable Debug Logs", group=groupDebug, tooltip="Temporary state tracing for regime/probability diagnostics.")

f_line_style(string styleName) =>
    styleName == "Dashed" ? line.style_dashed : styleName == "Dotted" ? line.style_dotted : line.style_solid

f_label_size(string sizeName) =>
    sizeName == "Tiny" ? size.tiny : sizeName == "Normal" ? size.normal : sizeName == "Large" ? size.large : size.small

//=====================
// REGIME DETECTION (ADX/ER/vol)
//=====================

// --- ADX(14) + signed DI spread + ADX slope ---
int adxLen = 14
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)
float diSpread = diPlus - diMinus
float adxSlope = adxVal - nz(adxVal[3])

// Regime classification: trending vs ranging
bool regimeTrending = adxVal > 25
bool regimeRanging  = adxVal < 20

// --- Efficiency Ratio (10, 20) ---
float er10Direction = math.abs(close - close[10])
float er10Volatility = math.sum(math.abs(close - close[1]), 10)
float er10 = er10Volatility != 0 ? er10Direction / er10Volatility : 0.0

float er20Direction = math.abs(close - close[20])
float er20Volatility = math.sum(math.abs(close - close[1]), 20)
float er20 = er20Volatility != 0 ? er20Direction / er20Volatility : 0.0

// --- ATR percentage (normalized volatility) ---
float atrRaw = ta.atr(20)
float atrPct = close != 0 ? atrRaw / close * 100.0 : 0.0

//=====================
// TA CORE PACK (15-metric feature set for offline training capture)
// Deterministic, point-in-time safe, no lookahead, no external dependencies.
//=====================
float ema9 = ta.ema(close, 9)
float ema21 = ta.ema(close, 21)
float ema50 = ta.ema(close, 50)
float ema200 = ta.ema(close, 200)
float ema100 = ta.ema(close, 100)
[_macdFast, _macdSlow, macdHist] = ta.macd(close, 12, 26, 9)
float rsi14 = ta.rsi(close, 14)
float atr14 = ta.atr(14)

// Bar geometry (used everywhere downstream — keep early)
float barRange = high - low

//=====================
// VOLUME PROXIES (v7 NEW — drop-in replacements for the cut footprint surface)
//
// signedVol — replaces fpDelta (footprint delta).
//   sign(body) * volume * (|body| / range). Strong directional bars produce
//   large magnitudes; doji-like bars produce near-zero. Range -volume..+volume.
//
// clv — replaces "POC near low / POC near high" intent.
//   Williams' close-location value. Range -1..+1.
//   +1 = close at high (rejection of lows / accumulation cap on bear bar)
//   -1 = close at low (rejection of highs / distribution on bull bar)
//   0  = close at midpoint
//
// volRatio — replaces "imbalance / institutional bar" intent.
//   volume / SMA(volume, 20). > 1.2 = above-average participation.
//=====================
float bodySign = close > open ? 1.0 : close < open ? -1.0 : 0.0
float bodyAbs = math.abs(close - open)
float signedVol = bodySign * volume * math.min(1.0, bodyAbs / math.max(barRange, syminfo.mintick))
float clv = barRange > 0 ? ((close - low) - (high - close)) / barRange : 0.0
float volSma20 = ta.sma(volume, 20)
float volRatio = volSma20 > 0 ? volume / volSma20 : 1.0
bool volExpansion = volRatio >= 1.2

// Direction-aligned volume gates (mirror the cut footprint triple gate:
// delta + POC position + imbalance → signedVol + clv + volRatio).
bool volumeLongOk = signedVol > 0 and clv >= 0.20 and volExpansion
bool volumeShortOk = signedVol < 0 and clv <= -0.20 and volExpansion

// Tighter version for exhaustion (rejection bars at extremes):
//   bull at swing low → close MUST be in upper portion of bar
//   bear at swing high → close MUST be in lower portion of bar
bool exhVolumeBullOk = signedVol > 0 and clv >= 0.30 and volExpansion
bool exhVolumeBearOk = signedVol < 0 and clv <= -0.30 and volExpansion

//=====================
// EMA / MA CROSSOVER (v7 NEW — folded in)
//=====================
float emaFastCross = ta.ema(close, lengthEmaCross)
float maSlowCross  = ta.sma(close, lengthMaCross)
int emaCrossDir = emaFastCross > maSlowCross ? 1 : emaFastCross < maSlowCross ? -1 : 0
float emaCrossSpread = atr14 > 0 ? (emaFastCross - maSlowCross) / atr14 : 0.0
bool emaGoldenCross = ta.crossover(emaFastCross, maSlowCross)
bool emaDeathCross  = ta.crossunder(emaFastCross, maSlowCross)
bool emaCrossLongOk = (not useEmaCrossEntryGate) or (emaFastCross >= maSlowCross)
bool emaCrossShortOk = (not useEmaCrossEntryGate) or (emaFastCross <= maSlowCross)

//=====================
// OPENING RANGE (first 30 min of RTH: 8:30-9:00 CT)
//=====================
bool isRTHOpen = (hour == 8 and minute >= 30) or (hour == 9 and minute == 0)
var float orHigh = na
var float orLow = na
var bool orLocked = false

if hour == 8 and minute == 30 and (hour[1] != 8 or minute[1] != 30)
    orHigh := high
    orLow := low
    orLocked := false

if isRTHOpen and not orLocked
    orHigh := math.max(nz(orHigh, high), high)
    orLow := math.min(nz(orLow, low), low)

if hour == 9 and minute > 0 and not orLocked
    orLocked := true

int orState = orLocked ? (close > orHigh ? 1 : close < orLow ? -1 : 0) : 0
float orMid = orLocked ? (orHigh + orLow) / 2.0 : na
float orDistNorm = (orLocked and not na(orMid) and atr14 > 0) ? (close - orMid) / atr14 : 0.0

//=====================
// ECONOMIC EVENT DAY PROXY (NFP / FOMC / CPI approximation)
//=====================
bool isNFPDay   = dayofweek == dayofweek.friday    and dayofmonth <= 7
bool isFOMCDay  = dayofweek == dayofweek.wednesday and dayofmonth >= 8 and dayofmonth <= 21
bool isCPIDay   = dayofweek == dayofweek.tuesday   and dayofmonth >= 8 and dayofmonth <= 14
bool isEventDay = isNFPDay or isFOMCDay or isCPIDay

//=====================
// LIQUIDITY SWEEP DETECTION (ICT — v7: feature-only, NOT in entry gate)
//=====================
int swingLookback = liqSweepLookbackBarsInput
float swingHigh = ta.highest(high, swingLookback)[1]
float swingLow = ta.lowest(low, swingLookback)[1]
bool liqSweepBull = low < swingLow and close > swingLow
bool liqSweepBear = high > swingHigh and close < swingHigh

//=====================
// CHANGE OF CHARACTER (CHoCH — v7: feature-only)
//=====================
int chochPivotLen = 5
float pvtHi = ta.pivothigh(high, chochPivotLen, chochPivotLen)
float pvtLo = ta.pivotlow(low, chochPivotLen, chochPivotLen)

var float lastPvtHi = na
var float lastPvtLo = na
if not na(pvtHi)
    lastPvtHi := pvtHi
if not na(pvtLo)
    lastPvtLo := pvtLo

bool chochBull = not na(lastPvtHi) and close > lastPvtHi and close[1] <= lastPvtHi
bool chochBear = not na(lastPvtLo) and close < lastPvtLo and close[1] >= lastPvtLo

//=====================
// FAIR VALUE GAP (FVG — v7: feature-only)
//=====================
bool fvgBull = high[2] < low
bool fvgBear = low[2] > high

var float nearestFvgBullMid = na
var float nearestFvgBearMid = na
if fvgBull
    nearestFvgBullMid := (high[2] + low) / 2.0
if fvgBear
    nearestFvgBearMid := (low[2] + high) / 2.0

if not na(nearestFvgBullMid) and low < nearestFvgBullMid
    nearestFvgBullMid := na
if not na(nearestFvgBearMid) and high > nearestFvgBearMid
    nearestFvgBearMid := na

float fvgBullDist = (not na(nearestFvgBullMid) and atr14 > 0) ? (close - nearestFvgBullMid) / atr14 : 0.0
float fvgBearDist = (not na(nearestFvgBearMid) and atr14 > 0) ? (nearestFvgBearMid - close) / atr14 : 0.0

//=====================
// HTF FIB CONFLUENCE (1H, 4H, Daily)
//=====================
float htfConfTolPct = 0.15

[htf1hHigh, htf1hLow] = request.security(syminfo.tickerid, "60", [ta.highest(high, 55), ta.lowest(low, 55)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
[htf4hHigh, htf4hLow] = request.security(syminfo.tickerid, "240", [ta.highest(high, 55), ta.lowest(low, 55)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
[htf1dHigh, htf1dLow] = request.security(syminfo.tickerid, "D", [ta.highest(high, 55), ta.lowest(low, 55)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

float htf1hRange = nz(htf1hHigh - htf1hLow)
float htf4hRange = nz(htf4hHigh - htf4hLow)
float htf1dRange = nz(htf1dHigh - htf1dLow)

htfFibPrice(float htfHigh, float htfLow, float htfRng, float ratio) =>
    htfRng <= 0 ? na : htfLow + htfRng * ratio

float htf1hP382 = htfFibPrice(htf1hHigh, htf1hLow, htf1hRange, FIB_382)
float htf1hP500 = htfFibPrice(htf1hHigh, htf1hLow, htf1hRange, FIB_PIVOT)
float htf1hP618 = htfFibPrice(htf1hHigh, htf1hLow, htf1hRange, FIB_618)

float htf4hP382 = htfFibPrice(htf4hHigh, htf4hLow, htf4hRange, FIB_382)
float htf4hP500 = htfFibPrice(htf4hHigh, htf4hLow, htf4hRange, FIB_PIVOT)
float htf4hP618 = htfFibPrice(htf4hHigh, htf4hLow, htf4hRange, FIB_618)

float htf1dP382 = htfFibPrice(htf1dHigh, htf1dLow, htf1dRange, FIB_382)
float htf1dP500 = htfFibPrice(htf1dHigh, htf1dLow, htf1dRange, FIB_PIVOT)
float htf1dP618 = htfFibPrice(htf1dHigh, htf1dLow, htf1dRange, FIB_618)

htfConfluenceCheck(float level15m, float currentFibRange) =>
    if na(level15m) or na(currentFibRange) or currentFibRange <= 0
        0
    else
        float tol = currentFibRange * htfConfTolPct * 0.01
        int hits = 0
        if not na(htf1hP382) and math.abs(level15m - htf1hP382) <= tol
            hits += 1
        if not na(htf1hP500) and math.abs(level15m - htf1hP500) <= tol
            hits += 1
        if not na(htf1hP618) and math.abs(level15m - htf1hP618) <= tol
            hits += 1
        if not na(htf4hP382) and math.abs(level15m - htf4hP382) <= tol
            hits += 1
        if not na(htf4hP500) and math.abs(level15m - htf4hP500) <= tol
            hits += 1
        if not na(htf4hP618) and math.abs(level15m - htf4hP618) <= tol
            hits += 1
        if not na(htf1dP382) and math.abs(level15m - htf1dP382) <= tol
            hits += 1
        if not na(htf1dP500) and math.abs(level15m - htf1dP500) <= tol
            hits += 1
        if not na(htf1dP618) and math.abs(level15m - htf1dP618) <= tol
            hits += 1
        hits

//=====================
// AUTO FIB ENGINE — ZigZag confirmed pivots (non-repainting)
// FIB ANCHOR LOGIC IS SACRED — UNTOUCHED FROM v6.
//=====================
fibZzUpdate() =>
    var fibSettings = zigzag.Settings.new(fibDeviation, fibDepth, color(na), false, false, false, false, "Absolute", true)
    var fibZZ = zigzag.newInstance(fibSettings)
    zigzag.Pivot lastPvt = na
    fibSettings.devThreshold := math.max(ta.atr(10) / close * 100 * fibDeviation, fibThresholdFloorPct)
    bool newPivot = false
    float pivotHighPrice = na
    float pivotLowPrice = na
    int pivotHighBar = na
    int pivotLowBar = na
    int swingDir = 0
    if fibZZ.update()
        lastPvt := fibZZ.lastPivot()
        if not na(lastPvt)
            newPivot := true
            float startP = lastPvt.start.price
            float endP = lastPvt.end.price
            pivotHighPrice := math.max(startP, endP)
            pivotLowPrice  := math.min(startP, endP)
            swingDir := endP > startP ? 1 : endP < startP ? -1 : 0
            if startP >= endP
                pivotHighBar := lastPvt.start.index
                pivotLowBar  := lastPvt.end.index
            else
                pivotHighBar := lastPvt.end.index
                pivotLowBar  := lastPvt.start.index
    [newPivot, pivotHighPrice, pivotLowPrice, pivotHighBar, pivotLowBar, swingDir]

[zzNewPivot, zzHighPrice, zzLowPrice, zzHighBar, zzLowBar, zzSwingDir] = fibZzUpdate()

var float fibAnchorHigh = na
var float fibAnchorLow = na
var int anchorHighBar = na
var int anchorLowBar = na
var int lastBreakBar = na

if zzNewPivot
    fibAnchorHigh := zzHighPrice
    fibAnchorLow  := zzLowPrice
    anchorHighBar := zzHighBar
    anchorLowBar  := zzLowBar
    lastBreakBar  := na

// Pre-compute rolling high/low at each confluence period at global scope.
// ta.highest/ta.lowest require a compile-time-constant length.
float _cqH8  = ta.highest(high, 8)
float _cqL8  = ta.lowest(low,  8)
float _cqH13 = ta.highest(high, 13)
float _cqL13 = ta.lowest(low,  13)
float _cqH21 = ta.highest(high, 21)
float _cqL21 = ta.lowest(low,  21)
float _cqH34 = ta.highest(high, 34)
float _cqL34 = ta.lowest(low,  34)
float _cqH55 = ta.highest(high, 55)
float _cqL55 = ta.lowest(low,  55)

float confluenceQuality = na
if not na(fibAnchorHigh) and not na(fibAnchorLow)
    float anchorRange = fibAnchorHigh - fibAnchorLow
    if anchorRange > 0
        float tol = anchorRange * fibConfluenceTolPct * 0.01
        int confHits = 0
        array<float> _cqPairs = array.from(_cqH8, _cqL8, _cqH13, _cqL13, _cqH21, _cqL21, _cqH34, _cqL34, _cqH55, _cqL55)
        for pairIdx = 0 to 4
            float rollingH = array.get(_cqPairs, pairIdx * 2)
            float rollingL = array.get(_cqPairs, pairIdx * 2 + 1)
            float rollingRange = rollingH - rollingL
            if rollingRange > 0
                for ratioIdx = 0 to 2
                    float ratio = ratioIdx == 0 ? 0.382 : ratioIdx == 1 ? 0.5 : 0.618
                    float anchorLevel = fibAnchorLow + anchorRange * ratio
                    float rollingLevel = rollingL + rollingRange * ratio
                    if math.abs(anchorLevel - rollingLevel) <= tol
                        confHits += 1
        confluenceQuality := float(confHits) * anchorRange

float fibRange = fibAnchorHigh - fibAnchorLow
float minFibRange = minFibRangeAtr * atr14
bool isValid = not na(fibAnchorHigh) and not na(fibAnchorLow) and fibRange >= minFibRange

float fibMidpoint = fibAnchorLow + fibRange * 0.5
float fibHystBand = fibRange * 0.02

var bool fibBull = true
if isValid
    if close >= fibMidpoint + fibHystBand
        fibBull := true
    else if close <= fibMidpoint - fibHystBand
        fibBull := false
else
    fibBull := true

float fibBase = fibBull ? fibAnchorLow : fibAnchorHigh
float fibDir = fibBull ? 1.0 : -1.0
fibPrice(float ratio) =>
    fibRange <= 0 ? na : (fibBase + fibDir * fibRange * ratio)

float pZero   = fibPrice(FIB_ZERO)
float pNeg236 = fibPrice(-FIB_236)
float p236    = fibPrice(FIB_236)
float p382    = fibPrice(FIB_382)
float pPivot  = fibPrice(FIB_PIVOT)
float p618    = fibPrice(FIB_618)
float p786    = fibPrice(FIB_786)
float pOne    = fibPrice(FIB_ONE)
float pT1     = fibPrice(FIB_T1)
float p1382   = fibPrice(FIB_W1382)
float p150    = fibPrice(FIB_W150)
float pT2     = fibPrice(FIB_T2)
float p1786   = fibPrice(FIB_W1786)
float pT3     = fibPrice(FIB_T3)
float pT4     = fibPrice(FIB_T4)
float pT5     = fibPrice(FIB_T5)

float entryZoneUpper = math.max(pPivot, p786)
float entryZoneLower = math.min(pPivot, p786)
float zoneUpper = math.max(p618, p786)
float zoneLower = math.min(p618, p786)

float zoneFillUpper = math.max(p382, p618)
float zoneFillLower = math.min(p382, p618)

float htfConfRange = fibRange
int htfConfPivot = htfConfluenceCheck(pPivot, htfConfRange)
int htfConf382   = htfConfluenceCheck(p382, htfConfRange)
int htfConf618   = htfConfluenceCheck(p618, htfConfRange)
int htfConfTotal = htfConfPivot + htfConf382 + htfConf618

//=====================
// CANDLESTICK PATTERN DETECTION — EMPIRICALLY VALIDATED ON MES 15m
// v7: Top 3 per side. Falling Window cut (-1.5%, weakest bear).
// Source: backtest indicator on MES 15m, 5+ years.
//=====================
float bodySize = math.abs(close - open)
float bodyRatio = barRange > 0 ? bodySize / barRange : 0.0
bool bullishCandle = close > open
bool bearishCandle = close < open
float upperWickSize = high - math.max(open, close)
float lowerWickSize = math.min(open, close) - low
float upperWickRatio = barRange > 0 ? upperWickSize / barRange : 0.0
float lowerWickRatio = barRange > 0 ? lowerWickSize / barRange : 0.0

// ── PROVEN BULLISH (top 3) ──────────────────────────────────────────────
// Long Lower Shadow (+3.9% at 1:6 R:R — STRONGEST bullish on MES 15m)
bool longLowerShadow = lowerWickRatio >= 0.55 and upperWickRatio <= 0.25
// Dragonfly Doji (+1.2%)
bool dragonflyDoji = lowerWickRatio >= 0.60 and bodyRatio <= 0.15
// Rising Window / Gap Up (+0.9%)
bool risingWindow = low > high[1]

// ── PROVEN BEARISH (top 3) ──────────────────────────────────────────────
// Long Upper Shadow (-7.7% — STRONGEST bearish)
bool longUpperShadow = upperWickRatio >= 0.55 and lowerWickRatio <= 0.25
// Bearish Engulfing (-6.6%)
bool bearishEngulfing = bearishCandle and bullishCandle[1] and close < open[1] and open > close[1]
// Shooting Star (-5.6%)
bool shootingStar = upperWickRatio >= 0.50 and bodyRatio <= 0.35 and bearishCandle

// ── EXCLUDED (proven losers OR weakest of group) ────────────────────────
// Falling Window:    -1.5% — CUT in v7 (weakest bear, top-3 trim)
// Hammer:            -1.0% to -2.0% — LOSER
// Bullish Engulfing: -1.4% to -5.3% — LOSER
// Inverted Hammer:   -1.0% to -3.0% — LOSER
// Doji Star (Bull):  -1.2% to -2.3% — LOSER

bool provenBullishPattern = longLowerShadow or dragonflyDoji or risingWindow
bool provenBearishPattern = longUpperShadow or bearishEngulfing or shootingStar

//=====================
// WICK REJECTION AT FIB ZONE (kept — primary price-action confirmation)
//=====================
bool wickRejectBull = not na(zoneLower) and low < zoneLower and close > zoneLower and bullishCandle
bool wickRejectBear = not na(zoneUpper) and high > zoneUpper and close < zoneUpper and bearishCandle

//=====================
// NYSE BREADTH + EMA DIRECTION HELPER
//=====================
f_ema_dir(float emaVal) =>
    close > emaVal and emaVal > nz(emaVal[1], emaVal) ? 1 : close < emaVal and emaVal < nz(emaVal[1], emaVal) ? -1 : 0

f_ema_dist_pct(float emaVal) =>
    emaVal != 0 ? (close - emaVal) / emaVal * 100.0 : 0.0

// MA family helper. Used by the optional MA Trend Filter gate.
maValue(float src, simple int len, simple string family) =>
    switch family
        "EMA"  => ta.ema(src, len)
        "SMA"  => ta.sma(src, len)
        "WMA"  => ta.wma(src, len)
        "HMA"  => ta.hma(src, len)
        "VWMA" => ta.vwma(src, len)
        "RMA"  => ta.rma(src, len)
        "DEMA" => 2.0 * ta.ema(src, len) - ta.ema(ta.ema(src, len), len)
        "TEMA" => 3.0 * ta.ema(src, len) - 3.0 * ta.ema(ta.ema(src, len), len) + ta.ema(ta.ema(ta.ema(src, len), len), len)
        => ta.ema(src, len)

// NYSE Advance-Decline issues (daily breadth)
float adLineRaw   = request.security("USI:ADD", "D", close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
float adSlope     = adLineRaw - nz(adLineRaw[3])
float adSlopeSma  = ta.sma(math.abs(adSlope), 20)
float adSlopeNorm = adSlopeSma > 0 ? adSlope / adSlopeSma : 0.0

//=====================
// ES EXECUTION QUALITY (chart-native, zero security calls)
//=====================
float vwapVal = ta.vwap(hlc3)
float vwapBand = atrRaw * 0.05
int vwapState = close > vwapVal + vwapBand ? 1 : close < vwapVal - vwapBand ? -1 : 0
int prevVwapSt = nz(vwapState[1], 0)
int vwapCode = vwapState == 0 ? 0 : vwapState == 1 ? (prevVwapSt == -1 ? 2 : 1) : (prevVwapSt == 1 ? -2 : -1)
float avgRange5 = ta.sma(barRange, 5)
float rangeExpansion = barRange / math.max(avgRange5, syminfo.mintick)
float rangeExpClamped = math.min(rangeExpansion, 5.0)
float barEfficiency = math.abs(close - open) / math.max(barRange, syminfo.mintick)
float execDir = vwapCode == 2 ? 1.0 : vwapCode == -2 ? -1.0 : vwapCode == 1 ? 0.5 : vwapCode == -1 ? -0.5 : 0.0
float execQual = 0.5 * barEfficiency + 0.5 * math.min(rangeExpClamped / 3.0, 1.0)
float execScore = execDir * (0.5 + 0.5 * execQual)
bool bullishTrendBlocksShorts = gateShortsInBullTrend and (
    adxVal >= shortTrendGateAdx and
    diPlus > diMinus and
    close > ema100 and
    ema100 > nz(ema100[1], ema100) and
    vwapCode >= 0 and
    adSlopeNorm >= 0)

//=====================
// STRUCTURE CONDITIONS (direction-aware)
//=====================
bool confirmed = barstate.isconfirmed
int dir = fibBull ? 1 : -1
bool zoneReady = not na(zoneUpper) and not na(zoneLower) and not na(pPivot)
bool breakInDir = zoneReady and confirmed ? (dir == 1 ? (close > zoneUpper and close[1] <= zoneUpper) : (close < zoneLower and close[1] >= zoneLower)) : false
if breakInDir
    lastBreakBar := bar_index
int barsSinceBreak = na(lastBreakBar) ? int(na) : bar_index - lastBreakBar
bool acceptInDir = (
 zoneReady and confirmed and
 not na(barsSinceBreak) and barsSinceBreak > 0 and barsSinceBreak <= retestBars and
    (dir == 1 ? (low <= zoneUpper and close > zoneUpper) : (high >= zoneLower and close < zoneLower))
)
bool rejectAtZone = (
 zoneReady and confirmed and
    (rejectWick ?
        (dir == 1 ? (high >= zoneLower and close < zoneLower) : (low <= zoneUpper and close > zoneUpper)) :
        (dir == 1 ? (close < zoneLower) : (close > zoneUpper)))
)
bool breakAgainst = zoneReady and confirmed ? (dir == 1 ? (close < pPivot and close[1] >= pPivot) : (close > pPivot and close[1] <= pPivot)) : false
bool tagT1 = confirmed and not na(pT1) and (dir == 1 ? high >= pT1 : low <= pT1)
bool tagT2 = confirmed and not na(pT2) and (dir == 1 ? high >= pT2 : low <= pT2)
bool tagT3 = confirmed and not na(pT3) and (dir == 1 ? high >= pT3 : low <= pT3)
bool acceptConfirmed = acceptInDir
bool rejectConfirmed = rejectAtZone
bool breakAgainstConfirmed = breakAgainst
bool acceptEvent = oneShotEvent ? (acceptConfirmed and not acceptConfirmed[1]) : acceptConfirmed
bool rejectEvent = oneShotEvent ? (rejectConfirmed and not rejectConfirmed[1]) : rejectConfirmed
bool breakAgainstEvent = oneShotEvent ? (breakAgainstConfirmed and not breakAgainstConfirmed[1]) : breakAgainstConfirmed
bool tagT1Event = oneShotEvent ? (tagT1 and not tagT1[1]) : tagT1
bool tagT2Event = oneShotEvent ? (tagT2 and not tagT2[1]) : tagT2
bool tagT3Event = oneShotEvent ? (tagT3 and not tagT3[1]) : tagT3
bool tagT4 = confirmed and not na(pT4) and (dir == 1 ? high >= pT4 : low <= pT4)
bool tagT5 = confirmed and not na(pT5) and (dir == 1 ? high >= pT5 : low <= pT5)
bool tagT4Event = oneShotEvent ? (tagT4 and not tagT4[1]) : tagT4
bool tagT5Event = oneShotEvent ? (tagT5 and not tagT5[1]) : tagT5

var bool ladderInvalidated = false
if zzNewPivot
    ladderInvalidated := false
if breakAgainstConfirmed
    ladderInvalidated := true

bool pivotNearZone = isValid and close <= zoneUpper and close >= zoneLower
int eventPivotInteractionCode = breakInDir ? 4 : rejectAtZone ? 3 : acceptInDir ? 1 : breakAgainst ? 2 : pivotNearZone ? 5 : 0

bool setupAcceptContinuation = acceptConfirmed
bool setupZoneRejection = rejectConfirmed
bool setupPivotContinuation = breakInDir
bool setupFailedMoveReversal = breakAgainstConfirmed
bool setupReentryAfterTp1 = tagT1 and acceptInDir
int setupArchetypeCode = setupAcceptContinuation ? 1 : setupZoneRejection ? 2 : setupPivotContinuation ? 3 : setupFailedMoveReversal ? 4 : setupReentryAfterTp1 ? 5 : 0

int fibLevelTouched = 0
if isValid
    float nearest = math.abs(close - p236)
    fibLevelTouched := 236
    float d382 = math.abs(close - p382)
    if d382 < nearest
        nearest := d382
        fibLevelTouched := 382
    float d500 = math.abs(close - pPivot)
    if d500 < nearest
        nearest := d500
        fibLevelTouched := 500
    float d618 = math.abs(close - p618)
    if d618 < nearest
        nearest := d618
        fibLevelTouched := 618
    float d786 = math.abs(close - p786)
    if d786 < nearest
        nearest := d786
        fibLevelTouched := 786
    float d100 = math.abs(close - pOne)
    if d100 < nearest
        fibLevelTouched := 100

//=====================
// EXHAUSTION DIAMOND — v7: FOOTPRINT-FREE
// Geometry gate (1.272 / 1.618 extension touch) + swing extreme + cooldown
// + session filter + proven candlestick + volume proxy.
//=====================

float p1272 = fibPrice(FIB_1272)
float exhaustionTol = atr14 * exhaustionLevelAtrTol
bool exhAt1272 = not na(p1272) and (dir == 1 ? high >= p1272 - exhaustionTol : low <= p1272 + exhaustionTol)
bool exhAt1618 = not na(pT2) and (dir == 1 ? high >= pT2 - exhaustionTol : low <= pT2 + exhaustionTol)
bool mlExhGeomConfluence = isValid and confirmed and (exhAt1272 or exhAt1618)
float exhaustionTriggerPrice = exhAt1618 ? pT2 : exhAt1272 ? p1272 : (dir == 1 ? high : low)

// Swing extreme
bool isSwingHighBar = high >= ta.highest(high, exhaustionSwingLookbackBarsInput)
bool isSwingLowBar = low <= ta.lowest(low, exhaustionSwingLookbackBarsInput)

// Cooldown
var int lastBearExhTriggerBar = na
var int lastBullExhTriggerBar = na
int exhCooldown = exhaustionCooldownBarsInput
bool bearCooldownOk = na(lastBearExhTriggerBar) or bar_index - lastBearExhTriggerBar >= exhCooldown
bool bullCooldownOk = na(lastBullExhTriggerBar) or bar_index - lastBullExhTriggerBar >= exhCooldown

int hourEt = hour(time, "America/New_York")
bool mlExhSessionValid = hourEt != 17

// v7: Three-requirement gate, all mandatory:
//   1. PROVEN candlestick pattern (top-3 per side)
//   2. SIGNED-VOLUME aligns with direction (replaces fpDelta)
//   3. CLV at extreme + volume expansion (replaces POC + imbalance)
// PLUS: swing extreme + cooldown + session filter
bool bullCandleProven = longLowerShadow or dragonflyDoji
bool bullishExhaustion = mlExhSessionValid and confirmed and isSwingLowBar and bullCooldownOk and exhVolumeBullOk and bullCandleProven

bool bearCandleProven = longUpperShadow or bearishEngulfing or shootingStar
bool bearishExhaustion = mlExhSessionValid and confirmed and isSwingHighBar and bearCooldownOk and exhVolumeBearOk and bearCandleProven

int mlExhConfidenceTier = bullishExhaustion or bearishExhaustion ? 1 : 0
int exhaustionSignalDir = bearishExhaustion ? -1 : bullishExhaustion ? 1 : 0

if confirmed and bearishExhaustion
    lastBearExhTriggerBar := bar_index
if confirmed and bullishExhaustion
    lastBullExhTriggerBar := bar_index

//=====================
// TRADE STATE MACHINE
//=====================
var int TRADE_NONE    = 0
var int TRADE_SETUP   = 1
var int TRADE_ACTIVE  = 2
var int TRADE_HIT_TP1 = 3
var int TRADE_HIT_TP2 = 4
var int TRADE_STOPPED = 5
var int TRADE_EXPIRED = 6
var int TRADE_HIT_TP3 = 7
var int TRADE_HIT_TP4 = 8
var int TRADE_HIT_TP5 = 9

var int tradeState = TRADE_NONE
var float entryPrice = na
var float slPrice = na
var float tp1Price = na
var float tp2Price = na
var float tp3Price = na
var float tp4Price = na
var float tp5Price = na
var float entryAtr = na
var int setupBar = na
var int entryBar = na
var int lastExitBar = na
var int lastExitDir = 0
var int tradeDir = 0
var int lastExitOutcome = 0
var int highestTargetHit = 0
var int lastExhTriggerBar = na
var int lastExhTriggerDir = 0
var int lastTier1ExhBar = na
var int lastTier1ExhDir = 0
var int mlContConfidenceTier = 0
int cooldownLen = 8
int barsSinceExit = not na(lastExitBar) ? bar_index - lastExitBar : 999
bool cooldownActive = barsSinceExit < cooldownLen

roundToTick(float price) =>
    na(price) ? na : math.round(price / syminfo.mintick) * syminfo.mintick

float optEntryRatio = optEntryLevelInput == "0.500" ? FIB_PIVOT : optEntryLevelInput == "0.786" ? FIB_786 : FIB_618
int stopFamilyCode = 3

float entryLevel = fibPrice(optEntryRatio)
float slLevel    = not isValid or na(entryLevel) ? na : roundToTick(fibBull ? entryLevel - atr14 * optStopAtrMult : entryLevel + atr14 * optStopAtrMult)
float tp1Level   = pT1
float tp2Level   = pT2
float tp3Level   = pT3
float tp4Level   = pT4
float tp5Level   = pT5

float slDistPts = math.abs(entryLevel - slLevel)
float slDistAtr = atr14 > 0 ? slDistPts / atr14 : 0.0
bool trendBiasLong = ema9 > ema21 and close >= ema50 and close >= vwapVal
bool trendBiasShort = ema9 < ema21 and close <= ema50 and close <= vwapVal

// Soft MA + VWAP gates (default OFF)
float maFastValue = useMaTrendFilter ? maValue(close, maFastLen, maFamily) : na
float maSlowValue = useMaTrendFilter ? maValue(close, maSlowLen, maFamily) : na
bool maGatePassLong  = (not useMaTrendFilter) or (not na(maFastValue) and not na(maSlowValue) and maFastValue > maSlowValue and close > maFastValue)
bool maGatePassShort = (not useMaTrendFilter) or (not na(maFastValue) and not na(maSlowValue) and maFastValue < maSlowValue and close < maFastValue)
bool vwapGatePassLong  = (not useVwapGate) or close > vwapVal
bool vwapGatePassShort = (not useVwapGate) or close < vwapVal
bool entryZoneTouched = not na(entryZoneUpper) and not na(entryZoneLower) and high >= entryZoneLower and low <= entryZoneUpper
bool entryAnchorBullTrigger = confirmed and not na(entryLevel) and low <= entryLevel and close >= entryLevel
bool entryAnchorBearTrigger = confirmed and not na(entryLevel) and high >= entryLevel and close <= entryLevel

// v7: Volume confirmation now uses signed-vol + CLV + volume expansion (replaces footprint).
bool volumeLongTrigger = volumeLongOk
bool volumeShortTrigger = volumeShortOk

bool atrRiskAcceptable = not na(slLevel) and atr14 > 0 and slDistAtr <= optMaxRiskAtr
bool setupContextLong = dir == 1 and trendBiasLong and entryZoneTouched and atrRiskAcceptable
bool setupContextShort = dir == -1 and trendBiasShort and entryZoneTouched and atrRiskAcceptable
bool setupContextActive = setupContextLong or setupContextShort

// v7: EMA(6)/MA(13) crossover alignment is the new direction/momentum gate.
bool longTriggerCore = setupContextLong and entryAnchorBullTrigger and volumeLongTrigger and emaCrossLongOk
bool shortTriggerCore = setupContextShort and entryAnchorBearTrigger and volumeShortTrigger and emaCrossShortOk
bool longTriggerEvent = longTriggerCore and (oneShotEvent ? not longTriggerCore[1] : true)
bool shortTriggerEvent = shortTriggerCore and (oneShotEvent ? not shortTriggerCore[1] : true)
bool entryLongTrigger = longTriggerEvent and not ladderInvalidated and maGatePassLong and vwapGatePassLong
bool entryShortTrigger = shortTriggerEvent and not ladderInvalidated and not bullishTrendBlocksShorts and maGatePassShort and vwapGatePassShort

if enableDebugLogs and barstate.isconfirmed and (acceptEvent or rejectEvent or breakAgainstEvent or entryLongTrigger or entryShortTrigger)
    log.info(str.format("WBDBG_EVENT bar={0} dir={1} accept={2} reject={3} breakAgainst={4} longTrig={5} shortTrig={6} shortGate={7} signedVol={8} clv={9} volRatio={10}", bar_index, dir, acceptEvent, rejectEvent, breakAgainstEvent, entryLongTrigger, entryShortTrigger, bullishTrendBlocksShorts, signedVol, clv, volRatio))

if confirmed
    if exhaustionSignalDir != 0
        lastExhTriggerBar := bar_index
        lastExhTriggerDir := exhaustionSignalDir
        if mlExhConfidenceTier == 1
            lastTier1ExhBar := bar_index
            lastTier1ExhDir := exhaustionSignalDir

    if tradeState == TRADE_NONE and setupContextActive and not cooldownActive and not ladderInvalidated
        tradeState := TRADE_SETUP
        setupBar := bar_index

    if tradeState == TRADE_SETUP and (entryLongTrigger or entryShortTrigger)
        entryPrice := entryLevel
        slPrice := slLevel
        tp1Price := tp1Level
        tp2Price := tp2Level
        tp3Price := tp3Level
        tp4Price := tp4Level
        tp5Price := tp5Level
        entryAtr := atr14
        tradeDir  := dir
        highestTargetHit := 0
        tradeState := TRADE_ACTIVE
        entryBar := bar_index

    bool tradeInFlight = tradeState == TRADE_ACTIVE or tradeState == TRADE_HIT_TP1 or tradeState == TRADE_HIT_TP2 or tradeState == TRADE_HIT_TP3 or tradeState == TRADE_HIT_TP4

    float activeTradeStopPrice = tradeInFlight ? slPrice : na
    if tradeInFlight and not na(slPrice) and not na(entryPrice)
        if tradeDir == 1
            float longRatchet = slPrice
            if highestTargetHit >= 1
                longRatchet := math.max(longRatchet, roundToTick(entryPrice))
            if highestTargetHit >= 2 and not na(tp1Price)
                longRatchet := math.max(longRatchet, tp1Price)
            if highestTargetHit >= 3 and not na(tp2Price)
                longRatchet := math.max(longRatchet, tp2Price)
            if highestTargetHit >= 4 and not na(tp3Price)
                longRatchet := math.max(longRatchet, tp3Price)
            activeTradeStopPrice := longRatchet
        else if tradeDir == -1
            float shortRatchet = slPrice
            if highestTargetHit >= 1
                shortRatchet := math.min(shortRatchet, roundToTick(entryPrice))
            if highestTargetHit >= 2 and not na(tp1Price)
                shortRatchet := math.min(shortRatchet, tp1Price)
            if highestTargetHit >= 3 and not na(tp2Price)
                shortRatchet := math.min(shortRatchet, tp2Price)
            if highestTargetHit >= 4 and not na(tp3Price)
                shortRatchet := math.min(shortRatchet, tp3Price)
            activeTradeStopPrice := shortRatchet

    if tradeInFlight and not na(activeTradeStopPrice)
        slPrice := activeTradeStopPrice

    bool canResolveTrade = tradeInFlight and not na(entryBar) and bar_index > entryBar
    if canResolveTrade
        if tradeDir == 1
            int targetHitNow = high >= tp5Price ? 5 : high >= tp4Price ? 4 : high >= tp3Price ? 3 : high >= tp2Price ? 2 : high >= tp1Price ? 1 : 0
            if low <= activeTradeStopPrice
                tradeState := TRADE_STOPPED
            else if targetHitNow > highestTargetHit
                highestTargetHit := targetHitNow
                tradeState := targetHitNow == 5 ? TRADE_HIT_TP5 : targetHitNow == 4 ? TRADE_HIT_TP4 : targetHitNow == 3 ? TRADE_HIT_TP3 : targetHitNow == 2 ? TRADE_HIT_TP2 : TRADE_HIT_TP1
        else
            int targetHitNow = low <= tp5Price ? 5 : low <= tp4Price ? 4 : low <= tp3Price ? 3 : low <= tp2Price ? 2 : low <= tp1Price ? 1 : 0
            if high >= activeTradeStopPrice
                tradeState := TRADE_STOPPED
            else if targetHitNow > highestTargetHit
                highestTargetHit := targetHitNow
                tradeState := targetHitNow == 5 ? TRADE_HIT_TP5 : targetHitNow == 4 ? TRADE_HIT_TP4 : targetHitNow == 3 ? TRADE_HIT_TP3 : targetHitNow == 2 ? TRADE_HIT_TP2 : TRADE_HIT_TP1

    if tradeState == TRADE_SETUP and not na(setupBar) and bar_index - setupBar > 12
        lastExitOutcome := 4
        tradeState := TRADE_EXPIRED

    bool tradeResolved = tradeState == TRADE_STOPPED or tradeState == TRADE_EXPIRED or tradeState == TRADE_HIT_TP5
    if tradeResolved
        lastExitOutcome := tradeState == TRADE_EXPIRED ? 4 : highestTargetHit == 5 ? 7 : highestTargetHit == 4 ? 6 : highestTargetHit == 3 ? 5 : highestTargetHit == 2 ? 2 : highestTargetHit == 1 ? 1 : 3
        lastExitDir := tradeDir
        lastExitBar := bar_index
        tradeState := TRADE_NONE
        entryPrice := na
        slPrice := na
        tp1Price := na
        tp2Price := na
        tp3Price := na
        tp4Price := na
        tp5Price := na
        entryAtr := na
        setupBar := na
        entryBar := na
        highestTargetHit := 0

bool tradeInFlightNow = tradeState == TRADE_ACTIVE or tradeState == TRADE_HIT_TP1 or tradeState == TRADE_HIT_TP2 or tradeState == TRADE_HIT_TP3 or tradeState == TRADE_HIT_TP4
float activeStopPrice = tradeInFlightNow ? slPrice : na
float mlExhBarsSinceTrigger = not na(lastExhTriggerBar) ? float(bar_index - lastExhTriggerBar) : na
fibLineStyle = f_line_style(fibLineStyleInput)
tradeLabelSize = f_label_size(tradeLabelSizeInput)

// Contrarian reversal feature (CHoCH opposite to last completed trade direction within 10 bars of exit)
bool contrChoch = barsSinceExit > 0 and barsSinceExit <= 10 and (
    (lastExitDir == 1  and chochBear) or
    (lastExitDir == -1 and chochBull))

bool tradeVisible = tradeState == TRADE_SETUP or tradeState == TRADE_ACTIVE or tradeState == TRADE_HIT_TP1 or tradeState == TRADE_HIT_TP2 or tradeState == TRADE_HIT_TP3 or tradeState == TRADE_HIT_TP4
bool tradeSetupVisible = tradeState == TRADE_SETUP and not na(setupBar) and not na(slLevel)
bool tradeProjectionVisible = tradeSetupVisible or (tradeInFlightNow and not na(entryPrice))
bool showTradeLevels = showTradeLabelsInput and tradeInFlightNow and not na(entryPrice)

//=====================
// DRAW ALL FIB LEVELS
//=====================
var line lineZero  = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineNeg236 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line236   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line382   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line linePivot = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line line618   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line786   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineOne   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineT1    = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line line1382  = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line150   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineT2    = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line line1786  = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineT3    = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line lineT4    = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line lineT5    = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line lineActiveSl = line.new(bar_index, close, bar_index, close, color=color(na), width=2)

var box zoneBox = box.new(bar_index, close, bar_index, close, bgcolor=color(na), border_color=color(na))

var label _lblEntry = label.new(bar_index, close, "", style=label.style_label_left, color=color(na), textcolor=color.new(color.white, 20), size=size.small)
var label _lblSl    = label.new(bar_index, close, "", style=label.style_label_left, color=color(na), textcolor=color.new(COLOR_STOP, 20),   size=size.small)
var label _lblT1    = label.new(bar_index, close, "", style=label.style_label_left, color=color(na), textcolor=color.new(COLOR_TARGET, 20),  size=size.small)
var label _lblT2    = label.new(bar_index, close, "", style=label.style_label_left, color=color(na), textcolor=color.new(COLOR_TARGET, 20),  size=size.small)
var label _lblT3    = label.new(bar_index, close, "", style=label.style_label_left, color=color(na), textcolor=color.new(COLOR_TARGET, 20),  size=size.small)
var label _lblT4    = label.new(bar_index, close, "", style=label.style_label_left, color=color(na), textcolor=color.new(COLOR_TARGET, 20),  size=size.small)
var label _lblT5    = label.new(bar_index, close, "", style=label.style_label_left, color=color(na), textcolor=color.new(COLOR_TARGET, 20),  size=size.small)
var label _fibLblZero = na
var label _fibLblNeg236 = na
var label _fibLbl236 = na
var label _fibLbl382 = na
var label _fibLblPivot = na
var label _fibLbl618 = na
var label _fibLbl786 = na
var label _fibLblOne = na
var label _fibLblT1 = na
var label _fibLbl1382 = na
var label _fibLbl150 = na
var label _fibLblT2 = na
var label _fibLbl1786 = na
var label _fibLblT3 = na
var label _fibLblT4 = na
var label _fibLblT5 = na

int fallbackLeftBar = int(math.max(0, bar_index - targetLookbackBars))
bool anchorBarsReady = not na(anchorHighBar) and not na(anchorLowBar)
int anchorStartBar = anchorBarsReady ? int(math.max(0, math.min(anchorHighBar, anchorLowBar))) : fallbackLeftBar
int drawLeftBarBase = useConfluenceAnchorSpan ? anchorStartBar : fallbackLeftBar
int drawLeftBar = int(math.max(drawLeftBarBase, anchorStartBar))

drawAnchoredLine(line id, bool visible, float price, color col, int width_, int leftBar) =>
    if visible and not na(price)
        int clampedLeftBar = int(math.max(leftBar, anchorStartBar))
        int rightBar = extendLevelsRight ? bar_index + tradeLabelOffsetBarsInput : bar_index
        line.set_xy1(id, clampedLeftBar, price)
        line.set_xy2(id, rightBar, price)
        line.set_color(id, col)
        line.set_width(id, width_)
        line.set_style(id, fibLineStyle)
        line.set_extend(id, extend.none)
    else
        line.set_color(id, color(na))

setFibLevelLabel(label idIn, bool visible, float price, string txt, color col) =>
    label id = idIn
    if visible and isValid and not na(price)
        int labelX = bar_index + tradeLabelOffsetBarsInput
        string labelText = txt + "  " + str.tostring(price, format.mintick)
        if na(id)
            id := label.new(labelX, price, labelText, style=label.style_label_left, color=color.new(color.black, tradeLabelBgTransparencyInput), textcolor=col, size=tradeLabelSize)
        label.set_xy(id, labelX, price)
        label.set_text(id, labelText)
        label.set_color(id, color.new(color.black, tradeLabelBgTransparencyInput))
        label.set_textcolor(id, col)
        label.set_size(id, tradeLabelSize)
    else if not na(id)
        label.delete(id)
        id := na
    id

drawAnchoredLine(lineZero,  true, pZero,  fibAnchorColorInput,             fibAnchorWidthInput,             drawLeftBar)
drawAnchoredLine(lineNeg236, false, pNeg236, fibStopColorInput,            fibStopWidthInput,               drawLeftBar)
drawAnchoredLine(line236,   true, p236,   fibRetracementColorInput,        fibRetracementWidthInput,        drawLeftBar)
drawAnchoredLine(line382,   true, p382,   fibRetracementAccentColorInput,  fibRetracementAccentWidthInput,  drawLeftBar)
drawAnchoredLine(linePivot, true, pPivot, fibAnchorColorInput,             fibPivotWidthInput,              drawLeftBar)
drawAnchoredLine(line618,   true, p618,   fibRetracementAccentColorInput,  fibRetracementAccentWidthInput,  drawLeftBar)
drawAnchoredLine(line786,   true, p786,   fibRetracementColorInput,        fibRetracementWidthInput,        drawLeftBar)
drawAnchoredLine(lineOne,   true, pOne,   fibAnchorColorInput,             fibAnchorWidthInput,             drawLeftBar)
drawAnchoredLine(lineT1,    true, pT1,    fibTargetColorInput,             fibTargetWidthInput,             drawLeftBar)
drawAnchoredLine(line1382,  true, p1382,  fibRetracementColorInput,        fibRetracementWidthInput,        drawLeftBar)
drawAnchoredLine(line150,   true, p150,   fibRetracementColorInput,        fibRetracementWidthInput,        drawLeftBar)
drawAnchoredLine(lineT2,    true, pT2,    fibTargetColorInput,             fibTargetWidthInput,             drawLeftBar)
drawAnchoredLine(line1786,  true, p1786,  fibRetracementColorInput,        fibRetracementWidthInput,        drawLeftBar)
drawAnchoredLine(lineT3,    true, pT3,    fibTargetColorInput,             fibTargetWidthInput,             drawLeftBar)
drawAnchoredLine(lineT4,    true, pT4,    fibTargetColorInput,             fibTargetWidthInput,             drawLeftBar)
drawAnchoredLine(lineT5,    true, pT5,    fibTargetColorInput,             fibTargetWidthInput,             drawLeftBar)

float slVisualLevel = tradeInFlightNow ? activeStopPrice : tradeState == TRADE_SETUP ? slLevel : na
int slLeftBar = tradeInFlightNow and not na(entryBar) ? entryBar : tradeState == TRADE_SETUP and not na(setupBar) ? setupBar : bar_index
drawAnchoredLine(lineActiveSl, tradeProjectionVisible and not na(slVisualLevel), slVisualLevel, stopLabelColorInput, fibStopWidthInput, slLeftBar)

if barstate.islast
    _fibLblZero := setFibLevelLabel(_fibLblZero, showFibLevelLabelsInput, pZero, "0", fibAnchorColorInput)
    _fibLblNeg236 := setFibLevelLabel(_fibLblNeg236, false, pNeg236, "-.236", fibStopColorInput)
    _fibLbl236 := setFibLevelLabel(_fibLbl236, showFibLevelLabelsInput, p236, ".236", fibRetracementColorInput)
    _fibLbl382 := setFibLevelLabel(_fibLbl382, showFibLevelLabelsInput, p382, ".382", fibRetracementAccentColorInput)
    _fibLblPivot := setFibLevelLabel(_fibLblPivot, showFibLevelLabelsInput, pPivot, ".500", fibAnchorColorInput)
    _fibLbl618 := setFibLevelLabel(_fibLbl618, showFibLevelLabelsInput, p618, ".618", fibRetracementAccentColorInput)
    _fibLbl786 := setFibLevelLabel(_fibLbl786, showFibLevelLabelsInput, p786, ".786", fibRetracementColorInput)
    _fibLblOne := setFibLevelLabel(_fibLblOne, showFibLevelLabelsInput, pOne, "1.000", fibAnchorColorInput)
    _fibLblT1 := setFibLevelLabel(_fibLblT1, showFibLevelLabelsInput, pT1, "T1", fibTargetColorInput)
    _fibLbl1382 := setFibLevelLabel(_fibLbl1382, showFibLevelLabelsInput, p1382, "1.382", fibRetracementColorInput)
    _fibLbl150 := setFibLevelLabel(_fibLbl150, showFibLevelLabelsInput, p150, "1.500", fibRetracementColorInput)
    _fibLblT2 := setFibLevelLabel(_fibLblT2, showFibLevelLabelsInput, pT2, "T2", fibTargetColorInput)
    _fibLbl1786 := setFibLevelLabel(_fibLbl1786, showFibLevelLabelsInput, p1786, "1.786", fibRetracementColorInput)
    _fibLblT3 := setFibLevelLabel(_fibLblT3, showFibLevelLabelsInput, pT3, "T3", fibTargetColorInput)
    _fibLblT4 := setFibLevelLabel(_fibLblT4, showFibLevelLabelsInput, pT4, "T4", fibTargetColorInput)
    _fibLblT5 := setFibLevelLabel(_fibLblT5, showFibLevelLabelsInput, pT5, "T5", fibTargetColorInput)

if barstate.islast and showTradeLevels and not na(activeStopPrice) and not na(tp1Price) and not na(tp2Price) and not na(tp3Price) and not na(tp4Price) and not na(tp5Price)
    float slLabelLevel = activeStopPrice
    label.set_xy(_lblEntry, bar_index + tradeLabelOffsetBarsInput, entryPrice)
    label.set_text(_lblEntry, "ENTRY " + str.tostring(entryPrice, format.mintick))
    label.set_color(_lblEntry, color.new(entryLabelColorInput, tradeLabelBgTransparencyInput))
    label.set_textcolor(_lblEntry, tradeLabelTextColorInput)
    label.set_size(_lblEntry, tradeLabelSize)
    label.set_xy(_lblSl, bar_index + tradeLabelOffsetBarsInput, slLabelLevel)
    label.set_text(_lblSl, "SL " + str.tostring(slLabelLevel, format.mintick))
    label.set_color(_lblSl, color.new(stopLabelColorInput, tradeLabelBgTransparencyInput))
    label.set_textcolor(_lblSl, tradeLabelTextColorInput)
    label.set_size(_lblSl, tradeLabelSize)
    label.set_xy(_lblT1, bar_index + tradeLabelOffsetBarsInput, tp1Price)
    label.set_text(_lblT1, "T1 " + str.tostring(tp1Price, format.mintick))
    label.set_color(_lblT1, color.new(targetLabelColorInput, tradeLabelBgTransparencyInput))
    label.set_textcolor(_lblT1, tradeLabelTextColorInput)
    label.set_size(_lblT1, tradeLabelSize)
    label.set_xy(_lblT2, bar_index + tradeLabelOffsetBarsInput, tp2Price)
    label.set_text(_lblT2, "T2 " + str.tostring(tp2Price, format.mintick))
    label.set_color(_lblT2, color.new(targetLabelColorInput, tradeLabelBgTransparencyInput))
    label.set_textcolor(_lblT2, tradeLabelTextColorInput)
    label.set_size(_lblT2, tradeLabelSize)
    label.set_xy(_lblT3, bar_index + tradeLabelOffsetBarsInput, tp3Price)
    label.set_text(_lblT3, "T3 " + str.tostring(tp3Price, format.mintick))
    label.set_color(_lblT3, color.new(targetLabelColorInput, tradeLabelBgTransparencyInput))
    label.set_textcolor(_lblT3, tradeLabelTextColorInput)
    label.set_size(_lblT3, tradeLabelSize)
    label.set_xy(_lblT4, bar_index + tradeLabelOffsetBarsInput, tp4Price)
    label.set_text(_lblT4, "T4 " + str.tostring(tp4Price, format.mintick))
    label.set_color(_lblT4, color.new(targetLabelColorInput, tradeLabelBgTransparencyInput))
    label.set_textcolor(_lblT4, tradeLabelTextColorInput)
    label.set_size(_lblT4, tradeLabelSize)
    label.set_xy(_lblT5, bar_index + tradeLabelOffsetBarsInput, tp5Price)
    label.set_text(_lblT5, "T5 " + str.tostring(tp5Price, format.mintick))
    label.set_color(_lblT5, color.new(targetLabelColorInput, tradeLabelBgTransparencyInput))
    label.set_textcolor(_lblT5, tradeLabelTextColorInput)
    label.set_size(_lblT5, tradeLabelSize)
else if barstate.islast
    label.set_text(_lblEntry, "")
    label.set_text(_lblSl, "")
    label.set_text(_lblT1, "")
    label.set_text(_lblT2, "")
    label.set_text(_lblT3, "")
    label.set_text(_lblT4, "")
    label.set_text(_lblT5, "")
    label.set_color(_lblEntry, color(na))
    label.set_color(_lblSl, color(na))
    label.set_color(_lblT1, color(na))
    label.set_color(_lblT2, color(na))
    label.set_color(_lblT3, color(na))
    label.set_color(_lblT4, color(na))
    label.set_color(_lblT5, color(na))

if entryLongTrigger
    label.new(bar_index, entryLevel, "▲", style=label.style_label_up, color=color.new(targetLabelColorInput, 20), textcolor=tradeLabelTextColorInput, size=tradeLabelSize, force_overlay=true)
if entryShortTrigger
    label.new(bar_index, entryLevel, "▼", style=label.style_label_down, color=color.new(stopLabelColorInput, 20), textcolor=tradeLabelTextColorInput, size=tradeLabelSize, force_overlay=true)

if not na(zoneFillUpper) and not na(zoneFillLower)
    box.set_left(zoneBox, drawLeftBar)
    box.set_right(zoneBox, bar_index)
    box.set_top(zoneBox, zoneFillUpper)
    box.set_bottom(zoneBox, zoneFillLower)
    box.set_bgcolor(zoneBox, color.new(fibPivotColorInput, zoneFillTransparencyInput))
    box.set_border_color(zoneBox, color.new(fibPivotColorInput, 100))
else
    box.set_bgcolor(zoneBox, color(na))
    box.set_border_color(zoneBox, color(na))

//=====================
// VISIBLE PLOTS (overlay)
//=====================
// EMA 9 / 21 / 50 plots removed — EMA(6)/MA(13) is the only MA display.
plot(showVwapInput ? vwapVal : na, "VWAP", vwapColorInput, vwapWidthInput, display=display.all)

// v7 NEW: EMA(6) / MA(13) crossover — folded in from operator's working layout
plot(showEmaCrossInput ? emaFastCross : na, "EMA Cross Fast", emaCrossFastColorInput, emaCrossFastWidthInput, display=display.all)
plot(showEmaCrossInput ? maSlowCross  : na, "MA Cross Slow",  emaCrossSlowColorInput, emaCrossSlowWidthInput, display=display.all)

//=====================
// OPTUNA FEATURE EXPORT (hidden — display=display.none)
//=====================

// ── FIB ENGINE ──
plot(fibRange, "fib_range", display=display.none, editable=false)
plot(pNeg236, "ml_fib_neg_0236", display=display.none, editable=false)
plot(nz(confluenceQuality), "confluence_quality", display=display.none, editable=false)
plot(float(htfConfPivot), "htf_conf_pivot", display=display.none, editable=false)
plot(float(htfConf382), "htf_conf_382", display=display.none, editable=false)
plot(float(htfConf618), "htf_conf_618", display=display.none, editable=false)
plot(float(htfConfTotal), "htf_conf_total", display=display.none, editable=false)

// ── STRUCTURE / MODEL CONTRACT ──
plot(float(dir), "ml_direction_code", display=display.none, editable=false)
plot(float(setupArchetypeCode), "ml_setup_archetype_code", display=display.none, editable=false)
plot(float(fibLevelTouched), "ml_fib_level_touched", display=display.none, editable=false)
plot(float(stopFamilyCode), "ml_stop_family_code", display=display.none, editable=false)
plot(float(eventPivotInteractionCode), "ml_event_pivot_interaction_code", display=display.none, editable=false)

// ── TRADE STATE MACHINE ──
plot(float(tradeState), "trade_state", display=display.none, editable=false)
plot(tradeVisible and tradeState != TRADE_SETUP and not na(entryBar) ? float(bar_index - entryBar) : 0.0, "bars_in_trade", display=display.none, editable=false)
plot(cooldownActive ? 1.0 : 0.0, "ml_cooldown_active", display=display.none, editable=false)
plot(math.min(float(barsSinceExit), 999.0), "ml_bars_since_exit", display=display.none, editable=false)
plot(slDistAtr, "ml_sl_dist_atr", display=display.none, editable=false)

// ── LABEL SURFACE ──
// ml_last_exit_outcome: 0=none, 1=TP1_HIT, 2=TP2_HIT, 3=STOPPED, 4=EXPIRED, 5=TP3_HIT, 6=TP4_HIT, 7=TP5_HIT
plot(float(lastExitOutcome), "ml_last_exit_outcome", display=display.none, editable=false)
plot(tagT1Event ? 1.0 : 0.0, "ml_tp1_hit_event", display=display.none, editable=false)
plot(tagT2Event ? 1.0 : 0.0, "ml_tp2_hit_event", display=display.none, editable=false)
plot(tagT3Event ? 1.0 : 0.0, "ml_tp3_hit_event", display=display.none, editable=false)
plot(tagT4Event ? 1.0 : 0.0, "ml_tp4_hit_event", display=display.none, editable=false)
plot(tagT5Event ? 1.0 : 0.0, "ml_tp5_hit_event", display=display.none, editable=false)

// ── VOLUME PROXIES (v7 NEW — replaces footprint exports) ──
plot(signedVol, "ml_signed_vol", display=display.none, editable=false)
plot(clv, "ml_clv", display=display.none, editable=false)
plot(volRatio, "ml_vol_ratio", display=display.none, editable=false)
plot(liqSweepBull ? 1.0 : liqSweepBear ? -1.0 : 0.0, "ml_liq_sweep", display=display.none, editable=false)

// ── EXHAUSTION (v7 — footprint-free) ──
plot(mlExhGeomConfluence ? 1.0 : 0.0, "ml_exh_geom_confluence", display=display.none, editable=false)
plot(float(mlExhConfidenceTier), "ml_exh_confidence_tier", display=display.none, editable=false)
plot(mlExhSessionValid ? 1.0 : 0.0, "ml_exh_session_valid", display=display.none, editable=false)
plot(mlExhBarsSinceTrigger, "ml_exh_bars_since_trigger", display=display.none, editable=false)
plot(float(mlContConfidenceTier), "ml_cont_confidence_tier", display=display.none, editable=false)
plot(mlExhConfidenceTier > 0 and tradeInFlightNow and exhaustionSignalDir != tradeDir ? 1.0 : 0.0, "ml_reversal_warning_in_trade", display=display.none, editable=false)

// ── ICT FEATURES (v7 — kept as features only, not in entry gate) ──
plot(chochBull ? 1.0 : chochBear ? -1.0 : 0.0, "ml_choch", display=display.none, editable=false)
// PIT NOTE: chochBull/chochBear fire at bar N+5 (ta.pivothigh rightbars=5).
// The offline pipeline MUST timestamp these at the emit bar.
plot(fvgBullDist, "ml_fvg_bull_dist", display=display.none, editable=false)
plot(fvgBearDist, "ml_fvg_bear_dist", display=display.none, editable=false)
plot(contrChoch ? 1.0 : 0.0, "ml_contrarian_choch", display=display.none, editable=false)

// ── SESSION / TIMING ──
plot(float(orState), "ml_or_state", display=display.none, editable=false)
plot(orDistNorm, "ml_or_dist_norm", display=display.none, editable=false)

// ── ES EXECUTION QUALITY ──
plot(float(vwapCode), "ml_vwap_code", display=display.none, editable=false)

// ── MACRO CONTEXT ──
plot(adSlopeNorm, "ml_adline_slope", display=display.none, editable=false)

// ── EMA / MA CROSSOVER (v7 NEW — folded in) ──
plot(float(emaCrossDir), "ml_ema_cross_dir", display=display.none, editable=false)
plot(emaCrossSpread, "ml_ema_cross_spread", display=display.none, editable=false)
plot(emaGoldenCross ? 1.0 : 0.0, "ml_ema_golden_cross", display=display.none, editable=false)
plot(emaDeathCross ? 1.0 : 0.0, "ml_ema_death_cross", display=display.none, editable=false)

