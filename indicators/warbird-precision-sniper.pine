//@version=6
// ══════════════════════════════════════════════════════════
// Warbird PRECISION SNIPER
// ══════════════════════════════════════════════════════════
// Author:  Kirk Musick
// Version: 1.3.0
//
// Pure PrecSniper trigger engine. Entries driven by EMA cross + momentum +
// RSI bounds + confluence score + grade filter. Optional signal layers
// (ICT/SMC, candlestick patterns, VF/NFE/RSI-KNN) feed the confluence score
// and are individually togglable as Optuna dims.

indicator(
    title            = "Warbird Precision Sniper",
    shorttitle       = "PrecSniper",
    overlay          = true,
    max_labels_count = 500,
    max_lines_count  = 500,
    max_boxes_count  = 500,
    max_bars_back    = 5000)

// ══════════════════════════════════════
// CONSTANTS
// ══════════════════════════════════════
GRP_MAIN   = "⚙️ Main Settings"
GRP_ENTRY  = "🎯 Entry Engine"
GRP_RISK   = "🛡️ Risk Management"
GRP_VISUAL = "🎨 Visual Settings"
GRP_DASH   = "📊 Dashboard"
GRP_ALERT  = "🔔 Alerts"
GRP_COLORS   = "🎨 Colors"
GRP_SIGNALS  = "🔬 Signal Layers"

INDICATOR_VERSION = "v1.3.0"

// ══════════════════════════════════════
// INPUTS — Main Settings
// ══════════════════════════════════════
sourceInput = input.source(close, "Source", group = GRP_MAIN, tooltip = "Price source for all calculations.\nDefault: close")

htfInput = input.timeframe("", "HTF Trend Filter", group = GRP_MAIN, tooltip = "Higher timeframe for trend bias.\nLeave empty = current TF.\nRecommended: 1H for 5-15M, 4H for 1H, D for 4H")

presetInput = input.string("Auto", "Preset", options = ["Auto", "Conservative", "Default", "Aggressive", "Scalping", "Swing", "Crypto 24/7", "Custom"], group = GRP_MAIN, tooltip = "Quick presets:\n• Auto: selects best preset for current timeframe\n• Conservative: fewer signals, higher reliability\n• Default: balanced\n• Aggressive: more signals, faster response\n• Scalping: optimized for 1-5min timeframes\n• Swing: optimized for 4H-D timeframes\n• Crypto 24/7: wider stops, no session bias\n• Custom: uses all manual settings below as-is")

// ══════════════════════════════════════
// INPUTS — Entry Engine
// ══════════════════════════════════════
emaFastLenInput = input.int(9, "EMA Fast Length", minval = 3, maxval = 50, group = GRP_ENTRY, tooltip = "Fast EMA for trend direction.\nOverridden by presets (except Custom).\nRecommended: 8-12")
emaSlowLenInput = input.int(21, "EMA Slow Length", minval = 10, maxval = 100, group = GRP_ENTRY, tooltip = "Slow EMA for trend confirmation.\nOverridden by presets (except Custom).\nRecommended: 20-30")
emaTrendLenInput = input.int(55, "EMA Trend Length", minval = 20, maxval = 200, group = GRP_ENTRY, tooltip = "Long EMA for macro trend filter.\nOverridden by presets (except Custom).\nRecommended: 50-100")

minScoreInput = input.int(5, "Min Confluence Score", minval = 1, maxval = 10, group = GRP_ENTRY, tooltip = "Minimum confluence points to trigger signal.\nOverridden by presets (except Custom).\n• Max possible: 10")

rsiLenInput = input.int(13, "RSI Length", minval = 5, maxval = 30, group = GRP_ENTRY, tooltip = "RSI period for momentum filter.\nOverridden by presets (except Custom).\nRecommended: 14")

gradeFilterInput = input.string("All", "Signal Grade Filter", options = ["All", "A+ and A", "A+ Only"], group = GRP_ENTRY, tooltip = "Filter signals by quality grade:\n• All: show every valid signal\n• A+ and A: only high-quality signals (score ≥ 6.5)\n• A+ Only: only premium signals (score ≥ 8.0)")

hideCGradeInput = input.bool(true, "Hide C-Grade Signals", group = GRP_ENTRY, tooltip = "When enabled, signals with score < 5.0 (C grade) are filtered out.")

// ══════════════════════════════════════
// INPUTS — Risk Management
// ══════════════════════════════════════
atrLenInput = input.int(14, "ATR Length", minval = 5, maxval = 50, group = GRP_RISK, tooltip = "ATR period for volatility measurement.\nOverridden by presets (except Custom).\nRecommended: 14")
slMultInput = input.float(1.5, "SL ATR Multiplier", minval = 0.5, maxval = 5.0, step = 0.1, group = GRP_RISK, tooltip = "Stop Loss distance = ATR × this value.\n• Tight: 1.0-1.5\n• Default: 1.5\n• Wide: 2.0-3.0")

tp1MultInput = input.float(1.0, "TP1 Risk:Reward", minval = 0.5, maxval = 5.0, step = 0.1, group = GRP_RISK, tooltip = "TP1 = Entry ± (SL distance × this). Recommended: 1.0")
tp2MultInput = input.float(2.0, "TP2 Risk:Reward", minval = 1.0, maxval = 8.0, step = 0.1, group = GRP_RISK, tooltip = "TP2 = Entry ± (SL distance × this). Recommended: 2.0")
tp3MultInput = input.float(3.0, "TP3 Risk:Reward", minval = 1.5, maxval = 12.0, step = 0.5, group = GRP_RISK, tooltip = "TP3 = Entry ± (SL distance × this). Recommended: 3.0")

useTrailInput = input.bool(true, "Enable Trailing Stop", group = GRP_RISK, tooltip = "After TP1 hit, trail SL to breakeven.\nAfter TP2 hit, trail SL to TP1 level.\nReduces drawdown on winning trades.")

useStructureSLInput = input.bool(true, "Structure-Based SL", group = GRP_RISK, tooltip = "Place SL below/above recent swing low/high\ninstead of pure ATR-based SL.")
swingLookbackInput = input.int(10, "Swing Lookback", minval = 3, maxval = 30, group = GRP_RISK, tooltip = "Bars to look back for swing high/low.")

// Post-TP3 runner management. Trail engages ONLY after TP3 hits — per research
// (KJ 567k, DataDriven 2M backtest studies, Turtle/Raschke/Bandy). Stepped per-TP
// ratcheting is a documented anti-pattern that kills runners.
postTp3ModeInput          = input.string("ATR Chandelier", "Post-TP3 Mode", options = ["Hold TP2", "ATR Chandelier", "Swing Trail", "Close at TP3"], group = GRP_RISK, tooltip = "Hold TP2: trail stays at TP2. ATR Chandelier: LeBeau trail from post-TP3 extreme (recommended). Swing Trail: trail from recent swing. Close at TP3: take 3R immediately.")
postTp3AtrMultInput       = input.float(3.0, "Post-TP3 Chandelier Mult", minval = 1.0, maxval = 3.5, step = 0.25, group = GRP_RISK, tooltip = "Chandelier trail = highest_high_since_TP3 - mult x ATR(len). LeBeau canonical default: 3.0. Tighter = earlier exit; wider = larger giveback.")
postTp3AtrLenInput        = input.int(22, "Post-TP3 Chandelier ATR Length", minval = 10, maxval = 50, group = GRP_RISK, tooltip = "Chandelier ATR period (LeBeau canonical: 22). Independent of entry-engine ATR so Optuna can tune them separately.")
postTp3SwingLookbackInput = input.int(10, "Post-TP3 Swing Lookback", minval = 3, maxval = 30, group = GRP_RISK, tooltip = "Swing lookback bars. Only used with 'Swing Trail' mode.")

// ══════════════════════════════════════
// INPUTS — Visual Settings
// ══════════════════════════════════════
themeInput = input.string("Auto", "Theme", options = ["Auto", "Dark", "Light"], group = GRP_VISUAL, tooltip = "Chart color theme.")

showSignalsInput   = input.bool(true,  "Show Buy/Sell Signals",  group = GRP_VISUAL)
signalSizeInput    = input.string("Small", "Signal Label Size", options = ["Tiny", "Small", "Normal", "Large", "Huge"], group = GRP_VISUAL)
showTPSLInput      = input.bool(true,  "Show TP/SL Lines",       group = GRP_VISUAL)
showRibbonInput    = input.bool(true,  "Show EMA Ribbon",        group = GRP_VISUAL)
showTrailInput     = input.bool(true,  "Show Trailing Stop",     group = GRP_VISUAL)
showBgInput        = input.bool(false, "Show Background Color",  group = GRP_VISUAL)
showWatermarkInput = input.bool(true,  "Show Watermark",         group = GRP_VISUAL)
showGradeInput     = input.bool(true,  "Show Signal Grade",      group = GRP_VISUAL)

labelOffsetInput   = input.int(3, "Label Offset (bars)", minval = 1, maxval = 50, group = GRP_VISUAL, tooltip = "Bars right of the last candle for TP/SL labels.\nTight: 2-3. Loose: 15-25.")

// ══════════════════════════════════════
// INPUTS — Dashboard
// ══════════════════════════════════════
showDashInput    = input.bool(true, "Show Dashboard", group = GRP_DASH)
showBtDashInput  = input.bool(true, "Show Backtest Stats", group = GRP_DASH)
dashPosStr       = input.string("Top Right", "Dashboard Position", options = ["Top Left", "Top Right", "Bottom Left", "Bottom Right"], group = GRP_DASH)

// ══════════════════════════════════════
// INPUTS — Alerts
// ══════════════════════════════════════
webhookInput = input.bool(false, "Webhook JSON Format", group = GRP_ALERT)

// ══════════════════════════════════════
// INPUTS — Colors
// ══════════════════════════════════════
bullColorInput    = input.color(#00E676, "Bull",    inline = "sig_colors", group = GRP_COLORS)
bearColorInput    = input.color(#FF5252, "Bear",    inline = "sig_colors", group = GRP_COLORS)
neutralColorInput = input.color(#FFEB3B, "Neutral", inline = "sig_colors", group = GRP_COLORS)

// ══════════════════════════════════════
// INPUTS — Signal Layers (Optuna-tunable)
// ══════════════════════════════════════
// Volume Force + NFE + RSI-KNN momentum layer
useVfInput        = input.bool(true,  "Volume Force Layer",  group = GRP_SIGNALS, tooltip = "Enable Volume Force + NFE + RSI-KNN momentum signals in confluence score.")
vfLenInput        = input.int(20,  "VF Window",             minval = 5, maxval = 100, group = GRP_SIGNALS)
vfFlowWeightInput = input.float(25.0, "VF Candle Weight",   minval = 5.0, maxval = 60.0, step = 1.0, group = GRP_SIGNALS)
vfVolWeightInput  = input.float(10.0, "VF Volume Weight",   minval = 1.0, maxval = 30.0, step = 1.0, group = GRP_SIGNALS)
nfeLenInput       = input.int(14, "NFE Length",             minval = 5, maxval = 50, group = GRP_SIGNALS)
rsiKnnWindowInput = input.int(20, "RSI KNN Window",         minval = 5, maxval = 50, group = GRP_SIGNALS)

// Proven MES candlestick pattern layer
usePatternInput   = input.bool(true, "Candlestick Patterns", group = GRP_SIGNALS, tooltip = "Enable empirically validated MES 15m candlestick pattern signals.\nBull: Long Lower Shadow, Dragonfly Doji, Rising Window.\nBear: Long Upper Shadow, Shooting Star, Bearish Engulfing, Falling Window.")

// ICT/SMC signal layer
useIctInput       = input.bool(true, "ICT/SMC Signals",     group = GRP_SIGNALS, tooltip = "Enable Liquidity Sweep, CHoCH, and FVG as confluence factors.")
ictSwingLenInput  = input.int(10, "ICT Swing Lookback",     minval = 3, maxval = 30, group = GRP_SIGNALS)
ictChochLenInput  = input.int(5,  "CHoCH Pivot Length",     minval = 3, maxval = 15, group = GRP_SIGNALS)

// ══════════════════════════════════════
// AUTO-PRESET ENGINE
// ══════════════════════════════════════
string resolvedPreset = presetInput

if presetInput == "Auto"
    float tfMinutes = timeframe.in_seconds() / 60.0
    if tfMinutes <= 5
        resolvedPreset := "Scalping"
    else if tfMinutes <= 60
        resolvedPreset := "Default"
    else if tfMinutes <= 240
        resolvedPreset := "Aggressive"
    else
        resolvedPreset := "Swing"

int effectiveEmaFast = switch resolvedPreset
    "Scalping"     => 5
    "Aggressive"   => 8
    "Default"      => 9
    "Conservative" => 12
    "Swing"        => 13
    "Crypto 24/7"  => 9
    "Custom"       => emaFastLenInput
    => emaFastLenInput

int effectiveEmaSlow = switch resolvedPreset
    "Scalping"     => 13
    "Aggressive"   => 18
    "Default"      => 21
    "Conservative" => 26
    "Swing"        => 34
    "Crypto 24/7"  => 21
    "Custom"       => emaSlowLenInput
    => emaSlowLenInput

int effectiveEmaTrend = switch resolvedPreset
    "Scalping"     => 34
    "Aggressive"   => 50
    "Default"      => 55
    "Conservative" => 89
    "Swing"        => 89
    "Crypto 24/7"  => 55
    "Custom"       => emaTrendLenInput
    => emaTrendLenInput

int effectiveRsiLen = switch resolvedPreset
    "Scalping"     => 8
    "Aggressive"   => 11
    "Default"      => 13
    "Conservative" => 14
    "Swing"        => 21
    "Crypto 24/7"  => 14
    "Custom"       => rsiLenInput
    => rsiLenInput

int effectiveAtrLen = switch resolvedPreset
    "Scalping"     => 10
    "Aggressive"   => 12
    "Default"      => 14
    "Conservative" => 14
    "Swing"        => 20
    "Crypto 24/7"  => 20
    "Custom"       => atrLenInput
    => atrLenInput

int effectiveScore = switch resolvedPreset
    "Scalping"     => 4
    "Aggressive"   => 3
    "Default"      => 5
    "Conservative" => 7
    "Swing"        => 6
    "Crypto 24/7"  => 5
    "Custom"       => minScoreInput
    => minScoreInput

float effectiveSL = switch resolvedPreset
    "Scalping"     => 0.8
    "Aggressive"   => 1.2
    "Default"      => 1.5
    "Conservative" => 2.0
    "Swing"        => 2.5
    "Crypto 24/7"  => 2.0
    "Custom"       => slMultInput
    => slMultInput

// ══════════════════════════════════════
// THEME DETECTION & COLORS
// ══════════════════════════════════════
isDark = switch themeInput
    "Dark"  => true
    "Light" => false
    => color.r(chart.bg_color) < 128

TEXT_COLOR    = isDark ? #E0E0E0                  : #1A1A1A
TEXT_MUTED    = isDark ? color.new(#9E9E9E, 0)    : color.new(#757575, 0)
TEXT_BRIGHT   = isDark ? #FFFFFF                   : #000000
TABLE_BG      = isDark ? color.new(#131722, 5)    : color.new(#FFFFFF, 5)
TABLE_BORDER  = isDark ? color.new(#2A2E39, 0)    : color.new(#D0D0D0, 0)
TABLE_ROW_ALT = isDark ? color.new(#1C2030, 0)    : color.new(#F0F4F8, 0)
HEADER_BG     = color.new(#2962FF, 0)
HEADER_TEXT   = #FFFFFF
LABEL_TEXT    = #FFFFFF
LINE_SUBTLE   = isDark ? color.new(#555555, 0)    : color.new(#AAAAAA, 0)
WM_COLOR      = isDark ? color.new(#FFFFFF, 80)   : color.new(#000000, 80)
BULL_BG       = color.new(bullColorInput, 88)
BEAR_BG       = color.new(bearColorInput, 88)
SL_COLOR      = color.new(#FF1744, 0)
TP_COLOR      = color.new(#00E676, 0)
TRAIL_COLOR   = color.new(#FF9800, 0)
ENTRY_COLOR   = color.new(#2979FF, 0)
BT_HEADER_BG  = color.new(#6200EA, 0)

DASH_BULL    = isDark ? bullColorInput    : #00873E
DASH_BEAR    = isDark ? bearColorInput    : #D32F2F
DASH_NEUTRAL = isDark ? neutralColorInput : #B8860B

// ══════════════════════════════════════
// FUNCTIONS
// ══════════════════════════════════════

safeDiv(float num, float den, float fallback = 0.0) =>
    den != 0 and not na(num) and not na(den) ? num / den : fallback

safeStr(float val, string fmt = "#.##") =>
    na(val) ? "—" : str.tostring(val, fmt)

getSwingLow(int lookback) => ta.lowest(low, lookback + 1)
getSwingHigh(int lookback) => ta.highest(high, lookback + 1)

getDashPos(string pos) =>
    switch pos
        "Top Left"     => position.top_left
        "Top Right"    => position.top_right
        "Bottom Left"  => position.bottom_left
        "Bottom Right" => position.bottom_right
        => position.top_right

getSignalSize(string sz) =>
    switch sz
        "Tiny"   => size.tiny
        "Small"  => size.small
        "Normal" => size.normal
        "Large"  => size.large
        "Huge"   => size.huge
        => size.small

getGrade(float score) =>
    score >= 8.0 ? "A+" : score >= 6.5 ? "A" : score >= 5.0 ? "B" : "C"

passesGradeFilter(float score) =>
    bool gradeOk = switch gradeFilterInput
        "A+ Only"   => score >= 8.0
        "A+ and A"  => score >= 6.5
        "All"       => true
        => true
    bool cOk = hideCGradeInput ? score >= 5.0 : true
    gradeOk and cOk

// Distance-weighted KNN smoother for RSI (ported from v7)
f_rsi_knn(float src, int window) =>
    float sumW = 0.0
    float sumV = 0.0
    for i = 1 to window
        float d = math.abs(src - src[i])
        float w = 1.0 / (d + 0.001)
        sumW += w
        sumV += src[i] * w
    sumW > 0 ? sumV / sumW : src

// ══════════════════════════════════════
// CALCULATIONS (using effective preset values)
// ══════════════════════════════════════
int WARMUP_BARS = math.max(effectiveEmaTrend, 50)
bool isWarmedUp = bar_index >= WARMUP_BARS
string sigSize = getSignalSize(signalSizeInput)

float emaFast  = nz(ta.ema(sourceInput, effectiveEmaFast), close)
float emaSlow  = nz(ta.ema(sourceInput, effectiveEmaSlow), close)
float emaTrend = nz(ta.ema(sourceInput, effectiveEmaTrend), close)

float atrVal       = nz(ta.atr(effectiveAtrLen), high - low)
float chandelierAtr = nz(ta.atr(postTp3AtrLenInput), high - low)  // independent ATR for Chandelier trail (LeBeau canonical ATR(22))
float rsiVal = nz(ta.rsi(sourceInput, effectiveRsiLen), 50.0)

[macdLine, signalLine, histLine] = ta.macd(sourceInput, 12, 26, 9)
float macdVal    = nz(macdLine, 0.0)
float macdSig    = nz(signalLine, 0.0)
float macdHist   = nz(histLine, 0.0)

bool hasVolume    = nz(volume, 0) > 0
float volSma      = hasVolume ? nz(ta.sma(volume, 20), volume) : 0.0
bool  volAboveAvg = hasVolume ? volume > volSma * 1.2 : true

[diPlus, diMinus, adxVal] = ta.dmi(14, 14)
float safeAdx     = nz(adxVal, 0.0)
float safeDiPlus  = nz(diPlus, 0.0)
float safeDiMinus = nz(diMinus, 0.0)
bool  strongTrend = safeAdx > 20

float vwapVal = nz(ta.vwap(hlc3), close)

float atrSmaGlobal = nz(ta.sma(atrVal, 42), atrVal)
float volRatio     = safeDiv(atrVal, atrSmaGlobal, 1.0)
string volRegime   = volRatio > 1.3 ? "High" : volRatio < 0.7 ? "Low" : "Normal"

// ══════════════════════════════════════
// SIGNAL LAYERS — candlestick geometry base
// ══════════════════════════════════════
float barRange       = high - low
float bodySize       = math.abs(close - open)
float bodyRatio      = barRange > 0 ? bodySize / barRange : 0.0
bool  bullishCandle  = close > open
bool  bearishCandle  = close < open
float upperWickSize  = high - math.max(open, close)
float lowerWickSize  = math.min(open, close) - low
float upperWickRatio = barRange > 0 ? upperWickSize / barRange : 0.0
float lowerWickRatio = barRange > 0 ? lowerWickSize / barRange : 0.0

// ── Proven MES 15m candlestick patterns (empirically validated — v7 source) ──
// Bull patterns: Long Lower Shadow +3.9%, Dragonfly Doji +1.2%, Rising Window +0.9%
// Bear patterns: Long Upper Shadow -7.7%, Shooting Star -5.6%, Bearish Engulfing -6.6%, Falling Window -1.5%
// Excluded losers: Hammer, Bullish Engulfing, Inverted Hammer (all net-negative on MES 15m)
bool longLowerShadow  = usePatternInput and lowerWickRatio >= 0.55 and upperWickRatio <= 0.25
bool dragonflyDoji    = usePatternInput and lowerWickRatio >= 0.60 and bodyRatio <= 0.15
bool risingWindow     = usePatternInput and low > high[1]
bool longUpperShadow  = usePatternInput and upperWickRatio >= 0.55 and lowerWickRatio <= 0.25
bool shootingStar     = usePatternInput and upperWickRatio >= 0.50 and bodyRatio <= 0.35 and bearishCandle
bool bearishEngulfing = usePatternInput and bearishCandle and bullishCandle[1] and close < open[1] and open > close[1]
bool fallingWindow    = usePatternInput and high < low[1]
bool provenBullPattern = longLowerShadow or dragonflyDoji or risingWindow
bool provenBearPattern = longUpperShadow or shootingStar or bearishEngulfing or fallingWindow

// ── Volume Force + NFE + RSI-KNN (ported from v7, OHLCV-derivable) ──
float _vfBodyNorm = barRange > syminfo.mintick ? (close - open) / barRange : 0.0
float _vfVolMean  = ta.sma(volume, vfLenInput)
float _vfVolStd   = ta.stdev(volume, vfLenInput)
float _vfVolZ     = _vfVolStd > 0 ? (volume - _vfVolMean) / _vfVolStd : 0.0
float mlVfBull    = math.max(0.0, math.min(100.0, 50.0 + _vfBodyNorm * vfFlowWeightInput + _vfVolZ * vfVolWeightInput))
float mlVfBear    = math.max(0.0, math.min(100.0, 50.0 - _vfBodyNorm * vfFlowWeightInput - _vfVolZ * vfVolWeightInput))
float mlNfe       = ta.ema(ta.rsi(sourceInput, nfeLenInput), 3)
float mlRsiKnn    = f_rsi_knn(rsiVal, rsiKnnWindowInput)
bool  vfBull      = useVfInput and mlVfBull > mlVfBear
bool  vfBear      = useVfInput and mlVfBear > mlVfBull
bool  nfeBull     = useVfInput and mlNfe > 55.0
bool  nfeBear     = useVfInput and mlNfe < 45.0
bool  knnBull     = useVfInput and mlRsiKnn > 55.0
bool  knnBear     = useVfInput and mlRsiKnn < 45.0

// ── ICT/SMC: Liquidity Sweep ──
float ictSwingHigh = ta.highest(high, ictSwingLenInput)[1]
float ictSwingLow  = ta.lowest(low,  ictSwingLenInput)[1]
bool  liqSweepBull = useIctInput and low < ictSwingLow  and close > ictSwingLow
bool  liqSweepBear = useIctInput and high > ictSwingHigh and close < ictSwingHigh

// ── ICT/SMC: Change of Character (CHoCH) ──
float _pvtHi = ta.pivothigh(high, ictChochLenInput, ictChochLenInput)
float _pvtLo = ta.pivotlow(low,  ictChochLenInput, ictChochLenInput)
var float lastPvtHi = na
var float lastPvtLo = na
if not na(_pvtHi)
    lastPvtHi := _pvtHi
if not na(_pvtLo)
    lastPvtLo := _pvtLo
bool chochBull = useIctInput and not na(lastPvtHi) and close > lastPvtHi and close[1] <= lastPvtHi
bool chochBear = useIctInput and not na(lastPvtLo) and close < lastPvtLo and close[1] >= lastPvtLo

// ── ICT/SMC: Fair Value Gap (FVG) ──
bool fvgBull = useIctInput and high[2] < low
bool fvgBear = useIctInput and low[2] > high
var float nearFvgBullMid = na
var float nearFvgBearMid = na
if fvgBull
    nearFvgBullMid := (high[2] + low) / 2.0
if fvgBear
    nearFvgBearMid := (low[2] + high) / 2.0
if not na(nearFvgBullMid) and low < nearFvgBullMid
    nearFvgBullMid := na
if not na(nearFvgBearMid) and high > nearFvgBearMid
    nearFvgBearMid := na
bool fvgBullActive = useIctInput and not na(nearFvgBullMid) and close > nearFvgBullMid
bool fvgBearActive = useIctInput and not na(nearFvgBearMid) and close < nearFvgBearMid

float htfEmaFast = request.security(syminfo.tickerid, htfInput, ta.ema(sourceInput, effectiveEmaFast)[1], barmerge.gaps_off, barmerge.lookahead_on)
float htfEmaSlow = request.security(syminfo.tickerid, htfInput, ta.ema(sourceInput, effectiveEmaSlow)[1], barmerge.gaps_off, barmerge.lookahead_on)
float safeHtfFast = nz(htfEmaFast, emaFast)
float safeHtfSlow = nz(htfEmaSlow, emaSlow)
int htfBias = safeHtfFast > safeHtfSlow ? 1 : safeHtfFast < safeHtfSlow ? -1 : 0

float recentSwingLow  = getSwingLow(swingLookbackInput)
float tp3SwingLow     = ta.lowest(low,  postTp3SwingLookbackInput + 1)
float tp3SwingHigh    = ta.highest(high, postTp3SwingLookbackInput + 1)
float recentSwingHigh = getSwingHigh(swingLookbackInput)

// ══════════════════════════════════════
// CONFLUENCE SCORING ENGINE
// ══════════════════════════════════════
float bullScore = 0.0
bullScore += emaFast > emaSlow                            ? 1.0 : 0.0
bullScore += close > emaTrend                             ? 1.0 : 0.0
bullScore += rsiVal > 50 and rsiVal < 75                  ? 1.0 : 0.0
bullScore += macdHist > 0                                 ? 1.0 : 0.0
bullScore += close > vwapVal                              ? 1.0 : 0.0
bullScore += volAboveAvg                                  ? 1.0 : 0.0
bullScore += strongTrend and safeDiPlus > safeDiMinus     ? 1.0 : 0.0
bullScore += htfBias == 1 and htfInput != ""              ? 1.5 : 0.0
bullScore += close > emaFast                              ? 0.5 : 0.0

float bearScore = 0.0
bearScore += emaFast < emaSlow                            ? 1.0 : 0.0
bearScore += close < emaTrend                             ? 1.0 : 0.0
bearScore += rsiVal < 50 and rsiVal > 25                  ? 1.0 : 0.0
bearScore += macdHist < 0                                 ? 1.0 : 0.0
bearScore += close < vwapVal                              ? 1.0 : 0.0
bearScore += volAboveAvg                                  ? 1.0 : 0.0
bearScore += strongTrend and safeDiMinus > safeDiPlus     ? 1.0 : 0.0
bearScore += htfBias == -1 and htfInput != ""             ? 1.5 : 0.0
bearScore += close < emaFast                              ? 0.5 : 0.0

// ── Signal layer contributions ─────────────────────────────────────────────
// VF / NFE / RSI-KNN momentum layer (each enabled by useVfInput)
bullScore += vfBull    ? 1.0 : 0.0
bullScore += nfeBull   ? 0.5 : 0.0
bullScore += knnBull   ? 0.5 : 0.0
bearScore += vfBear    ? 1.0 : 0.0
bearScore += nfeBear   ? 0.5 : 0.0
bearScore += knnBear   ? 0.5 : 0.0

// Proven MES candlestick patterns (enabled by usePatternInput)
bullScore += provenBullPattern ? 1.0 : 0.0
bearScore += provenBearPattern ? 1.0 : 0.0

// ICT/SMC: sweep +1.0, CHoCH +0.5, FVG +0.5 (enabled by useIctInput)
bullScore += liqSweepBull  ? 1.0 : 0.0
bullScore += chochBull     ? 0.5 : 0.0
bullScore += fvgBullActive ? 0.5 : 0.0
bearScore += liqSweepBear  ? 1.0 : 0.0
bearScore += chochBear     ? 0.5 : 0.0
bearScore += fvgBearActive ? 0.5 : 0.0

// ══════════════════════════════════════
// SIGNAL LOGIC
// ══════════════════════════════════════
bool emaBullCross = ta.crossover(emaFast, emaSlow)
bool emaBearCross = ta.crossunder(emaFast, emaSlow)

bool bullMomentum = close > emaFast and close > emaSlow
bool bearMomentum = close < emaFast and close < emaSlow

bool rsiNotOB = rsiVal < 75
bool rsiNotOS = rsiVal > 25

bool rawBuy  = emaBullCross and bullMomentum and rsiNotOB and bullScore >= effectiveScore and passesGradeFilter(bullScore)
bool rawSell = emaBearCross and bearMomentum and rsiNotOS and bearScore >= effectiveScore and passesGradeFilter(bearScore)

var int lastDirection = 0
bool buyCondition  = rawBuy  and lastDirection != 1
bool sellCondition = rawSell and lastDirection != -1

bool confirmedBuy  = buyCondition  and barstate.isconfirmed and isWarmedUp
bool confirmedSell = sellCondition and barstate.isconfirmed and isWarmedUp

if confirmedBuy
    lastDirection := 1
else if confirmedSell
    lastDirection := -1

// ══════════════════════════════════════
// TRADE MANAGEMENT (SL / TP / TRAIL)
// ══════════════════════════════════════
var float entryPrice  = na
var float slPrice     = na
var float tp1Price    = na
var float tp2Price    = na
var float tp3Price    = na
var float trailPrice  = na
var bool  tp1Hit      = false
var bool  tp2Hit      = false
var bool  tp3Hit      = false
var bool  slHit       = false
var int   tradeDir    = 0
var float tradeRisk   = na
var int   entryBar    = 0

// Post-TP3 runner state
var float hhSinceTp3 = na
var float llSinceTp3 = na
var bool  closedAtTp3 = false

calcSL(bool isLong, float entry, float atrSL) =>
    float atrStop = isLong ? entry - atrSL : entry + atrSL
    if useStructureSLInput
        float structStop = isLong ? recentSwingLow - atrVal * 0.2 : recentSwingHigh + atrVal * 0.2
        float finalStop = isLong ? math.max(atrStop, structStop) : math.min(atrStop, structStop)
        float minDist = atrVal * 0.5
        float dist = math.abs(entry - finalStop)
        finalStop := dist < minDist ? (isLong ? entry - minDist : entry + minDist) : finalStop
        finalStop
    else
        atrStop

if confirmedBuy
    entryPrice := close
    tradeDir   := 1
    float risk  = atrVal * effectiveSL
    slPrice    := calcSL(true, close, risk)
    tradeRisk  := math.abs(close - slPrice)
    tp1Price   := close + tradeRisk * tp1MultInput
    tp2Price   := close + tradeRisk * tp2MultInput
    tp3Price   := close + tradeRisk * tp3MultInput
    trailPrice := slPrice
    tp1Hit     := false
    tp2Hit     := false
    tp3Hit     := false
    slHit      := false
    entryBar   := bar_index
    hhSinceTp3 := na
    llSinceTp3 := na
    closedAtTp3 := false

if confirmedSell
    entryPrice := close
    tradeDir   := -1
    float risk  = atrVal * effectiveSL
    slPrice    := calcSL(false, close, risk)
    tradeRisk  := math.abs(close - slPrice)
    tp1Price   := close - tradeRisk * tp1MultInput
    tp2Price   := close - tradeRisk * tp2MultInput
    tp3Price   := close - tradeRisk * tp3MultInput
    trailPrice := slPrice
    tp1Hit     := false
    tp2Hit     := false
    tp3Hit     := false
    slHit      := false
    entryBar   := bar_index
    hhSinceTp3 := na
    llSinceTp3 := na
    closedAtTp3 := false

bool canCheckTPSL = bar_index > entryBar and tradeDir != 0 and not slHit

if canCheckTPSL and tradeDir == 1
    float preTrail = trailPrice
    // TP1 and TP2 are tag-only — do NOT ratchet the stop. Trade must breathe
    // until TP3 validates the runner (ratcheting stops prevents TP2/TP3 retests).
    if high >= tp1Price and not tp1Hit
        tp1Hit := true
    if high >= tp2Price and not tp2Hit
        tp2Hit := true
    if high >= tp3Price and not tp3Hit
        tp3Hit := true
        hhSinceTp3 := high
        if postTp3ModeInput == "Close at TP3"
            closedAtTp3 := true
            slHit := true
        else if useTrailInput
            float initTrail = tp2Price
            if postTp3ModeInput == "ATR Chandelier"
                initTrail := high - postTp3AtrMultInput * chandelierAtr
            else if postTp3ModeInput == "Swing Trail"
                initTrail := tp3SwingLow
            trailPrice := math.max(nz(trailPrice, initTrail), initTrail)
    if low <= nz(preTrail, slPrice)
        slHit := true

if canCheckTPSL and tradeDir == -1
    float preTrail = trailPrice
    // TP1/TP2 tag-only, matching LONG branch — no pre-TP3 ratchet.
    if low <= tp1Price and not tp1Hit
        tp1Hit := true
    if low <= tp2Price and not tp2Hit
        tp2Hit := true
    if low <= tp3Price and not tp3Hit
        tp3Hit := true
        llSinceTp3 := low
        if postTp3ModeInput == "Close at TP3"
            closedAtTp3 := true
            slHit := true
        else if useTrailInput
            float initTrail = tp2Price
            if postTp3ModeInput == "ATR Chandelier"
                initTrail := low + postTp3AtrMultInput * chandelierAtr
            else if postTp3ModeInput == "Swing Trail"
                initTrail := tp3SwingHigh
            trailPrice := math.min(nz(trailPrice, initTrail), initTrail)
    if high >= nz(preTrail, slPrice)
        slHit := true

// Post-TP3 runner: ratchet trail each bar while tp3Hit active (non-Close modes)
if tp3Hit and tradeDir != 0 and not slHit and not closedAtTp3 and useTrailInput and postTp3ModeInput != "Hold TP2"
    if tradeDir == 1
        hhSinceTp3 := math.max(nz(hhSinceTp3, high), high)
        float candidateTrail = na
        if postTp3ModeInput == "ATR Chandelier"
            candidateTrail := hhSinceTp3 - postTp3AtrMultInput * chandelierAtr
        else if postTp3ModeInput == "Swing Trail"
            candidateTrail := tp3SwingLow
        if not na(candidateTrail)
            trailPrice := math.max(nz(trailPrice, candidateTrail), candidateTrail)
    else
        llSinceTp3 := math.min(nz(llSinceTp3, low), low)
        float candidateTrail = na
        if postTp3ModeInput == "ATR Chandelier"
            candidateTrail := llSinceTp3 + postTp3AtrMultInput * chandelierAtr
        else if postTp3ModeInput == "Swing Trail"
            candidateTrail := tp3SwingHigh
        if not na(candidateTrail)
            trailPrice := math.min(nz(trailPrice, candidateTrail), candidateTrail)

bool tradeActive = tradeDir != 0 and not slHit
string tradeStatus = "No Trade"
if tradeActive and tp3Hit
    tradeStatus := "TP3 ✓ — Trail"
else if tradeActive and tp2Hit
    tradeStatus := "TP2 ✓"
else if tradeActive and tp1Hit
    tradeStatus := "TP1 ✓"
else if tradeActive
    tradeStatus := "Active"

var bool slHitPrev = false
if slHit and not slHitPrev
    lastDirection := 0
slHitPrev := slHit

// ══════════════════════════════════════
// BACKTEST TRACKER
// ══════════════════════════════════════
var int   btTotalTrades = 0
var int   btWins        = 0
var int   btLosses      = 0
var float btTotalR      = 0.0
var float btGrossWin    = 0.0
var float btGrossLoss   = 0.0

var bool  prevTradeOpen = false
var int   prevDir       = 0
var bool  prevTP1       = false
var bool  prevTP2       = false
var bool  prevTP3       = false
var bool  prevSL        = false

bool tradeJustClosed = false
float closedR = 0.0

if slHit and not prevSL and prevTradeOpen
    tradeJustClosed := true
    if closedAtTp3
        closedR := tp3MultInput
    else if useTrailInput
        if prevTP3 or tp3Hit
            // Post-TP3 exit: compute actual realized R from trail position.
            // Covers Hold TP2 (trail=tp2Price), ATR Chandelier, and Swing Trail.
            if not na(trailPrice) and not na(entryPrice) and not na(tradeRisk) and tradeRisk > 0 and tradeDir != 0
                closedR := (trailPrice - entryPrice) / tradeRisk * tradeDir
            else
                closedR := tp2MultInput
        else if prevTP2 or tp2Hit
            closedR := tp1MultInput
        else if prevTP1 or tp1Hit
            closedR := 0.0
        else
            closedR := -1.0
    else
        if prevTP3 or tp3Hit
            closedR := tp3MultInput
        else if prevTP2 or tp2Hit
            closedR := tp2MultInput
        else if prevTP1 or tp1Hit
            closedR := tp1MultInput
        else
            closedR := -1.0
else if (confirmedBuy and prevDir == -1 and prevTradeOpen) or (confirmedSell and prevDir == 1 and prevTradeOpen)
    tradeJustClosed := true
    float prevEntry = nz(entryPrice[1], close)
    float prevRisk  = nz(tradeRisk[1], atrVal)
    float pnl = prevDir == 1 ? close - prevEntry : prevEntry - close
    closedR := prevRisk != 0 ? pnl / prevRisk : 0.0

if tradeJustClosed
    btTotalTrades += 1
    btTotalR      += closedR
    if closedR > 0
        btWins     += 1
        btGrossWin += closedR
    else if closedR < 0
        btLosses    += 1
        btGrossLoss += math.abs(closedR)

prevTradeOpen := tradeActive
prevDir       := tradeDir
prevTP1       := tp1Hit
prevTP2       := tp2Hit
prevTP3       := tp3Hit
prevSL        := slHit

float btWinRate      = btTotalTrades > 0 ? btWins * 1.0 / btTotalTrades * 100.0 : 0.0
float btAvgR         = btTotalTrades > 0 ? btTotalR / (btTotalTrades * 1.0) : 0.0
float btProfitFactor = btGrossLoss > 0  ? btGrossWin / btGrossLoss : (btGrossWin > 0 ? 999.0 : 0.0)
float btExpectancy   = btTotalTrades > 0 ? btTotalR : 0.0

// ══════════════════════════════════════
// PLOTS — EMA Ribbon
// ══════════════════════════════════════
pFast = plot(showRibbonInput ? emaFast : na, "EMA Fast", color = color.new(bullColorInput, 30), linewidth = 2)
pSlow = plot(showRibbonInput ? emaSlow : na, "EMA Slow", color = color.new(bearColorInput, 30), linewidth = 2)
fill(pFast, pSlow, color = emaFast > emaSlow ? BULL_BG : BEAR_BG, title = "EMA Ribbon Fill")

plot(showRibbonInput ? emaTrend : na, "EMA Trend", color = LINE_SUBTLE, linewidth = 1, style = plot.style_circles)

bgcolor(showBgInput ? (emaFast > emaSlow and close > emaTrend ? color.new(bullColorInput, 94) : emaFast < emaSlow and close < emaTrend ? color.new(bearColorInput, 94) : na) : na, title = "Trend Background")

// ══════════════════════════════════════
// SIGNALS VISUAL — Long / Short labels with Grade
// ══════════════════════════════════════
if showSignalsInput and confirmedBuy
    string gradeStr = showGradeInput ? " " + getGrade(bullScore) : ""
    label.new(bar_index, low, "Long" + gradeStr, color = bullColorInput, textcolor = LABEL_TEXT, style = label.style_label_up, size = sigSize, yloc = yloc.belowbar)

if showSignalsInput and confirmedSell
    string gradeStr = showGradeInput ? " " + getGrade(bearScore) : ""
    label.new(bar_index, high, "Short" + gradeStr, color = bearColorInput, textcolor = LABEL_TEXT, style = label.style_label_down, size = sigSize, yloc = yloc.abovebar)

// ══════════════════════════════════════
// TP/SL LINES & LABELS
// ══════════════════════════════════════
var line lineEntry = na, var line lineSL = na
var line lineTP1 = na, var line lineTP2 = na, var line lineTP3 = na
var label lbEntry = na, var label lbSL = na
var label lbTP1 = na, var label lbTP2 = na, var label lbTP3 = na

if (confirmedBuy or confirmedSell) and showTPSLInput
    line.delete(lineEntry), line.delete(lineSL)
    line.delete(lineTP1), line.delete(lineTP2), line.delete(lineTP3)
    label.delete(lbEntry), label.delete(lbSL)
    label.delete(lbTP1), label.delete(lbTP2), label.delete(lbTP3)

    int lineEnd  = bar_index + labelOffsetInput
    int labelPos = bar_index + labelOffsetInput + 2

    lineEntry := line.new(bar_index, entryPrice, lineEnd, entryPrice, color = ENTRY_COLOR, width = 2, style = line.style_solid)
    lineSL    := line.new(bar_index, slPrice, lineEnd, slPrice, color = SL_COLOR, width = 2, style = line.style_solid)
    lineTP1   := line.new(bar_index, tp1Price, lineEnd, tp1Price, color = TP_COLOR, width = 1, style = line.style_dashed)
    lineTP2   := line.new(bar_index, tp2Price, lineEnd, tp2Price, color = TP_COLOR, width = 1, style = line.style_dashed)
    lineTP3   := line.new(bar_index, tp3Price, lineEnd, tp3Price, color = TP_COLOR, width = 2, style = line.style_dashed)

    lbEntry := label.new(labelPos, entryPrice, "ENTRY " + str.tostring(entryPrice, format.mintick), color = color.new(ENTRY_COLOR, 60), textcolor = TEXT_BRIGHT, style = label.style_label_left, size = size.small, text_font_family = font.family_monospace)
    lbSL    := label.new(labelPos, slPrice, "SL " + str.tostring(slPrice, format.mintick), color = color.new(SL_COLOR, 60), textcolor = TEXT_BRIGHT, style = label.style_label_left, size = size.small, text_font_family = font.family_monospace)
    lbTP1   := label.new(labelPos, tp1Price, "TP1 " + str.tostring(tp1Price, format.mintick), color = color.new(TP_COLOR, 60), textcolor = TEXT_BRIGHT, style = label.style_label_left, size = size.small, text_font_family = font.family_monospace)
    lbTP2   := label.new(labelPos, tp2Price, "TP2 " + str.tostring(tp2Price, format.mintick), color = color.new(TP_COLOR, 60), textcolor = TEXT_BRIGHT, style = label.style_label_left, size = size.small, text_font_family = font.family_monospace)
    lbTP3   := label.new(labelPos, tp3Price, "TP3 " + str.tostring(tp3Price, format.mintick), color = color.new(TP_COLOR, 60), textcolor = TEXT_BRIGHT, style = label.style_label_left, size = size.small, text_font_family = font.family_monospace)

if showTPSLInput and not na(lineEntry) and not (confirmedBuy or confirmedSell)
    int newLineEnd  = bar_index + labelOffsetInput
    int newLabelPos = bar_index + labelOffsetInput + 2

    // Effective stop = trail if it's tighter than original SL (ratcheted post-TP).
    // This makes the SL pill move up/down with each TP hit so the chart reflects
    // the actual active stop after the post-TP3 readjust (not the stale original SL).
    float effectiveStop = slPrice
    if useTrailInput and not na(trailPrice) and tradeDir != 0
        effectiveStop := tradeDir == 1 ? math.max(slPrice, trailPrice) : math.min(slPrice, trailPrice)
    bool trailActive = useTrailInput and tp3Hit and not na(trailPrice)
    string slLabelText = trailActive ? "SL→" + str.tostring(effectiveStop, format.mintick) : "SL " + str.tostring(slPrice, format.mintick)

    if not na(lineEntry)
        line.set_x2(lineEntry, newLineEnd)
    if not na(lineSL)
        line.set_x2(lineSL, newLineEnd)
        line.set_y1(lineSL, effectiveStop)
        line.set_y2(lineSL, effectiveStop)
    if not na(lineTP1)
        line.set_x2(lineTP1, newLineEnd)
    if not na(lineTP2)
        line.set_x2(lineTP2, newLineEnd)
    if not na(lineTP3)
        line.set_x2(lineTP3, newLineEnd)

    if not na(lbEntry)
        label.set_x(lbEntry, newLabelPos)
    if not na(lbSL)
        label.set_xy(lbSL, newLabelPos, effectiveStop)
        label.set_text(lbSL, slLabelText)
    if not na(lbTP1)
        label.set_x(lbTP1, newLabelPos)
    if not na(lbTP2)
        label.set_x(lbTP2, newLabelPos)
    if not na(lbTP3)
        label.set_x(lbTP3, newLabelPos)

if showTPSLInput and not na(lineTP1) and tp1Hit
    line.set_color(lineTP1, color.new(#40E0D0, 0))
    line.set_style(lineTP1, line.style_solid)
    if not na(lbTP1)
        label.set_text(lbTP1, "TP1 ✓ " + str.tostring(tp1Price, format.mintick))
        label.set_color(lbTP1, color.new(#40E0D0, 40))
if showTPSLInput and not na(lineTP2) and tp2Hit
    line.set_color(lineTP2, color.new(#40E0D0, 0))
    line.set_style(lineTP2, line.style_solid)
    if not na(lbTP2)
        label.set_text(lbTP2, "TP2 ✓ " + str.tostring(tp2Price, format.mintick))
        label.set_color(lbTP2, color.new(#40E0D0, 40))
if showTPSLInput and not na(lineTP3) and tp3Hit
    line.set_color(lineTP3, color.new(#40E0D0, 0))
    line.set_style(lineTP3, line.style_solid)
    if not na(lbTP3)
        label.set_text(lbTP3, "TP3 ✓ " + str.tostring(tp3Price, format.mintick))
        label.set_color(lbTP3, color.new(#40E0D0, 40))

// ══════════════════════════════════════
// DASHBOARD
// ══════════════════════════════════════
int dashRows = 12 + (showBtDashInput ? 7 : 0)

var table dashTable = table.new(getDashPos(dashPosStr), 2, dashRows, TABLE_BG, TABLE_BORDER, 1, TABLE_BORDER, 1)

if showDashInput and barstate.islast
    int row = 0

    table.cell(dashTable, 0, row, "Warbird", text_color = HEADER_TEXT, bgcolor = HEADER_BG, text_size = size.small, text_halign = text.align_center)
    table.merge_cells(dashTable, 0, row, 1, row)
    row += 1

    string trendStr = emaFast > emaSlow and close > emaTrend ? "Bullish" : emaFast < emaSlow and close < emaTrend ? "Bearish" : "Neutral"
    color trendCol = trendStr == "Bullish" ? DASH_BULL : trendStr == "Bearish" ? DASH_BEAR : DASH_NEUTRAL
    table.cell(dashTable, 0, row, "Trend", text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_BG)
    table.cell(dashTable, 1, row, trendStr, text_color = trendCol, text_size = size.small, bgcolor = TABLE_BG)
    row += 1

    float activeScore = tradeDir == 1 ? bullScore : tradeDir == -1 ? bearScore : math.max(bullScore, bearScore)
    string scoreStr = safeStr(activeScore, "#.#") + " / 10"
    color scoreCol = activeScore >= 7 ? DASH_BULL : activeScore >= 5 ? DASH_NEUTRAL : DASH_BEAR
    table.cell(dashTable, 0, row, "Score", text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_ROW_ALT)
    table.cell(dashTable, 1, row, scoreStr, text_color = scoreCol, text_size = size.small, bgcolor = TABLE_ROW_ALT)
    row += 1

    color statusCol = tradeStatus == "No Trade" ? TEXT_MUTED : str.contains(tradeStatus, "TP") ? DASH_BULL : DASH_NEUTRAL
    table.cell(dashTable, 0, row, "Status", text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_BG)
    table.cell(dashTable, 1, row, tradeStatus, text_color = statusCol, text_size = size.small, bgcolor = TABLE_BG)
    row += 1

    string htfStr = htfBias == 1 ? "Bullish" : htfBias == -1 ? "Bearish" : "Neutral"
    color htfCol = htfBias == 1 ? DASH_BULL : htfBias == -1 ? DASH_BEAR : DASH_NEUTRAL
    table.cell(dashTable, 0, row, "HTF Bias", text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_ROW_ALT)
    table.cell(dashTable, 1, row, htfStr, text_color = htfCol, text_size = size.small, bgcolor = TABLE_ROW_ALT)
    row += 1

    color volCol = volRegime == "High" ? DASH_BEAR : volRegime == "Low" ? TEXT_MUTED : DASH_BULL
    table.cell(dashTable, 0, row, "Volatility", text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_BG)
    table.cell(dashTable, 1, row, volRegime, text_color = volCol, text_size = size.small, bgcolor = TABLE_BG)
    row += 1

    color rsiCol = rsiVal > 70 ? DASH_BEAR : rsiVal < 30 ? DASH_BULL : TEXT_COLOR
    table.cell(dashTable, 0, row, "RSI", text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_ROW_ALT)
    table.cell(dashTable, 1, row, safeStr(rsiVal, "#.0"), text_color = rsiCol, text_size = size.small, bgcolor = TABLE_ROW_ALT)
    row += 1

    string adxStr = safeStr(safeAdx, "#.0") + (strongTrend ? " ✓" : "")
    table.cell(dashTable, 0, row, "ADX", text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_BG)
    table.cell(dashTable, 1, row, adxStr, text_color = strongTrend ? DASH_BULL : TEXT_MUTED, text_size = size.small, bgcolor = TABLE_BG)
    row += 1

    table.cell(dashTable, 0, row, "Timeframe", text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_ROW_ALT)
    table.cell(dashTable, 1, row, timeframe.period, text_color = TEXT_COLOR, text_size = size.small, bgcolor = TABLE_ROW_ALT)
    row += 1

    string presetDisplay = presetInput == "Auto" ? "Auto → " + resolvedPreset : resolvedPreset
    table.cell(dashTable, 0, row, "Preset", text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_BG)
    table.cell(dashTable, 1, row, presetDisplay, text_color = TEXT_COLOR, text_size = size.small, bgcolor = TABLE_BG)
    row += 1

    color gfCol = gradeFilterInput == "A+ Only" ? DASH_BULL : gradeFilterInput == "A+ and A" ? DASH_NEUTRAL : TEXT_COLOR
    table.cell(dashTable, 0, row, "Grade Filter", text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_ROW_ALT)
    table.cell(dashTable, 1, row, gradeFilterInput, text_color = gfCol, text_size = size.small, bgcolor = TABLE_ROW_ALT)
    row += 1

    table.cell(dashTable, 0, row, "Version", text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_BG)
    table.cell(dashTable, 1, row, INDICATOR_VERSION, text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_BG)
    row += 1

    if showBtDashInput
        table.cell(dashTable, 0, row, "📈 Backtest", text_color = HEADER_TEXT, bgcolor = BT_HEADER_BG, text_size = size.small, text_halign = text.align_center)
        table.merge_cells(dashTable, 0, row, 1, row)
        row += 1

        table.cell(dashTable, 0, row, "Trades", text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_BG)
        table.cell(dashTable, 1, row, str.tostring(btTotalTrades) + " (" + str.tostring(btWins) + "W / " + str.tostring(btLosses) + "L)", text_color = TEXT_COLOR, text_size = size.small, bgcolor = TABLE_BG)
        row += 1

        color wrCol = btWinRate >= 55 ? DASH_BULL : btWinRate >= 45 ? DASH_NEUTRAL : DASH_BEAR
        table.cell(dashTable, 0, row, "Win Rate", text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_ROW_ALT)
        table.cell(dashTable, 1, row, safeStr(btWinRate, "#.0") + "%", text_color = btTotalTrades > 0 ? wrCol : TEXT_MUTED, text_size = size.small, bgcolor = TABLE_ROW_ALT)
        row += 1

        color avgRCol = btAvgR > 0.5 ? DASH_BULL : btAvgR > 0 ? DASH_NEUTRAL : DASH_BEAR
        table.cell(dashTable, 0, row, "Avg R", text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_BG)
        table.cell(dashTable, 1, row, safeStr(btAvgR, "#.##") + "R", text_color = btTotalTrades > 0 ? avgRCol : TEXT_MUTED, text_size = size.small, bgcolor = TABLE_BG)
        row += 1

        string pfStr = btProfitFactor >= 999 ? "∞" : safeStr(btProfitFactor, "#.##")
        color pfCol = btProfitFactor >= 1.5 ? DASH_BULL : btProfitFactor >= 1.0 ? DASH_NEUTRAL : DASH_BEAR
        table.cell(dashTable, 0, row, "Profit Factor", text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_ROW_ALT)
        table.cell(dashTable, 1, row, pfStr, text_color = btTotalTrades > 0 ? pfCol : TEXT_MUTED, text_size = size.small, bgcolor = TABLE_ROW_ALT)
        row += 1

        color totRCol = btExpectancy > 0 ? DASH_BULL : btExpectancy < 0 ? DASH_BEAR : TEXT_MUTED
        table.cell(dashTable, 0, row, "Total R", text_color = TEXT_MUTED, text_size = size.small, bgcolor = TABLE_BG)
        table.cell(dashTable, 1, row, safeStr(btExpectancy, "#.##") + "R", text_color = btTotalTrades > 0 ? totRCol : TEXT_MUTED, text_size = size.small, bgcolor = TABLE_BG)

// ══════════════════════════════════════
// WATERMARK
// ══════════════════════════════════════
var table wmTable = table.new(position.bottom_center, 1, 1, color.new(color.lime, 100), color.new(color.lime, 100), 0, color.new(color.lime, 100), 0)

if barstate.islast and showWatermarkInput
    table.cell(wmTable, 0, 0, "Warbird Pro", text_color = WM_COLOR, text_size = size.normal, text_halign = text.align_center, bgcolor = color.new(color.black, 100))

// ══════════════════════════════════════
// ALERTS
// ══════════════════════════════════════
string tickerStr = syminfo.tickerid
string tfStr     = timeframe.period

if confirmedBuy
    string priceStr = str.tostring(close, format.mintick)
    string slAlStr = str.tostring(nz(slPrice, 0.0), format.mintick)
    string tp1AlStr = str.tostring(nz(tp1Price, 0.0), format.mintick)
    string tp2AlStr = str.tostring(nz(tp2Price, 0.0), format.mintick)
    string tp3AlStr = str.tostring(nz(tp3Price, 0.0), format.mintick)
    string bScoreStr = str.tostring(nz(bullScore, 0.0), "#.#")
    string gradeAlStr = getGrade(bullScore)
    string jsonMsg = '{"action":"buy","ticker":"' + tickerStr + '","price":' + priceStr + ',"sl":' + slAlStr + ',"tp1":' + tp1AlStr + ',"tp2":' + tp2AlStr + ',"tp3":' + tp3AlStr + ',"score":' + bScoreStr + ',"grade":"' + gradeAlStr + '","preset":"' + resolvedPreset + '","tf":"' + tfStr + '"}'
    string textMsg = "🟢 BUY " + gradeAlStr + " | " + tickerStr + " | TF: " + tfStr + " | Price: " + priceStr + " | SL: " + slAlStr + " | TP1: " + tp1AlStr + " | TP2: " + tp2AlStr + " | TP3: " + tp3AlStr + " | Score: " + bScoreStr
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)

if confirmedSell
    string priceStr = str.tostring(close, format.mintick)
    string slAlStr = str.tostring(nz(slPrice, 0.0), format.mintick)
    string tp1AlStr = str.tostring(nz(tp1Price, 0.0), format.mintick)
    string tp2AlStr = str.tostring(nz(tp2Price, 0.0), format.mintick)
    string tp3AlStr = str.tostring(nz(tp3Price, 0.0), format.mintick)
    string sScoreStr = str.tostring(nz(bearScore, 0.0), "#.#")
    string gradeAlStr = getGrade(bearScore)
    string jsonMsg = '{"action":"sell","ticker":"' + tickerStr + '","price":' + priceStr + ',"sl":' + slAlStr + ',"tp1":' + tp1AlStr + ',"tp2":' + tp2AlStr + ',"tp3":' + tp3AlStr + ',"score":' + sScoreStr + ',"grade":"' + gradeAlStr + '","preset":"' + resolvedPreset + '","tf":"' + tfStr + '"}'
    string textMsg = "🔴 SELL " + gradeAlStr + " | " + tickerStr + " | TF: " + tfStr + " | Price: " + priceStr + " | SL: " + slAlStr + " | TP1: " + tp1AlStr + " | TP2: " + tp2AlStr + " | TP3: " + tp3AlStr + " | Score: " + sScoreStr
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)

if tp1Hit and not tp1Hit[1] and tradeDir != 0
    string p = str.tostring(close, format.mintick)
    string msg = webhookInput ? '{"event":"tp1_hit","ticker":"' + tickerStr + '","price":' + p + '}' : "🎯 TP1 HIT | " + tickerStr + " | Price: " + p
    alert(msg, alert.freq_once_per_bar_close)

if tp2Hit and not tp2Hit[1] and tradeDir != 0
    string p = str.tostring(close, format.mintick)
    string msg = webhookInput ? '{"event":"tp2_hit","ticker":"' + tickerStr + '","price":' + p + '}' : "🎯 TP2 HIT | " + tickerStr + " | Price: " + p
    alert(msg, alert.freq_once_per_bar_close)

if tp3Hit and not tp3Hit[1] and tradeDir != 0
    string p = str.tostring(close, format.mintick)
    string msg = webhookInput ? '{"event":"tp3_hit","ticker":"' + tickerStr + '","price":' + p + '}' : "🏆 TP3 HIT | " + tickerStr + " | Price: " + p
    alert(msg, alert.freq_once_per_bar_close)

if slHit and not slHit[1] and tradeDir != 0
    string p = str.tostring(close, format.mintick)
    string msg = webhookInput ? '{"event":"sl_hit","ticker":"' + tickerStr + '","price":' + p + '}' : "🛑 SL HIT | " + tickerStr + " | Price: " + p
    alert(msg, alert.freq_once_per_bar_close)
// ══════════════════════════════════════
// END
// ══════════════════════════════════════
