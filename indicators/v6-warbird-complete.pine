// Warbird v6 Complete — v2 Baseline
// Baseline: Warbird v2 — Unified Fib Engine
// Canonical spec: lib/fibonacci.ts (dashboard TypeScript engine)
// Merge: v1 intermarket + v0 full levels + dashboard structural break locking
// Date: 2026-03-26
//
// NO-REPAINT AUDIT:
// - Structural break: barstate.isconfirmed gated
// - request.security(): lookahead_off on all calls
// - Structure conditions: close-based, bar-close semantics
// - Last verified: 2026-03-26
//
// REQUEST.SECURITY() BUDGET:
// Intermarket (60min): NQ, BANK, VIX, DXY, 10Y         = 5 calls
// VIX daily:           close + percentrank               = 2 calls
// HTF fib (1H):        [high, low] tuple                 = 1 call
// HTF fib (4H):        [high, low] tuple                 = 1 call
// HTF fib (1D):        [high, low] tuple                 = 1 call
// TOTAL:                                                 = 10 of 40 (25%)
//@version=6
indicator("Warbird v6 Complete", shorttitle="WB v6", overlay=true, max_lines_count=200, max_labels_count=200, max_boxes_count=100)
import TradingView/ZigZag/7 as zigzag

//=====================
// FIBONACCI ENGINE SETTINGS
//=====================
groupFibEngine = "Fibonacci Engine"
fibDeviation = input.float(3.0, "ZigZag Deviation (ATR multiplier)", minval=0.5, maxval=10.0, step=0.5, group=groupFibEngine, tooltip="Higher = fewer pivots, more stable anchors. Lower = more pivots, more responsive.")
fibDepth = input.int(10, "ZigZag Depth (min bars between pivots)", minval=2, maxval=50, group=groupFibEngine)
fibConfluenceTolPct = input.float(0.10, "Confluence Tolerance (%)", minval=0.01, maxval=2.00, step=0.01, group=groupFibEngine)

//=====================
// CANONICAL FIB LEVELS (from lib/fibonacci.ts + FibLinesPrimitive.ts)
// DO NOT change these — they match the dashboard exactly
//=====================

// Retracement ratios
FIB_ZERO  = 0.0
FIB_236   = 0.236
FIB_382   = 0.382
FIB_PIVOT = 0.5
FIB_618   = 0.618
FIB_786   = 0.786
FIB_ONE   = 1.0

// Extension ratios
FIB_T1    = 1.236
FIB_T2    = 1.618
FIB_T3    = 2.0

// Colors (from lib/colors.ts:43-54)
COLOR_ANCHOR      = #FFFFFF    // white — 0 and 1 levels
COLOR_RETRACEMENT = #808080    // 50% white — .236, .382, .618, .786
COLOR_PIVOT       = #FF9800    // orange — .5 level
COLOR_TARGET      = #4CAF50    // green — TARGET 1, 2, 3
COLOR_STOP        = #FF1744    // red — stop loss

// Widths (from FibLinesPrimitive.ts:49-60)
WIDTH_ANCHOR      = 1
WIDTH_RETRACEMENT = 1
WIDTH_PIVOT       = 2
WIDTH_TARGET      = 2

//=====================
// STRUCTURE LOGIC
//=====================
groupLogic = "Structure Logic"
retestBars   = input.int(6, "Acceptance Retest Window (bars)", minval=1, group=groupLogic)
rejectWick   = input.bool(true, "Rejection = wick into zone then close back out", group=groupLogic)
oneShotEvent = input.bool(true, "One-shot event markers/alerts", group=groupLogic)

//=====================
// INTERMARKET CONFIRMATION
//=====================
groupIM = "Intermarket Inputs"
useIntermarket = input.bool(true, "Use Intermarket Confirmation", group=groupIM)
tfIM           = input.timeframe("60", "Intermarket Timeframe", group=groupIM)
maLen          = input.int(20, "Confirm EMA Length", minval=5, group=groupIM)
slopeBars      = input.int(1, "Slope Bars", minval=1, maxval=10, group=groupIM)
neutralBandPct = input.float(0.05, "Neutral Band Around EMA (%)", minval=0.0, step=0.01, group=groupIM)
symNQ   = input.symbol("CME_MINI:NQ1!", "NQ (risk appetite)", group=groupIM)
symBANK = input.symbol("NASDAQ:BANK", "BANK (financials)", group=groupIM)
symVIX  = input.symbol("CBOE:VIX", "VIX (volatility)", group=groupIM)
symDXY  = input.symbol("TVC:DXY", "DXY (USD)", group=groupIM)
sym10Y  = input.symbol("TVC:US10Y", "US10Y (yield)", group=groupIM)
vixMaxRiskOn  = input.float(20.40, "VIX Max (risk-on filter)", step=0.1, group=groupIM)
use10YConfirm = input.bool(false, "Include 10Y in confirmation", group=groupIM)

groupIMModel = "Intermarket Model (v2)"
imModel           = input.string("Score + Hysteresis", "Decision Model", options=["Binary Gates", "Score + Hysteresis"], group=groupIMModel)
requireAnchors    = true
scoreThresholdPct = input.float(0.67, "Score Threshold %", minval=0.50, maxval=1.00, step=0.01, group=groupIMModel)
confirmBars       = input.int(2, "Bars Required To Flip", minval=1, maxval=10, group=groupIMModel)
cooldownBars      = input.int(3, "Flip Cooldown (bars)", minval=0, maxval=50, group=groupIMModel)
neutralizeBars    = input.int(0, "Neutralize After Inactive Bars (0=off)", minval=0, maxval=200, group=groupIMModel)
wNQ   = input.int(2, "Weight: NQ", minval=0, maxval=10, group=groupIMModel)
wBANK = input.int(2, "Weight: BANK", minval=0, maxval=10, group=groupIMModel)
wVIX  = input.int(2, "Weight: VIX", minval=0, maxval=10, group=groupIMModel)
wDXY  = input.int(1, "Weight: DXY", minval=0, maxval=10, group=groupIMModel)
w10Y  = input.int(1, "Weight: US10Y", minval=0, maxval=10, group=groupIMModel)

//=====================
// VISUALS (colors/widths locked to spec — see constants above)
//=====================
groupViz = "Visuals"
targetLookbackBars = input.int(55, "Target Line Lookback Bars", minval=5, maxval=500, group=groupViz)
extendLevelsRight = input.bool(false, "Extend Levels Right", group=groupViz)
useConfluenceAnchorSpan = input.bool(true, "Anchor Span = Active Fib Window", group=groupViz)
showBg = input.bool(false, "Background Regime Tint", group=groupViz)

groupDebug = "Debug Diagnostics"
enableDebugLogs = input.bool(false, "Enable Debug Logs", group=groupDebug, tooltip="Temporary state tracing for regime/probability diagnostics.")

//=====================
// REGIME DETECTION (from session-checkpoint research: ADX/ER/VIX-vol)
// These are computed values for sidebar + AG features, NOT chart markers
//=====================

// --- ADX(14) + signed DI spread + ADX slope ---
adxLen = 14
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)
diSpread = diPlus - diMinus
adxSlope = adxVal - nz(adxVal[3])

// Regime classification: trending vs ranging
regimeTrending = adxVal > 25
regimeRanging  = adxVal < 20

// --- Efficiency Ratio (10, 20) ---
er10Direction = math.abs(close - close[10])
er10Volatility = math.sum(math.abs(close - close[1]), 10)
er10 = er10Volatility != 0 ? er10Direction / er10Volatility : 0.0

er20Direction = math.abs(close - close[20])
er20Volatility = math.sum(math.abs(close - close[1]), 20)
er20 = er20Volatility != 0 ? er20Direction / er20Volatility : 0.0

// --- VIX percentile approximation (rolling 252-day) ---
vixDaily = request.security("CBOE:VIX", "D", close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
vixPctRank = request.security("CBOE:VIX", "D", ta.percentrank(close, 252), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

// --- ATR percentage (normalized volatility) ---
atrRaw = ta.atr(20)
atrPct = close != 0 ? atrRaw / close * 100.0 : 0.0

//=====================
// HTF FIB CONFLUENCE (1H, 4H, Daily)
//=====================
groupHTF = "HTF Confluence"
htfConfTolPct = 0.15

[htf1hHigh, htf1hLow] = request.security(syminfo.tickerid, "60", [ta.highest(high, 55), ta.lowest(low, 55)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
[htf4hHigh, htf4hLow] = request.security(syminfo.tickerid, "240", [ta.highest(high, 55), ta.lowest(low, 55)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
[htf1dHigh, htf1dLow] = request.security(syminfo.tickerid, "D", [ta.highest(high, 55), ta.lowest(low, 55)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

htf1hRange = nz(htf1hHigh - htf1hLow)
htf4hRange = nz(htf4hHigh - htf4hLow)
htf1dRange = nz(htf1dHigh - htf1dLow)

htfFibPrice(float htfHigh, float htfLow, float htfRng, float ratio) =>
    htfRng <= 0 ? na : htfLow + htfRng * ratio

htf1hP382 = htfFibPrice(htf1hHigh, htf1hLow, htf1hRange, FIB_382)
htf1hP500 = htfFibPrice(htf1hHigh, htf1hLow, htf1hRange, FIB_PIVOT)
htf1hP618 = htfFibPrice(htf1hHigh, htf1hLow, htf1hRange, FIB_618)

htf4hP382 = htfFibPrice(htf4hHigh, htf4hLow, htf4hRange, FIB_382)
htf4hP500 = htfFibPrice(htf4hHigh, htf4hLow, htf4hRange, FIB_PIVOT)
htf4hP618 = htfFibPrice(htf4hHigh, htf4hLow, htf4hRange, FIB_618)

htf1dP382 = htfFibPrice(htf1dHigh, htf1dLow, htf1dRange, FIB_382)
htf1dP500 = htfFibPrice(htf1dHigh, htf1dLow, htf1dRange, FIB_PIVOT)
htf1dP618 = htfFibPrice(htf1dHigh, htf1dLow, htf1dRange, FIB_618)

htfConfluenceCheck(float level15m, float currentFibRange) =>
    if na(level15m) or na(currentFibRange) or currentFibRange <= 0
        0
    else
        float tol = currentFibRange * htfConfTolPct * 0.01
        int hits = 0
        if not na(htf1hP382) and math.abs(level15m - htf1hP382) <= tol
            hits += 1
        if not na(htf1hP500) and math.abs(level15m - htf1hP500) <= tol
            hits += 1
        if not na(htf1hP618) and math.abs(level15m - htf1hP618) <= tol
            hits += 1
        if not na(htf4hP382) and math.abs(level15m - htf4hP382) <= tol
            hits += 1
        if not na(htf4hP500) and math.abs(level15m - htf4hP500) <= tol
            hits += 1
        if not na(htf4hP618) and math.abs(level15m - htf4hP618) <= tol
            hits += 1
        if not na(htf1dP382) and math.abs(level15m - htf1dP382) <= tol
            hits += 1
        if not na(htf1dP500) and math.abs(level15m - htf1dP500) <= tol
            hits += 1
        if not na(htf1dP618) and math.abs(level15m - htf1dP618) <= tol
            hits += 1
        hits

// NOTE: htfConfluenceCheck() is called AFTER fib prices are computed (below the AUTO FIB ENGINE)

//=====================
// AUTO FIB ENGINE — ZigZag confirmed pivots (non-repainting)
//=====================
fibZzUpdate() =>
    var fibSettings = zigzag.Settings.new(fibDeviation, fibDepth, color(na), false, false, false, false, "Absolute", true)
    var zigzag.ZigZag fibZZ = zigzag.newInstance(fibSettings)
    var zigzag.Pivot lastPvt = na
    fibSettings.devThreshold := ta.atr(10) / close * 100 * fibDeviation
    bool newPivot = false
    float pivotHighPrice = na
    float pivotLowPrice = na
    int pivotHighBar = na
    int pivotLowBar = na
    if fibZZ.update()
        lastPvt := fibZZ.lastPivot()
        if not na(lastPvt)
            newPivot := true
            float startP = lastPvt.start.price
            float endP = lastPvt.end.price
            pivotHighPrice := math.max(startP, endP)
            pivotLowPrice  := math.min(startP, endP)
            pivotHighBar := bar_index
            pivotLowBar  := bar_index
    [newPivot, pivotHighPrice, pivotLowPrice, pivotHighBar, pivotLowBar]

[zzNewPivot, zzHighPrice, zzLowPrice, zzHighBar, zzLowBar] = fibZzUpdate()

var float fibAnchorHigh = na
var float fibAnchorLow = na
var int anchorHighBar = na
var int anchorLowBar = na
var int lastBreakBar = na

if zzNewPivot
    fibAnchorHigh := zzHighPrice
    fibAnchorLow  := zzLowPrice
    anchorHighBar := zzHighBar
    anchorLowBar  := zzLowBar
    lastBreakBar  := na

float confluenceQuality = na
if not na(fibAnchorHigh) and not na(fibAnchorLow)
    float anchorRange = fibAnchorHigh - fibAnchorLow
    if anchorRange > 0
        float tol = anchorRange * fibConfluenceTolPct * 0.01
        int confHits = 0
        for period in array.from(8, 13, 21, 34, 55)
            float rollingH = ta.highest(high, period)
            float rollingL = ta.lowest(low, period)
            float rollingRange = rollingH - rollingL
            if rollingRange > 0
                for ratioIdx = 0 to 2
                    float ratio = ratioIdx == 0 ? 0.382 : ratioIdx == 1 ? 0.5 : 0.618
                    float anchorLevel = fibAnchorLow + anchorRange * ratio
                    float rollingLevel = rollingL + rollingRange * ratio
                    if math.abs(anchorLevel - rollingLevel) <= tol
                        confHits += 1
        confluenceQuality := float(confHits) * anchorRange

fibRange = fibAnchorHigh - fibAnchorLow
fibMidpoint = fibAnchorLow + fibRange * 0.5

float hystBand = fibRange * 0.02
var bool fibBull = true
if fibRange > 0
    if close >= fibMidpoint + hystBand
        fibBull := true
    else if close <= fibMidpoint - hystBand
        fibBull := false
else
    fibBull := true

fibBase = fibBull ? fibAnchorLow : fibAnchorHigh
fibDir = fibBull ? 1.0 : -1.0
fibPrice(float ratio) =>
    fibRange <= 0 ? na : (fibBase + fibDir * fibRange * ratio)

pZero   = fibPrice(FIB_ZERO)
p236    = fibPrice(FIB_236)
p382    = fibPrice(FIB_382)
pPivot  = fibPrice(FIB_PIVOT)
p618    = fibPrice(FIB_618)
p786    = fibPrice(FIB_786)
pOne    = fibPrice(FIB_ONE)
pT1     = fibPrice(FIB_T1)
pT2     = fibPrice(FIB_T2)
pT3     = fibPrice(FIB_T3)

// Internal-only target viability gate used by trigger wiring.
float minTargetPoints = 20.0
float targetPathPoints = isValid ? math.abs(pT1 - close) : na
bool targetEligible20pt = isValid and targetPathPoints >= minTargetPoints

// Fixed stop family code for v6 baseline (fib invalidation path).
int stopFamilyCode = 1

zoneUpper = math.max(p618, p786)
zoneLower = math.min(p618, p786)

zoneFillUpper = math.max(p382, p618)
zoneFillLower = math.min(p382, p618)

htfConfPivot = htfConfluenceCheck(pPivot, fibRange)
htfConf382   = htfConfluenceCheck(p382, fibRange)
htfConf618   = htfConfluenceCheck(p618, fibRange)
htfConfTotal = htfConfPivot + htfConf382 + htfConf618

//=====================
// VOLUME DELTA AT FIB TOUCHES
//=====================
groupVolDelta = "Volume Delta"
volDeltaLookback = 5
volDeltaTolPts = 2.0

barRange = high - low
clv = barRange > 0 ? (close - low) / barRange : 0.5
signedVol = volume * (2.0 * clv - 1.0)

fibTouchCheck(float level) =>
    not na(level) and math.abs(close - level) <= volDeltaTolPts

isTouchingFib = fibTouchCheck(p236) or fibTouchCheck(p382) or fibTouchCheck(pPivot) or fibTouchCheck(p618) or fibTouchCheck(p786)

bullVol = math.sum(volume * math.max(clv, 0), volDeltaLookback)
totalVol = math.sum(volume, volDeltaLookback)
volDeltaPct = totalVol > 0 ? bullVol / totalVol * 100.0 : 50.0
fibTouchVolDelta = isTouchingFib ? volDeltaPct : na

//=====================
// INTERMARKET SERIES + REGIMES
//=====================
imClose(string symbol) =>
    request.security(symbol, tfIM, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

trendFlags(float px, float ma, int slopeBars_, float neutralPct_) =>
    float distPct = ma != 0 ? math.abs(px - ma) / ma * 100.0 : 0.0
    bool near = distPct <= neutralPct_
    bool up = not near and px > ma and px >= nz(px[slopeBars_], px)
    bool down = not near and px < ma and px <= nz(px[slopeBars_], px)
    [up, down]

f_ema_dir(float emaVal) =>
    close > emaVal and emaVal > nz(emaVal[1], emaVal) ? 1 : close < emaVal and emaVal < nz(emaVal[1], emaVal) ? -1 : 0

f_ema_dist_pct(float emaVal) =>
    emaVal != 0 ? (close - emaVal) / emaVal * 100.0 : 0.0

nq = imClose(symNQ)
bk = imClose(symBANK)
vx = imClose(symVIX)
dx = imClose(symDXY)
y10 = imClose(sym10Y)
nqMA = ta.ema(nq, maLen)
bkMA = ta.ema(bk, maLen)
vxMA = ta.ema(vx, maLen)
dxMA = ta.ema(dx, maLen)
y10MA = ta.ema(y10, maLen)
[nqUp, nqDown] = trendFlags(nq, nqMA, slopeBars, neutralBandPct)
[bkUp, bkDown] = trendFlags(bk, bkMA, slopeBars, neutralBandPct)
[vxUp, vxDown] = trendFlags(vx, vxMA, slopeBars, neutralBandPct)
[dxUp, dxDown] = trendFlags(dx, dxMA, slopeBars, neutralBandPct)
[y10Up, y10Down] = trendFlags(y10, y10MA, slopeBars, neutralBandPct)
nqBull = nqUp
nqBear = nqDown
bkBull = bkUp
bkBear = bkDown
vxRiskOn = vxDown and vx < vixMaxRiskOn
vxRiskOff = vxUp
dxRiskOn = dxDown
dxRiskOff = dxUp
y10RiskOn = y10Down
y10RiskOff = y10Up
use10YOK_on = (not use10YConfirm) or y10RiskOn
use10YOK_off = (not use10YConfirm) or y10RiskOff
riskOnBinary = nqBull and bkBull and vxRiskOn and dxRiskOn and use10YOK_on
riskOffBinary = nqBear and bkBear and vxRiskOff and dxRiskOff and use10YOK_off
int activeW10Y = use10YConfirm ? w10Y : 0
int totalWeight = wNQ + wBANK + wVIX + wDXY + activeW10Y
int scoreNeeded = int(math.max(1.0, math.ceil(totalWeight * scoreThresholdPct)))
int scoreOn = (
    (nqBull ? wNQ : 0) +
    (bkBull ? wBANK : 0) +
    (vxRiskOn ? wVIX : 0) +
    (dxRiskOn ? wDXY : 0) +
    ((use10YConfirm and y10RiskOn) ? w10Y : 0)
)
int scoreOff = (
    (nqBear ? wNQ : 0) +
    (bkBear ? wBANK : 0) +
    (vxRiskOff ? wVIX : 0) +
    (dxRiskOff ? wDXY : 0) +
    ((use10YConfirm and y10RiskOff) ? w10Y : 0)
)
scoreOnRaw = scoreOn >= scoreNeeded
scoreOffRaw = scoreOff >= scoreNeeded
anchorsOn = nqBull and bkBull
anchorsOff = nqBear and bkBear
scoreOnCandidate = scoreOnRaw and anchorsOn
scoreOffCandidate = scoreOffRaw and anchorsOff
candidateOn = imModel == "Binary Gates" ? riskOnBinary : scoreOnCandidate
candidateOff = imModel == "Binary Gates" ? riskOffBinary : scoreOffCandidate
onExclusive = candidateOn and not candidateOff
offExclusive = candidateOff and not candidateOn
var int regime = 0
var int onStreak = 0
var int offStreak = 0
var int inactiveStreak = 0
var int lastFlipBar = na
onStreak := onExclusive ? onStreak + 1 : 0
offStreak := offExclusive ? offStreak + 1 : 0
inactiveStreak := (not candidateOn and not candidateOff) ? inactiveStreak + 1 : 0
if useIntermarket
    bool canFlip = na(lastFlipBar) or (bar_index - lastFlipBar >= cooldownBars)
    if regime == 0
        if onStreak >= confirmBars
            regime := 1
            lastFlipBar := bar_index
        else if offStreak >= confirmBars
            regime := -1
            lastFlipBar := bar_index
    else if regime == 1
        if offStreak >= confirmBars and canFlip
            regime := -1
            lastFlipBar := bar_index
    else if regime == -1
        if onStreak >= confirmBars and canFlip
            regime := 1
            lastFlipBar := bar_index
    if neutralizeBars > 0 and inactiveStreak >= neutralizeBars
        regime := 0
else
    regime := 0

riskOnBase = (not useIntermarket) or regime == 1
riskOffBase = (not useIntermarket) or regime == -1

riskOn = riskOnBase
riskOff = riskOffBase

int eventNqState = nqBull ? 1 : nqBear ? -1 : 0
int eventDxyState = dxRiskOff ? 1 : dxRiskOn ? -1 : 0
// ZN is inverse to 10Y yield direction: yield down => ZN up.
int eventZnState = y10RiskOn ? 1 : y10RiskOff ? -1 : 0
int eventVixState = vxRiskOff ? 1 : vxRiskOn ? -1 : 0

if enableDebugLogs and barstate.isconfirmed
    bool stateFlip = riskOn != riskOn[1] or riskOff != riskOff[1] or regime != regime[1]
    if stateFlip
        log.info("WBDBG_STATE bar={0} useIM={1} regime={2} riskOn={3} riskOff={4} riskOnBase={5} riskOffBase={6} scoreOn={7} scoreOff={8}", bar_index, useIntermarket, regime, riskOn, riskOff, riskOnBase, riskOffBase, scoreOn, scoreOff)
    if riskOn == riskOff
        log.info("WBDBG_CONTRADICTION bar={0} regime={1} riskOn={2} riskOff={3}", bar_index, regime, riskOn, riskOff)

//=====================
// STRUCTURE CONDITIONS (direction-aware)
//=====================
dir = fibBull ? 1 : -1
zoneReady = not na(zoneUpper) and not na(zoneLower) and not na(pPivot)
breakInDir = zoneReady and barstate.isconfirmed ? (dir == 1 ? (close > zoneUpper and close[1] <= zoneUpper) : (close < zoneLower and close[1] >= zoneLower)) : false
if breakInDir
    lastBreakBar := bar_index
barsSinceBreak = na(lastBreakBar) ? int(na) : bar_index - lastBreakBar
acceptInDir = (
 zoneReady and barstate.isconfirmed and
 not na(barsSinceBreak) and barsSinceBreak > 0 and barsSinceBreak <= retestBars and
    (dir == 1 ? (low <= zoneUpper and close > zoneUpper) : (high >= zoneLower and close < zoneLower))
)
rejectAtZone = (
 zoneReady and barstate.isconfirmed and
    (rejectWick ?
        (dir == 1 ? (high >= zoneLower and close < zoneLower) : (low <= zoneUpper and close > zoneUpper)) :
        (dir == 1 ? (close < zoneLower) : (close > zoneUpper)))
)
breakAgainst = zoneReady and barstate.isconfirmed ? (dir == 1 ? (close < pPivot and close[1] >= pPivot) : (close > pPivot and close[1] <= pPivot)) : false
tagT1 = barstate.isconfirmed and not na(pT1) and (dir == 1 ? high >= pT1 : low <= pT1)
tagT2 = barstate.isconfirmed and not na(pT2) and (dir == 1 ? high >= pT2 : low <= pT2)
tagT3 = barstate.isconfirmed and not na(pT3) and (dir == 1 ? high >= pT3 : low <= pT3)
regimeAligned = dir == 1 ? riskOn : riskOff
regimeOpposed = dir == 1 ? riskOff : riskOn
acceptConfirmed = acceptInDir and regimeAligned
rejectConfirmed = rejectAtZone and regimeOpposed
breakAgainstConfirmed = breakAgainst and regimeOpposed
conflictBreak = breakInDir and (dir == 1 ? (vxRiskOff or dxRiskOff) : (vxRiskOn or dxRiskOn))
acceptEvent = oneShotEvent ? (acceptConfirmed and not acceptConfirmed[1]) : acceptConfirmed
rejectEvent = oneShotEvent ? (rejectConfirmed and not rejectConfirmed[1]) : rejectConfirmed
breakAgainstEvent = oneShotEvent ? (breakAgainstConfirmed and not breakAgainstConfirmed[1]) : breakAgainstConfirmed
conflictEvent = oneShotEvent ? (conflictBreak and not conflictBreak[1]) : conflictBreak
tagT1Event = oneShotEvent ? (tagT1 and not tagT1[1]) : tagT1
tagT2Event = oneShotEvent ? (tagT2 and not tagT2[1]) : tagT2
tagT3Event = oneShotEvent ? (tagT3 and not tagT3[1]) : tagT3

bool pivotNearZone = isValid and close <= zoneUpper and close >= zoneLower
int eventPivotInteractionCode = breakInDir ? 4 : rejectAtZone ? 3 : acceptInDir ? 1 : breakAgainst ? 2 : pivotNearZone ? 5 : 0

bool setupAcceptContinuation = acceptConfirmed
bool setupZoneRejection = rejectConfirmed
bool setupPivotContinuation = breakInDir and regimeAligned and not conflictBreak
bool setupFailedMoveReversal = breakAgainstConfirmed
bool setupReentryAfterTp1 = tagT1 and acceptInDir and regimeAligned
int setupArchetypeCode = setupAcceptContinuation ? 1 : setupZoneRejection ? 2 : setupPivotContinuation ? 3 : setupFailedMoveReversal ? 4 : setupReentryAfterTp1 ? 5 : 0

int fibLevelTouched = 0
if isValid
    float nearest = math.abs(close - p236)
    fibLevelTouched := 236
    float d382 = math.abs(close - p382)
    if d382 < nearest
        nearest := d382
        fibLevelTouched := 382
    float d500 = math.abs(close - pPivot)
    if d500 < nearest
        nearest := d500
        fibLevelTouched := 500
    float d618 = math.abs(close - p618)
    if d618 < nearest
        nearest := d618
        fibLevelTouched := 618
    float d786 = math.abs(close - p786)
    if d786 < nearest
        nearest := d786
        fibLevelTouched := 786
    float d100 = math.abs(close - pOne)
    if d100 < nearest
        fibLevelTouched := 100

bool shockContinuation = dir == 1 ? (eventNqState == 1 and eventDxyState <= 0 and eventVixState <= 0) : (eventNqState == -1 and eventDxyState >= 0 and eventVixState >= 0)
bool shockFailure = dir == 1 ? (eventNqState == -1 or eventDxyState == 1 or eventVixState == 1) : (eventNqState == 1 or eventDxyState == -1 or eventVixState == -1)
float eventShockScore = math.max(0.0, math.min(100.0, math.abs(float(scoreOn - scoreOff)) * 8.0 + math.abs(ta.roc(close, 1)) / (atr + 0.0001) * 20.0 + (conflictBreak ? 20.0 : 0.0)))
float eventReversalScore = math.max(0.0, math.min(100.0, (breakAgainstConfirmed ? 45.0 : 0.0) + (rejectConfirmed ? 35.0 : 0.0) + (conflictBreak ? 20.0 : 0.0)))
int eventModeCode = conflictBreak ? 6 : shockFailure ? 2 : shockContinuation ? 1 : rejectConfirmed ? 3 : 0

float confidenceRaw = 50.0 + float(scoreOn - scoreOff) * 4.0 + (setupAcceptContinuation ? 12.0 : 0.0) - (setupZoneRejection ? 8.0 : 0.0) - (conflictBreak ? 12.0 : 0.0) + (targetEligible20pt ? 8.0 : -12.0)
float confidenceScore = math.max(0.0, math.min(100.0, confidenceRaw))

bool entryLongTrigger = acceptEvent and dir == 1 and targetEligible20pt and not conflictBreak and not breakAgainstConfirmed
bool entryShortTrigger = acceptEvent and dir == -1 and targetEligible20pt and not conflictBreak and not breakAgainstConfirmed

if enableDebugLogs and barstate.isconfirmed and (acceptEvent or rejectEvent or breakAgainstEvent or conflictEvent or entryLongTrigger or entryShortTrigger)
    log.info("WBDBG_EVENT bar={0} dir={1} accept={2} reject={3} breakAgainst={4} conflict={5} longTrig={6} shortTrig={7} aligned={8} opposed={9}", bar_index, dir, acceptEvent, rejectEvent, breakAgainstEvent, conflictEvent, entryLongTrigger, entryShortTrigger, regimeAligned, regimeOpposed)

//=====================
// TRADE STATE MACHINE (SL / ENTRY / TP1 / TP2)
//=====================
var int TRADE_NONE    = 0
var int TRADE_SETUP   = 1
var int TRADE_ACTIVE  = 2
var int TRADE_HIT_TP1 = 3
var int TRADE_HIT_TP2 = 4
var int TRADE_STOPPED = 5
var int TRADE_EXPIRED = 6

var int tradeState = TRADE_NONE
var float entryPrice = na
var float slPrice = na
var float tp1Price = na
var float tp2Price = na
var int setupBar = na
var int entryBar = na

float slLevel = fibBull ? fibPrice(-0.236) : fibPrice(1.236)
float entryLevel = fibBull ? p618 : p382
float tp1Level = fibBull ? fibPrice(FIB_T1) : fibPrice(-0.236)
float tp2Level = fibBull ? fibPrice(FIB_T2) : fibPrice(-0.618)

if barstate.isconfirmed
    if tradeState == TRADE_NONE and zoneReady
        if fibBull and close <= entryLevel and close >= zoneLower
            tradeState := TRADE_SETUP
            setupBar := bar_index
        if not fibBull and close >= entryLevel and close <= zoneUpper
            tradeState := TRADE_SETUP
            setupBar := bar_index

    if tradeState == TRADE_SETUP and regimeAligned
        entryPrice := close
        slPrice := slLevel
        tp1Price := tp1Level
        tp2Price := tp2Level
        tradeState := TRADE_ACTIVE
        entryBar := bar_index

    if tradeState == TRADE_ACTIVE
        if fibBull
            if low <= slPrice
                tradeState := TRADE_STOPPED
            else if high >= tp2Price
                tradeState := TRADE_HIT_TP2
            else if high >= tp1Price
                tradeState := TRADE_HIT_TP1
        else
            if high >= slPrice
                tradeState := TRADE_STOPPED
            else if low <= tp2Price
                tradeState := TRADE_HIT_TP2
            else if low <= tp1Price
                tradeState := TRADE_HIT_TP1

    if tradeState == TRADE_SETUP and not na(setupBar) and bar_index - setupBar > 12
        tradeState := TRADE_EXPIRED

    if tradeState >= TRADE_HIT_TP1
        tradeState := TRADE_NONE
        entryPrice := na
        slPrice := na
        tp1Price := na
        tp2Price := na
        setupBar := na
        entryBar := na

var line slLine = line.new(na, na, na, na, color=color(na))
var line entryLine = line.new(na, na, na, na, color=color(na))
var line tp1LineTrade = line.new(na, na, na, na, color=color(na))
var line tp2LineTrade = line.new(na, na, na, na, color=color(na))
var label slLabel = label.new(na, na, "", style=label.style_none)
var label entryLabel = label.new(na, na, "", style=label.style_none)
var label tp1LblTrade = label.new(na, na, "", style=label.style_none)
var label tp2LblTrade = label.new(na, na, "", style=label.style_none)

if tradeState == TRADE_SETUP or tradeState == TRADE_ACTIVE
    int leftBar = nz(setupBar, bar_index - 10)
    line.set_xy1(slLine, leftBar, nz(slPrice, slLevel))
    line.set_xy2(slLine, bar_index, nz(slPrice, slLevel))
    line.set_color(slLine, COLOR_STOP)
    line.set_width(slLine, 2)
    label.set_xy(slLabel, bar_index, nz(slPrice, slLevel))
    label.set_text(slLabel, "SL")
    label.set_textcolor(slLabel, COLOR_STOP)

    line.set_xy1(entryLine, leftBar, nz(entryPrice, entryLevel))
    line.set_xy2(entryLine, bar_index, nz(entryPrice, entryLevel))
    line.set_color(entryLine, #FF9800)
    line.set_width(entryLine, 2)
    label.set_xy(entryLabel, bar_index, nz(entryPrice, entryLevel))
    label.set_text(entryLabel, "ENTRY")
    label.set_textcolor(entryLabel, #FF9800)

    line.set_xy1(tp1LineTrade, leftBar, nz(tp1Price, tp1Level))
    line.set_xy2(tp1LineTrade, bar_index, nz(tp1Price, tp1Level))
    line.set_color(tp1LineTrade, #00C853)
    line.set_width(tp1LineTrade, 2)
    label.set_xy(tp1LblTrade, bar_index, nz(tp1Price, tp1Level))
    label.set_text(tp1LblTrade, "TP1")
    label.set_textcolor(tp1LblTrade, #00C853)

    line.set_xy1(tp2LineTrade, leftBar, nz(tp2Price, tp2Level))
    line.set_xy2(tp2LineTrade, bar_index, nz(tp2Price, tp2Level))
    line.set_color(tp2LineTrade, #69F0AE)
    line.set_width(tp2LineTrade, 2)
    label.set_xy(tp2LblTrade, bar_index, nz(tp2Price, tp2Level))
    label.set_text(tp2LblTrade, "TP2")
    label.set_textcolor(tp2LblTrade, #69F0AE)
else
    line.set_color(slLine, color(na))
    line.set_color(entryLine, color(na))
    line.set_color(tp1LineTrade, color(na))
    line.set_color(tp2LineTrade, color(na))
    label.set_textcolor(slLabel, color(na))
    label.set_textcolor(entryLabel, color(na))
    label.set_textcolor(tp1LblTrade, color(na))
    label.set_textcolor(tp2LblTrade, color(na))

//=====================
// DRAW ALL 10 FIB LEVELS
//=====================
var line lineZero = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line236 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line382 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line linePivot = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line618 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line786 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineOne = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineT1 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineT2 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineT3 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)

var box zoneBox = box.new(bar_index, close, bar_index, close, bgcolor=color(na), border_color=color(na))

fallbackLeftBar = int(math.max(0, bar_index - targetLookbackBars))
anchorLeftBar = int(math.max(0, na(anchorHighBar) or na(anchorLowBar) ? fallbackLeftBar : math.min(anchorHighBar, anchorLowBar)))
drawLeftBar = useConfluenceAnchorSpan ? anchorLeftBar : fallbackLeftBar

drawAnchoredLine(line id, bool visible, float price, color col, int width_, int leftBar) =>
    if visible and not na(price)
        line.set_xy1(id, leftBar, price)
        line.set_xy2(id, bar_index, price)
        line.set_color(id, col)
        line.set_width(id, width_)
        line.set_style(id, line.style_solid)
        line.set_extend(id, extendLevelsRight ? extend.right : extend.none)
    else
        line.set_color(id, color(na))

drawAnchoredLine(lineZero, true, pZero, COLOR_ANCHOR, WIDTH_ANCHOR, drawLeftBar)
drawAnchoredLine(line236, true, p236, COLOR_RETRACEMENT, WIDTH_RETRACEMENT, drawLeftBar)
drawAnchoredLine(line382, true, p382, COLOR_RETRACEMENT, WIDTH_RETRACEMENT, drawLeftBar)
drawAnchoredLine(linePivot, true, pPivot, COLOR_PIVOT, WIDTH_PIVOT, drawLeftBar)
drawAnchoredLine(line618, true, p618, COLOR_RETRACEMENT, WIDTH_RETRACEMENT, drawLeftBar)
drawAnchoredLine(line786, true, p786, COLOR_RETRACEMENT, WIDTH_RETRACEMENT, drawLeftBar)
drawAnchoredLine(lineOne, true, pOne, COLOR_ANCHOR, WIDTH_ANCHOR, drawLeftBar)
drawAnchoredLine(lineT1, true, pT1, COLOR_TARGET, WIDTH_TARGET, drawLeftBar)
drawAnchoredLine(lineT2, true, pT2, COLOR_TARGET, WIDTH_TARGET, drawLeftBar)
drawAnchoredLine(lineT3, true, pT3, COLOR_TARGET, WIDTH_TARGET, drawLeftBar)

if not na(zoneFillUpper) and not na(zoneFillLower)
    box.set_left(zoneBox, drawLeftBar)
    box.set_right(zoneBox, bar_index)
    box.set_top(zoneBox, zoneFillUpper)
    box.set_bottom(zoneBox, zoneFillLower)
    box.set_bgcolor(zoneBox, color.new(COLOR_PIVOT, 92))
    box.set_border_color(zoneBox, color.new(COLOR_PIVOT, 100))
else
    box.set_bgcolor(zoneBox, color(na))
    box.set_border_color(zoneBox, color(na))

bgcolor(showBg and useIntermarket ? (riskOn ? color.new(color.green, 92) : riskOff ? color.new(color.red, 92) : color.new(color.gray, 94)) : na)

float trendStr = math.min(adxVal / 60.0 * 100.0, 100.0)
float maxIMScore = float(totalWeight)
float corrStr = maxIMScore > 0 ? math.max(float(scoreOn), float(scoreOff)) / maxIMScore * 100.0 : 0.0

float ema21 = ta.ema(close, 21)
float ema50 = ta.ema(close, 50)
float ema200 = ta.ema(close, 200)
int ema21Dir = f_ema_dir(ema21)
int ema50Dir = f_ema_dir(ema50)
int ema200Dir = f_ema_dir(ema200)
float ema21DistPct = f_ema_dist_pct(ema21)
float ema50DistPct = f_ema_dist_pct(ema50)
float ema200DistPct = f_ema_dist_pct(ema200)

//=====================
// AG FEATURE EXPORT (hidden plots — display=display.none)
//=====================
plot(adxVal, "adx_14", display=display.none)
plot(diSpread, "di_spread_14", display=display.none)
plot(adxSlope, "adx_slope_14", display=display.none)
plot(er10, "er_10", display=display.none)
plot(er20, "er_20", display=display.none)
plot(vixPctRank, "vix_pct_252d", display=display.none)
plot(atrPct, "atr_pct_20", display=display.none)
plot(vixDaily, "vix_close", display=display.none)

plot(clv, "clv", display=display.none)
plot(signedVol, "signed_vol_proxy", display=display.none)
plot(volDeltaPct, "vol_delta_pct", display=display.none)
plot(nz(fibTouchVolDelta), "fib_touch_vol_delta", display=display.none)

plot(float(htfConfPivot), "htf_conf_pivot", display=display.none)
plot(float(htfConf382), "htf_conf_382", display=display.none)
plot(float(htfConf618), "htf_conf_618", display=display.none)
plot(float(htfConfTotal), "htf_conf_total", display=display.none)

plot(float(regime), "im_regime", display=display.none)
plot(float(scoreOn), "im_score_on", display=display.none)
plot(float(scoreOff), "im_score_off", display=display.none)

plot(fibRange, "fib_range", display=display.none)
plot(float(dir), "fib_direction", display=display.none)
plot(nz(confluenceQuality), "confluence_quality", display=display.none)

plot(float(tradeState), "trade_state", display=display.none)
plot(tradeState == TRADE_ACTIVE and not na(entryBar) ? float(bar_index - entryBar) : 0.0, "bars_in_trade", display=display.none)

plot(trendStr, "trend_strength", display=display.none)
plot(corrStr, "correlation_strength", display=display.none)

// v6 minimum model contract + simplified trigger contract
plot(confidenceScore, "ml_confidence_score", display=display.none)
plot(float(dir), "ml_direction_code", display=display.none)
plot(float(setupArchetypeCode), "ml_setup_archetype_code", display=display.none)
plot(float(fibLevelTouched), "ml_fib_level_touched", display=display.none)
plot(float(stopFamilyCode), "ml_stop_family_code", display=display.none)
plot(float(eventModeCode), "ml_event_mode_code", display=display.none)
plot(eventShockScore, "ml_event_shock_score", display=display.none)
plot(eventReversalScore, "ml_event_reversal_score", display=display.none)
plot(float(eventNqState), "ml_event_nq_state", display=display.none)
plot(float(eventDxyState), "ml_event_dxy_state", display=display.none)
plot(float(eventZnState), "ml_event_zn_state", display=display.none)
plot(float(eventVixState), "ml_event_vix_state", display=display.none)
plot(float(eventPivotInteractionCode), "ml_event_pivot_interaction_code", display=display.none)
plot(float(ema21Dir), "ml_ema21_dir", display=display.none)
plot(float(ema50Dir), "ml_ema50_dir", display=display.none)
plot(float(ema200Dir), "ml_ema200_dir", display=display.none)
plot(ema21DistPct, "ml_ema21_dist_pct", display=display.none)
plot(ema50DistPct, "ml_ema50_dist_pct", display=display.none)
plot(ema200DistPct, "ml_ema200_dist_pct", display=display.none)
plot(entryLongTrigger ? 1.0 : 0.0, "ml_entry_long_trigger", display=display.none)
plot(entryShortTrigger ? 1.0 : 0.0, "ml_entry_short_trigger", display=display.none)
plot(tagT1Event ? 1.0 : 0.0, "ml_tp1_hit_event", display=display.none)
plot(tagT2Event ? 1.0 : 0.0, "ml_tp2_hit_event", display=display.none)

//=====================
// ALERTS
//=====================
riskOnFlip = useIntermarket and regime == 1 and regime[1] != 1
riskOffFlip = useIntermarket and regime == -1 and regime[1] != -1
alertcondition(entryLongTrigger, "WARBIRD ENTRY LONG", "Warbird long entry trigger. Close={{close}}")
alertcondition(entryShortTrigger, "WARBIRD ENTRY SHORT", "Warbird short entry trigger. Close={{close}}")
alertcondition(acceptEvent, "ACCEPT (AutoFib) + Regime Aligned", "Accepted through AutoFib zone with regime aligned confirmation. Close={{close}}")
alertcondition(rejectEvent, "REJECT (AutoFib) + Regime Opposed", "Rejected at AutoFib zone while intermarket regime opposed direction. Close={{close}}")
alertcondition(breakAgainstEvent, "PIVOT BREAK (against) + Regime Opposed", "Broke pivot against AutoFib direction with intermarket opposition. Close={{close}}")
alertcondition(tagT1Event, "TARGET HIT: 1.236", "Warbird TARGET 1 (1.236) tagged. Price={{close}}")
alertcondition(tagT2Event, "TARGET HIT: 1.618", "Warbird TARGET 2 (1.618) tagged. Price={{close}}")
alertcondition(tagT3Event, "TARGET HIT: 2.0", "Warbird TARGET 3 (2.0) tagged. Price={{close}}")
alertcondition(conflictEvent, "CONFLICT: Break vs VIX/DXY", "Caution: Break in AutoFib direction while VIX/DXY disagree. Close={{close}}")
alertcondition(riskOnFlip, "Flip to RISK-ON", "Intermarket flipped to RISK-ON.")
alertcondition(riskOffFlip, "Flip to RISK-OFF", "Intermarket flipped to RISK-OFF.")
