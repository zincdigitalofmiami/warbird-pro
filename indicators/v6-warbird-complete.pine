// © Kirk / ZINC Digital
// Warbird v6 — Complete: Visuals + ML Features + Exhaustion
// Merge: v5 visuals + v4 ML engine
// Date: 2026-03-23
//@version=6
indicator("Warbird v6 Complete", overlay = false, max_lines_count = 500, max_boxes_count = 500, max_labels_count = 500)

// =====================================================================
// INPUT GROUPS
// =====================================================================
string G_STYL = "Style & Colors"
string G_FIB  = "Fibonacci Engine"
string G_OSC  = "Velocity Oscillator"
string G_MTF  = "MTF & Consensus"
string G_UI   = "Dashboard & UI"
string G_CORR = "Correlation Analysis"
string G_ADAP = "Adaptive Settings"
string G_ML   = "ML Export & Debugging"

// =====================================================================
// INPUTS: STYLE
// =====================================================================
color c_bull    = input.color(#089981, "Bullish Color", group = G_STYL)
color c_bear    = input.color(#f23645, "Bearish Color", group = G_STYL)
color c_neut    = input.color(#787b86, "Neutral Color", group = G_STYL)
color c_warn    = input.color(#ff9800, "Warning Color", group = G_STYL)
color c_dash_bg = input.color(#1a1a2e, "Dashboard Background", group = G_UI)
color c_dash_bd = input.color(#00BCD4, "Dashboard Border", group = G_UI)

// =====================================================================
// INPUTS: FIBONACCI ENGINE
// =====================================================================
int leftBars        = input.int(10, "Pivot Left Bars", minval = 1, group = G_FIB)
int rightBars       = input.int(5, "Pivot Right Bars", minval = 1, group = G_FIB)
float pivotAtrMult  = input.float(2.0, "Pivot ATR Multiplier", group = G_FIB)
float sl_mult       = input.float(0.236, "Stop Loss Multiplier", group = G_FIB)
float t1_mult       = input.float(1.236, "Target 1 Multiplier", group = G_FIB)
float t2_mult       = input.float(1.618, "Target 2 Multiplier", group = G_FIB)
float t3_mult       = input.float(2.000, "Target 3 Multiplier", group = G_FIB)

// =====================================================================
// INPUTS: VELOCITY OSCILLATOR
// =====================================================================
int fastLen   = input.int(8, "Fast Length", group = G_OSC)
int slowLen   = input.int(17, "Slow Length", group = G_OSC)
int sigLen    = input.int(9, "Signal Smoothing", group = G_OSC)
float v_mult  = input.float(10.0, "Velocity Sensitivity", group = G_OSC)

// =====================================================================
// INPUTS: MTF & CORRELATION
// =====================================================================
string tf1 = input.timeframe("15", "MTF 1 Timeframe", group = G_MTF)
string tf2 = input.timeframe("60", "MTF 2 Timeframe", group = G_MTF)
string tf3 = input.timeframe("240", "MTF 3 Timeframe", group = G_MTF)
string corrSym = input.symbol("SPY", "Correlation Symbol", group = G_CORR)
int corrLen    = input.int(20, "Correlation Length", group = G_CORR)

// =====================================================================
// INPUTS: ADAPTIVE & ML
// =====================================================================
float exhAtrMult = input.float(0.7, "Exhaustion ATR Multiplier", minval = 0.3, maxval = 1.0, step = 0.05, group = G_ADAP)
bool showMLData  = input.bool(false, "Show ML Features in Data Window", group = G_ML)

// =====================================================================
// CONSENSUS LOGIC (6 oscillators)
// =====================================================================
f_get_consensus() =>
    float r = ta.rsi(close, 14)
    float k = ta.stoch(close, high, low, 14)
    float d = ta.sma(k, 3)
    float cci = ta.cci(close, 20)
    [_, bb_u, bb_l] = ta.bb(close, 20, 2)
    float bbp = (close - bb_l) / (math.max(bb_u - bb_l, 0.0001))
    [_, __, m_hist] = ta.macd(close, 12, 26, 9)
    float vwap = ta.vwap(close)

    int score = 0
    score += (r > 50 ? 1 : -1)
    score += (k > d ? 1 : -1)
    score += (cci > 0 ? 1 : -1)
    score += (bbp > 0.5 ? 1 : -1)
    score += (m_hist > 0 ? 1 : -1)
    score += (close > vwap ? 1 : -1)
    score

// =====================================================================
// CORE CALCULATIONS
// =====================================================================
int score_curr = f_get_consensus()
int score_mtf1 = request.security(syminfo.tickerid, tf1, f_get_consensus())
int score_mtf2 = request.security(syminfo.tickerid, tf2, f_get_consensus())
int score_mtf3 = request.security(syminfo.tickerid, tf3, f_get_consensus())

float atr = ta.atr(14)
float ph  = ta.pivothigh(high, leftBars, rightBars)
float pl  = ta.pivotlow(low, leftBars, rightBars)

var float anchorHigh = 0.0
var float anchorLow  = 0.0
var int   highIdx    = 0
var int   lowIdx     = 0

if not na(ph) and (anchorHigh == 0.0 or math.abs(ph - anchorHigh) > atr * pivotAtrMult)
    anchorHigh := ph
    highIdx    := bar_index - rightBars
if not na(pl) and (anchorLow == 0.0 or math.abs(pl - anchorLow) > atr * pivotAtrMult)
    anchorLow  := pl
    lowIdx     := bar_index - rightBars

float f_range = anchorHigh - anchorLow
float fibMid  = (anchorHigh + anchorLow) / 2
bool isValid  = anchorHigh != 0.0 and anchorLow != 0.0

var int regime = 0
if barstate.isconfirmed
    regime := close > fibMid ? 1 : -1
bool isBull = regime == 1

// Fib levels
float l_sl  = isBull ? anchorLow - f_range * sl_mult : anchorHigh + f_range * sl_mult
float l_236 = isBull ? anchorLow + f_range * 0.236 : anchorHigh - f_range * 0.236
float l_382 = isBull ? anchorLow + f_range * 0.382 : anchorHigh - f_range * 0.382
float l_piv = isBull ? anchorLow + f_range * 0.5   : anchorHigh - f_range * 0.5
float l_618 = isBull ? anchorLow + f_range * 0.618 : anchorHigh - f_range * 0.618
float l_786 = isBull ? anchorLow + f_range * 0.786 : anchorHigh - f_range * 0.786
float l_one = isBull ? anchorHigh : anchorLow
float l_t1  = isBull ? anchorLow + f_range * t1_mult : anchorHigh - f_range * t1_mult
float l_t2  = isBull ? anchorLow + f_range * t2_mult : anchorHigh - f_range * t2_mult
float l_t3  = isBull ? anchorLow + f_range * t3_mult : anchorHigh - f_range * t3_mult

// =====================================================================
// LEVEL INTERACTION TRACKING (from v4)
// =====================================================================
f_level_feat(float lvl) =>
    float tol = atr * 0.05
    bool touch = math.abs(close - lvl) < tol or math.abs(high - lvl) < tol or math.abs(low - lvl) < tol
    int bs = nz(ta.barssince(touch), 100)
    float tc_f = ta.sma(touch ? 1.0 : 0.0, 55) * 55
    int tc = int(math.round(tc_f))
    bool brk = (close[1] < lvl and close > lvl) or (close[1] > lvl and close < lvl)
    bool hld = (regime == 1 ? high >= lvl and close < lvl : low <= lvl and close > lvl)
    [touch, bs, tc, brk, hld]

[t236, bs236, tc236, br236, h236] = f_level_feat(l_236)
[t382, bs382, tc382, br382, h382] = f_level_feat(l_382)
[t500, bs500, tc500, br500, h500] = f_level_feat(l_piv)
[t618, bs618, tc618, br618, h618] = f_level_feat(l_618)
[t786, bs786, tc786, br786, h786] = f_level_feat(l_786)
[t100, bs100, tc100, br100, h100] = f_level_feat(l_one)

// =====================================================================
// EXHAUSTION ENGINE (from v4)
// =====================================================================
float p_vel = ta.roc(close, 5) / (atr + 0.0001)
float v_vel = ta.roc(volume, 5)
float exh_score = (p_vel > 0 and v_vel < 0) ? 1.0 : (p_vel < 0 and v_vel < 0) ? -1.0 : 0.0
bool shrinking = ta.atr(3) < ta.atr(8) * exhAtrMult
bool is_doji = math.abs(close - open) < (high - low + 0.0001) * 0.2
float candle_exh = (shrinking ? 0.33 : 0) + (is_doji ? 0.33 : 0)
float vol_delta = volume * ((high - low) == 0 ? 0 : (2 * close - high - low) / (high - low))
float resonance = ta.correlation(vol_delta, close - close[1], 14)
float energy = 100.0 - (math.abs(exh_score) * 40 + candle_exh * 40 + (resonance < 0.3 ? 20 : 0))
energy := math.max(0, math.min(100, energy))
bool fib_exh_flag = energy < 40 and (math.abs(close - l_piv) < atr * 0.1 or math.abs(close - l_618) < atr * 0.1 or math.abs(close - l_382) < atr * 0.1 or math.abs(close - l_t1) < atr * 0.1 or math.abs(close - l_sl) < atr * 0.1)

// =====================================================================
// SENTIMENT (from v4 — composite)
// =====================================================================
float rsi = ta.rsi(close, 14)
[_, __, m_hist_sent] = ta.macd(close, 8, 17, 9)
float bull_pct = (ta.sma(volume * math.max((close - low) / (high - low + 0.0001), 0), 20)) / (ta.sma(volume, 20) + 0.0001) * 100
float sentiment = ((rsi - 50) * 0.5) + (m_hist_sent > 0 ? 20 : -20) + (bull_pct - 50) * 0.2

// =====================================================================
// SESSION FEATURES
// =====================================================================
int ny_h = hour(time, "America/New_York")
int ny_m = minute(time, "America/New_York")
int ny_t = ny_h * 100 + ny_m
int sess = ny_t >= 930 and ny_t <= 1600 ? 2 : (ny_t >= 300 and ny_t < 930 ? 1 : 0)

// =====================================================================
// VELOCITY OSCILLATOR
// =====================================================================
[macd_v, sig_v, hist_v] = ta.macd(close, fastLen, slowLen, sigLen)
float velocity = (macd_v / (math.max(atr, 0.0001))) * v_mult
float velocity_sig = ta.ema(velocity, sigLen)

plot(0, "Zero", color.new(c_neut, 50))
p_vel_plot = plot(velocity, "Velocity", color.new(velocity > 0 ? c_bull : c_bear, 20), linewidth = 2)
p_sig_plot = plot(velocity_sig, "Signal", color.new(c_neut, 40), linewidth = 1)
fill(p_vel_plot, p_sig_plot, velocity > velocity_sig ? color.new(c_bull, 60) : color.new(c_bear, 60))

// =====================================================================
// CORRELATION
// =====================================================================
float corrVal = ta.correlation(close, request.security(corrSym, timeframe.period, close), corrLen)

// =====================================================================
// SIGNAL LOGIC
// =====================================================================
bool align_bull = score_mtf1 > 0 and score_mtf2 > 0 and score_mtf3 > 0
bool align_bear = score_mtf1 < 0 and score_mtf2 < 0 and score_mtf3 < 0

if (ta.crossover(velocity, velocity_sig) and align_bull and close > fibMid)
    label.new(bar_index, low, "WARBIRD LONG", color=c_bull, textcolor=color.white, style=label.style_label_up, size=size.small, force_overlay=true)
if (ta.crossunder(velocity, velocity_sig) and align_bear and close < fibMid)
    label.new(bar_index, high, "WARBIRD SHORT", color=c_bear, textcolor=color.white, style=label.style_label_down, size=size.small, force_overlay=true)

// =====================================================================
// EXHAUSTION VISUAL
// =====================================================================
plotshape(fib_exh_flag, "Exhaustion", shape.diamond, location.abovebar, c_warn, 0, "EXH", color.white, true, size.tiny, force_overlay=true)

// =====================================================================
// DASHBOARD: CORRELATION & SENTIMENT (top right)
// =====================================================================
var table ui_top = table.new(position.top_right, 6, 2, bgcolor=color.new(c_dash_bg, 10), border_color=color.new(c_dash_bd, 50), border_width=1, force_overlay=true)
if barstate.islast
    table.cell(ui_top, 0, 0, "Correlation (" + corrSym + ")", text_color=color.white, bgcolor=color.new(c_dash_bd, 30))
    table.cell(ui_top, 1, 0, str.tostring(math.round(corrVal, 2)), text_color=corrVal > 0 ? c_bull : c_bear, bgcolor=color.new(c_dash_bg, 10))
    table.cell(ui_top, 0, 1, "WARBIRD SENTIMENT", text_color=color.white, bgcolor=color.new(c_dash_bd, 30))
    color g_col = score_curr > 3 ? c_bull : score_curr < -3 ? c_bear : c_neut
    table.cell(ui_top, 1, 1, score_curr > 0 ? "BULLISH (" + str.tostring(score_curr) + ")" : "BEARISH (" + str.tostring(score_curr) + ")", text_color=color.white, bgcolor=color.new(g_col, 20))
    // Energy meter
    table.cell(ui_top, 2, 0, "ENERGY", text_color=color.white, bgcolor=color.new(c_dash_bd, 30))
    color e_col = energy >= 70 ? c_bull : energy >= 40 ? c_warn : c_bear
    table.cell(ui_top, 2, 1, str.tostring(math.round(energy)) + "%", text_color=color.white, bgcolor=color.new(e_col, 20))

// =====================================================================
// DASHBOARD: METRICS TABLE (bottom left)
// =====================================================================
var table metrics = table.new(position.bottom_left, 4, 8, bgcolor=color.new(c_dash_bg, 10), border_color=color.new(c_dash_bd, 50), border_width=1, force_overlay=true)
if barstate.islast
    table.cell(metrics, 0, 0, "WARBIRD METRICS", text_color=color.white, bgcolor=color.new(c_dash_bd, 20))
    table.cell(metrics, 1, 0, "VALUE", text_color=color.white, bgcolor=color.new(c_dash_bd, 20))
    table.cell(metrics, 2, 0, "% DIST", text_color=color.white, bgcolor=color.new(c_dash_bd, 20))
    table.cell(metrics, 3, 0, "MTF", text_color=color.white, bgcolor=color.new(c_dash_bd, 20))
    table.cell(metrics, 0, 1, "Current Price", text_color=c_neut)
    table.cell(metrics, 1, 1, str.tostring(close), text_color=color.white)
    table.cell(metrics, 0, 2, "Stop Loss", text_color=c_bear)
    table.cell(metrics, 1, 2, str.tostring(math.round(l_sl, 2)), text_color=color.white)
    table.cell(metrics, 2, 2, str.tostring(math.round(math.abs(l_sl-close)/close*100, 2)) + "%")
    table.cell(metrics, 0, 3, "Target 1", text_color=c_bull)
    table.cell(metrics, 1, 3, str.tostring(math.round(l_t1, 2)), text_color=color.white)
    table.cell(metrics, 2, 3, str.tostring(math.round(math.abs(l_t1-close)/close*100, 2)) + "%")
    table.cell(metrics, 0, 4, "Target 2", text_color=c_bull)
    table.cell(metrics, 1, 4, str.tostring(math.round(l_t2, 2)), text_color=color.white)
    table.cell(metrics, 2, 4, str.tostring(math.round(math.abs(l_t2-close)/close*100, 2)) + "%")
    table.cell(metrics, 0, 5, "Target 3", text_color=c_bull)
    table.cell(metrics, 1, 5, str.tostring(math.round(l_t3, 2)), text_color=color.white)
    table.cell(metrics, 2, 5, str.tostring(math.round(math.abs(l_t3-close)/close*100, 2)) + "%")
    table.cell(metrics, 3, 1, tf1 + ": " + str.tostring(score_mtf1), text_color=score_mtf1 > 0 ? c_bull : c_bear)
    table.cell(metrics, 3, 2, tf2 + ": " + str.tostring(score_mtf2), text_color=score_mtf2 > 0 ? c_bull : c_bear)
    table.cell(metrics, 3, 3, tf3 + ": " + str.tostring(score_mtf3), text_color=score_mtf3 > 0 ? c_bull : c_bear)

// =====================================================================
// VISUALS: FIB LINES ON CHART
// =====================================================================
if barstate.islast
    int fibLeft = math.min(highIdx, lowIdx)
    // 0 and 1 (white, 2pt)
    line.new(fibLeft, anchorLow, bar_index, anchorLow, color=color.white, width=2, force_overlay=true)
    line.new(fibLeft, anchorHigh, bar_index, anchorHigh, color=color.white, width=2, force_overlay=true)
    // Retracements (gray, 1pt)
    line.new(fibLeft, l_236, bar_index, l_236, color=#808080, width=1, force_overlay=true)
    line.new(fibLeft, l_382, bar_index, l_382, color=#808080, width=1, force_overlay=true)
    line.new(fibLeft, l_piv, bar_index, l_piv, color=#ff9800, width=2, force_overlay=true)
    line.new(fibLeft, l_618, bar_index, l_618, color=#808080, width=1, force_overlay=true)
    line.new(fibLeft, l_786, bar_index, l_786, color=#808080, width=1, force_overlay=true)
    // SL (red, 2pt dashed)
    line.new(fibLeft, l_sl, bar_index, l_sl, color=#FF1744, width=2, style=line.style_dashed, force_overlay=true)
    // Targets (green, 2pt)
    line.new(fibLeft, l_t1, bar_index, l_t1, color=#4CAF50, width=2, force_overlay=true)
    line.new(fibLeft, l_t2, bar_index, l_t2, color=#4CAF50, width=2, force_overlay=true)
    line.new(fibLeft, l_t3, bar_index, l_t3, color=#4CAF50, width=2, force_overlay=true)

// =====================================================================
// TOP PULSE BAR
// =====================================================================
var table pulse = table.new(position.top_center, 1, 1, force_overlay=true)
if barstate.islast
    color p_col = align_bull ? c_bull : align_bear ? c_bear : c_neut
    table.cell(pulse, 0, 0, "⚡ WARBIRD | " + (align_bull ? "STRONG BULL" : align_bear ? "STRONG BEAR" : "NEUTRAL") + " | ENERGY: " + str.tostring(math.round(energy)) + "%", text_color=color.white, bgcolor=color.new(p_col, 20))

// =====================================================================
// ML FEATURE EXPORT (hidden plots)
// =====================================================================

// Fib structure
plot(float(regime), "ml_fib_regime", display = showMLData ? display.data_window : display.none)
plot(isValid ? (close - anchorLow) / f_range : na, "ml_norm_price", display = showMLData ? display.data_window : display.none)
plot(isValid ? f_range / close * 100 : na, "ml_range_vol", display = showMLData ? display.data_window : display.none)
plot(float(bar_index - math.max(highIdx, lowIdx)), "ml_bars_since_anchor", display = showMLData ? display.data_window : display.none)

// .236 level
plot(t236 ? 1.0 : 0.0, "ml_t_236", display = showMLData ? display.data_window : display.none)
plot(float(bs236), "ml_bs_236", display = showMLData ? display.data_window : display.none)
plot(float(tc236), "ml_tc_236", display = showMLData ? display.data_window : display.none)
plot(br236 ? 1.0 : 0.0, "ml_br_236", display = showMLData ? display.data_window : display.none)
plot(h236 ? 1.0 : 0.0, "ml_h_236", display = showMLData ? display.data_window : display.none)

// .382 level
plot(t382 ? 1.0 : 0.0, "ml_t_382", display = showMLData ? display.data_window : display.none)
plot(float(bs382), "ml_bs_382", display = showMLData ? display.data_window : display.none)
plot(float(tc382), "ml_tc_382", display = showMLData ? display.data_window : display.none)
plot(br382 ? 1.0 : 0.0, "ml_br_382", display = showMLData ? display.data_window : display.none)
plot(h382 ? 1.0 : 0.0, "ml_h_382", display = showMLData ? display.data_window : display.none)

// .500 level
plot(t500 ? 1.0 : 0.0, "ml_t_500", display = showMLData ? display.data_window : display.none)
plot(float(bs500), "ml_bs_500", display = showMLData ? display.data_window : display.none)
plot(float(tc500), "ml_tc_500", display = showMLData ? display.data_window : display.none)
plot(br500 ? 1.0 : 0.0, "ml_br_500", display = showMLData ? display.data_window : display.none)
plot(h500 ? 1.0 : 0.0, "ml_h_500", display = showMLData ? display.data_window : display.none)

// .618 level
plot(t618 ? 1.0 : 0.0, "ml_t_618", display = showMLData ? display.data_window : display.none)
plot(float(bs618), "ml_bs_618", display = showMLData ? display.data_window : display.none)
plot(float(tc618), "ml_tc_618", display = showMLData ? display.data_window : display.none)
plot(br618 ? 1.0 : 0.0, "ml_br_618", display = showMLData ? display.data_window : display.none)
plot(h618 ? 1.0 : 0.0, "ml_h_618", display = showMLData ? display.data_window : display.none)

// .786 level
plot(t786 ? 1.0 : 0.0, "ml_t_786", display = showMLData ? display.data_window : display.none)
plot(float(bs786), "ml_bs_786", display = showMLData ? display.data_window : display.none)
plot(float(tc786), "ml_tc_786", display = showMLData ? display.data_window : display.none)
plot(br786 ? 1.0 : 0.0, "ml_br_786", display = showMLData ? display.data_window : display.none)
plot(h786 ? 1.0 : 0.0, "ml_h_786", display = showMLData ? display.data_window : display.none)

// 1.0 level
plot(t100 ? 1.0 : 0.0, "ml_t_100", display = showMLData ? display.data_window : display.none)
plot(float(bs100), "ml_bs_100", display = showMLData ? display.data_window : display.none)
plot(float(tc100), "ml_tc_100", display = showMLData ? display.data_window : display.none)
plot(br100 ? 1.0 : 0.0, "ml_br_100", display = showMLData ? display.data_window : display.none)
plot(h100 ? 1.0 : 0.0, "ml_h_100", display = showMLData ? display.data_window : display.none)

// Exhaustion features
plot(energy, "ml_energy", display = showMLData ? display.data_window : display.none)
plot(resonance, "ml_resonance", display = showMLData ? display.data_window : display.none)
plot(exh_score, "ml_exh_score", display = showMLData ? display.data_window : display.none)
plot(candle_exh, "ml_candle_exh", display = showMLData ? display.data_window : display.none)
plot(fib_exh_flag ? 1.0 : 0.0, "ml_fib_exh_flag", display = showMLData ? display.data_window : display.none)

// Sentiment & volume
plot(sentiment, "ml_sent", display = showMLData ? display.data_window : display.none)
plot(bull_pct, "ml_bvol", display = showMLData ? display.data_window : display.none)

// Correlation
plot(corrVal, "ml_corr", display = showMLData ? display.data_window : display.none)

// MTF consensus
plot(float(score_curr), "ml_score_curr", display = showMLData ? display.data_window : display.none)
plot(float(score_mtf1), "ml_score_mtf1", display = showMLData ? display.data_window : display.none)
plot(float(score_mtf2), "ml_score_mtf2", display = showMLData ? display.data_window : display.none)
plot(float(score_mtf3), "ml_score_mtf3", display = showMLData ? display.data_window : display.none)

// Session
plot(float(sess), "ml_sess", display = showMLData ? display.data_window : display.none)
plot(float(dayofweek(time)), "ml_dow", display = showMLData ? display.data_window : display.none)

// Velocity oscillator
plot(velocity, "ml_velocity", display = showMLData ? display.data_window : display.none)
plot(velocity_sig, "ml_velocity_sig", display = showMLData ? display.data_window : display.none)

// Signal direction
plot(align_bull ? 1 : align_bear ? -1 : 0, "ml_alignment", display = showMLData ? display.data_window : display.none)

// =====================================================================
// ALERTS
// =====================================================================
alertcondition(ta.crossover(velocity, velocity_sig) and align_bull and close > fibMid, "WARBIRD LONG", "WARBIRD LONG signal. Close={{close}}")
alertcondition(ta.crossunder(velocity, velocity_sig) and align_bear and close < fibMid, "WARBIRD SHORT", "WARBIRD SHORT signal. Close={{close}}")
alertcondition(fib_exh_flag, "EXHAUSTION at Fib Level", "Exhaustion detected at fib level. Energy={{plot_0}}. Close={{close}}")
