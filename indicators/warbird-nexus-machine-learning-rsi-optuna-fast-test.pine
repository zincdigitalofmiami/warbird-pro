    tooltip = "Threshold above which confluence is considered strongly bullish.\nUsed for alerts and dashboard coloring.")
confLowInput = input.float(30.868639925029193, "Low Confluence", minval = 10.0, maxval = 45.0, group = GRP_CONF,
    tooltip = "Threshold below which confluence is considered strongly bearish.")
