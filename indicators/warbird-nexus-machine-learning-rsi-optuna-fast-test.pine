gasOutOffsetInput = input.float(10.0, "Gas-Out Offset", minval = 2.0, maxval = 20.0, step = 0.5, group = GRP_EXHAUST,
    tooltip = "Vertical offset applied to gas-out diamonds so they remain readable above/below the oscillator trace.")

