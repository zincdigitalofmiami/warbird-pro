footprintVaPercentInput = input.float(50.0, "Footprint VA %", minval = 1.0, maxval = 100.0, step = 1.0, group = GRP_DELTA)
footprintImbalancePercentInput = input.float(195.0, "Footprint Imbalance %", minval = 100.0, maxval = 1000.0, step = 10.0, group = GRP_DELTA)
deltaLookbackInput = input.int(10, "Delta Lookback", minval = 3, maxval = 20, group = GRP_DELTA)
deltaSlopeLenInput = input.int(5, "Delta Slope Length", minval = 2, maxval = 10, group = GRP_DELTA)
deltaFlipThresholdInput = input.float(0.10, "Delta Flip Threshold", minval = 0.05, maxval = 0.40, step = 0.01, group = GRP_DELTA)
