vfFastBlendWeightInput = input.float(0.60, "Fast Blend Weight", minval = 0.0, maxval = 1.0, step = 0.01, group = GRP_VOL,
    tooltip = "Blend weight for fast volume-flow smoothing.\nSlow weight is 1 - Fast Blend Weight.")
vfPeakLenMultInput = input.float(4.0, "Peak Length Mult", minval = 1.0, maxval = 8.0, step = 0.1, group = GRP_VOL,
    tooltip = "Lookback multiplier used to normalize volume-flow amplitude.")
vfSignalThresholdInput = input.float(50.0, "Signal Threshold", minval = 50.0, maxval = 80.0, step = 0.1, group = GRP_VOL,
