vfAlphaInput = input.int(18, "Volume Flow Opacity", minval = 0, maxval = 100, group = GRP_VOL,
    tooltip = "Fill opacity for volume flow. Keep 10–25 so oscillator line stays visible.")
vfBodyWeightInput = input.float(0.70, "Bar Delta Weight", minval = 0.0, maxval = 1.0, step = 0.01, group = GRP_VOL,
    tooltip = "Weight applied to the current footprint bar delta.\nThe remaining weight uses rolling footprint delta. No candle-body proxy is used.")
vfFastLenMultInput = input.float(0.60, "Fast Length Mult", minval = 0.1, maxval = 3.0, step = 0.01, group = GRP_VOL,
    tooltip = "Fast EMA length multiplier for volume-flow smoothing.")
vfSlowLenMultInput = input.float(1.40, "Slow Length Mult", minval = 0.1, maxval = 4.0, step = 0.01, group = GRP_VOL,
