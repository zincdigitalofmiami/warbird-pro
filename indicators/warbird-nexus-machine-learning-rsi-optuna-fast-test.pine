fatigueBarsInput = input.int(4, "Confirmation Bars", minval = 1, maxval = 5, group = GRP_EXHAUST,
    tooltip = "Consecutive bars of weakening/strengthening needed.\n1=fast, 3=balanced, 5=very strict")
showGasOutInput = input.bool(true, "Show Delta Gas-Out", group = GRP_EXHAUST,
