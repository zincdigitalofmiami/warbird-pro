//@version=6
// ══════════════════════════════════════════════════════════
// Warbird Nexus Machine Learning RSI
// ══════════════════════════════════════════════════════════
// Author:  Kirk Musick
// Version: 1.2.5-optuna-footprint — Nexus footprint/multi-mode lane
// Defaults restored to Optuna Fast 5m Signal Quality April 25 trial #357 after expanded #492 visual rejection.
// Signal-quality research only; not a production trade/P&L champion.

indicator(
    title            = "Warbird Nexus Machine Learning RSI - Optuna Fast Test",
    shorttitle       = "Nexus ML Fast",
    overlay          = false,
    precision        = 2,
    max_lines_count  = 500,
    max_labels_count = 500,
    max_bars_back    = 5000)

// ══════════════════════════════════════════════════════════
// CONSTANTS
// ══════════════════════════════════════════════════════════
GRP_MAIN    = "⚙️ Main Settings"
GRP_VISUAL  = "🎨 Visual Settings"
GRP_ZONES   = "📐 Zones & Fills"
GRP_VOL     = "📊 Volume Flow"
GRP_REGIME  = "🔬 Regime Detection"
GRP_DIV     = "🔀 Divergence"
GRP_EXHAUST = "💨 Momentum Fatigue"
GRP_DELTA   = "🧩 Footprint Delta"
GRP_KNN     = "🧠 KNN Bias"
GRP_CONF    = "🎯 Confluence"
GRP_DASH    = "📊 Dashboard"
GRP_ALERT   = "🔔 Alerts"
GRP_COLORS  = "🎨 Colors"

const string INDICATOR_VERSION = "v1.2.5-optuna-footprint"
const color WARBIRD_BULL = #26C6DA
const color WARBIRD_BEAR = #cc0000
const color WARBIRD_YELLOW = #FFEB3B
const color WARBIRD_NEUTRAL = #888888

// ══════════════════════════════════════════════════════════
// INPUTS — Main Settings
// ══════════════════════════════════════════════════════════
lengthInput = input.int(34, "Engine Period", minval = 2, maxval = 200, group = GRP_MAIN,
    tooltip = "Core lookback for the AMF engine.\n" +
              "• 8–12: responsive, more signals, suited for scalping\n" +
              "• 18: balanced 5m Nexus starting point\n" +
              "• 20–50: smooth, fewer signals, suited for swing")
sourceInput = input.source(open, "Source", group = GRP_MAIN,
    tooltip = "Price source for calculations.\nClose = standard | HLC3 = smoother | OHLC4 = smoothest")
smoothTypeInput = input.string("SMA", "Smoothing",
    options = ["EMA", "SMA", "DEMA", "TEMA", "WMA", "VWMA"],
    group = GRP_MAIN,
    tooltip = "Smoothing algorithm for the oscillator core.\n" +
              "• DEMA: double-exponential, fast & smooth (recommended)\n" +
              "• TEMA: triple-exponential, ultra-smooth\n" +
              "• EMA: classic exponential\n" +
              "• WMA: weighted, gives recent bars more importance\n" +
              "• VWMA: volume-weighted, responds to volume spikes\n" +
              "• SMA: simple average, equal weight")
presetInput = input.string("Default", "Preset",
    options = ["Scalping", "Default", "Swing", "Position"],
    group = GRP_MAIN,
    tooltip = "Quick presets:\n" +
              "• Scalping: period 8, fast smoothing, tight zones\n" +
              "• Default: uses the tuned 5m input defaults\n" +
              "• Swing: period 21, relaxed zones\n" +
              "• Position: period 34, wide zones, maximum filter")
modeInput = input.string("5m", "Mode",
    options = ["5m", "15m", "1H", "4H"],
    group = GRP_MAIN,
    tooltip = "Select the chart timeframe mode. All modes stay on this single Nexus study lane; per-mode defaults must come from manifest-backed Optuna evidence.")

// ══════════════════════════════════════════════════════════
// INPUTS — Signal Line
// ══════════════════════════════════════════════════════════
sigLenInput = input.int(8, "Signal Period", minval = 1, maxval = 50, group = GRP_MAIN,
    tooltip = "Smoothing period for the trigger line.\nKeep below Engine Period for clean crossovers.\n5m start: 6")
sigTypeInput = input.string("EMA", "Signal Smoothing",
    options = ["EMA", "SMA", "DEMA", "WMA"],
    group = GRP_MAIN,
    tooltip = "Smoothing method for the signal/trigger line.\nEMA recommended for responsive crossovers.")
showCrossDotsInput = input.bool(true, "Show Cross Dots", group = GRP_MAIN,
    tooltip = "Show dots when oscillator crosses the signal line")

// ══════════════════════════════════════════════════════════
// INPUTS — Visual Settings
// ══════════════════════════════════════════════════════════
themeInput = input.string("Auto", "Theme",
    options = ["Auto", "Dark", "Light"],
    group = GRP_VISUAL,
    tooltip = "Chart color theme.\n" +
              "• Auto: detects from chart background\n" +
              "• Dark: optimized for dark backgrounds\n" +
              "• Light: optimized for light/white backgrounds")
adaptColorInput = input.bool(true, "Adaptive Line Color", group = GRP_VISUAL,
    tooltip = "ON — oscillator color shifts with momentum direction.\nOFF — uses a neutral muted color.")
showWatermarkInput = input.bool(true, "Show Watermark", group = GRP_VISUAL,
    tooltip = "Display the Warbird Pro watermark on chart")
bullColorInput = input.color(WARBIRD_BULL, "Bull", inline = "colors", group = GRP_COLORS)
bearColorInput = input.color(WARBIRD_BEAR, "Bear", inline = "colors", group = GRP_COLORS)

// ══════════════════════════════════════════════════════════
// INPUTS — Zones
// ══════════════════════════════════════════════════════════
obInput = input.float(71.84351171357757, "Overbought Level", minval = 55.0, maxval = 95.0, step = 0.1, group = GRP_ZONES,
    tooltip = "Upper threshold for overbought zone.\n5m start: 75")
osInput = input.float(19.58825492875482, "Oversold Level", minval = 5.0, maxval = 45.0, step = 0.1, group = GRP_ZONES,
    tooltip = "Lower threshold for oversold zone.\n5m start: 25")
obAlphaInput = input.int(20, "OB Fill Opacity", minval = 0, maxval = 100, group = GRP_ZONES,
    tooltip = "Opacity of the overbought zone fill. 0=invisible, 100=solid")
osAlphaInput = input.int(20, "OS Fill Opacity", minval = 0, maxval = 100, group = GRP_ZONES,
    tooltip = "Opacity of the oversold zone fill. 0=invisible, 100=solid")

// ══════════════════════════════════════════════════════════
// INPUTS — Volume Flow
// ══════════════════════════════════════════════════════════
showVfInput = input.bool(true, "Show Volume Flow", group = GRP_VOL,
