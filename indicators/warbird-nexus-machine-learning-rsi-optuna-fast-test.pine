confErThresholdInput = input.float(0.30, "ER Trend Vote", minval = 0.05, maxval = 0.80, step = 0.01, group = GRP_CONF,
    tooltip = "Efficiency-ratio threshold used by the confluence trend vote.")
confSmoothLenInput = input.int(3, "Confluence Smoothing", minval = 1, maxval = 20, group = GRP_CONF,
