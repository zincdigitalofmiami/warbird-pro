vfGateThresholdInput = input.float(50.0, "Confirmation Threshold", minval = 50.0, maxval = 80.0, step = 0.1, group = GRP_VOL,
    tooltip = "Volume-flow confirmation threshold for optional filters.\nBear threshold is calculated as 100 - this value.")

// ══════════════════════════════════════════════════════════
