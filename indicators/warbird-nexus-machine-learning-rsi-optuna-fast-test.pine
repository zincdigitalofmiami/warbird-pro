    tooltip = "Alert on hidden divergence detection")
alVolFlowInput = input.bool(false, "Volume Flow Alerts", group = GRP_ALERT,
    tooltip = "Alert when volume flow crosses the midline")
alFatigueInput = input.bool(true, "Fatigue Alerts", group = GRP_ALERT,
    tooltip = "Alert when fatigue label fires in OB or OS zone")
alKnnInput = input.bool(false, "KNN Flip Alerts", group = GRP_ALERT,
    tooltip = "Alert when KNN bias flips direction")
alConfInput = input.bool(false, "Confluence Alerts", group = GRP_ALERT,
    tooltip = "Alert when confluence meter crosses high/low thresholds")

// ══════════════════════════════════════════════════════════
// THEME DETECTION & COLORS
// ══════════════════════════════════════════════════════════
isDark = switch themeInput
    "Dark"  => true
    "Light" => false
    =>         color.r(chart.bg_color) < 128

TEXT_COLOR    = isDark ? #E0E0E0 : #1A1A1A
TEXT_MUTED    = isDark ? color.new(#9E9E9E, 0) : color.new(#757575, 0)

BULL_TEXT     = bullColorInput
BEAR_TEXT     = bearColorInput
NEUTRAL_TEXT  = WARBIRD_YELLOW

TABLE_BG      = isDark ? color.new(#131722, 5)  : color.new(#FFFFFF, 5)
TABLE_BORDER  = isDark ? color.new(#2A2E39, 0)  : color.new(#D0D0D0, 0)
TABLE_ROW_ALT = isDark ? color.new(#1C2030, 0)  : color.new(#F0F4F8, 0)
HEADER_BG     = isDark ? color.new(#0D47A1, 0)  : color.new(WARBIRD_BULL, 15)
HEADER_TEXT   = #FFFFFF

LINE_SUBTLE   = isDark ? color.new(#666666, 0) : color.new(#999999, 0)
WM_COLOR      = isDark ? color.new(#FFFFFF, 60) : color.new(#000000, 60)

// ══════════════════════════════════════════════════════════
// PRESET RESOLUTION
// ══════════════════════════════════════════════════════════
int effLen = switch presetInput
    "Scalping"  => 8
    "Swing"     => 21
    "Position"  => 34
    => lengthInput

float effOB = switch presetInput
    "Scalping"  => 75.0
    "Swing"     => 80.0
    "Position"  => 85.0
    => obInput

float effOS = switch presetInput
    "Scalping"  => 25.0
    "Swing"     => 20.0
    "Position"  => 15.0
    => osInput

// ══════════════════════════════════════════════════════════
// FUNCTIONS
// ══════════════════════════════════════════════════════════
safeDiv(float num, float den, float fallback = 0.0) =>
    den != 0 and not na(num) and not na(den) ? num / den : fallback

uSmooth(series float src, simple int len, simple string method) =>
    float e1 = ta.ema(src, len)
    float e2 = ta.ema(e1, len)
    float e3 = ta.ema(e2, len)
    switch method
        "EMA"  => e1
        "SMA"  => ta.sma(src, len)
        "DEMA" => 2.0 * e1 - e2
        "TEMA" => 3.0 * e1 - 3.0 * e2 + e3
        "WMA"  => ta.wma(src, len)
        "VWMA" => ta.vwma(src, len)
        => e1

calcER(series float src, simple int len) =>
    float direction  = math.abs(src - src[len])
    float volatility = math.sum(math.abs(src - src[1]), len)
    safeDiv(direction, volatility, 0.0)

// ══════════════════════════════════════════════════════════
// RESOLVED CONSTANTS (sizes, positions)
// ══════════════════════════════════════════════════════════
dashPos = switch dashPosStr
    "Top Left"     => position.top_left
    "Top Right"    => position.top_right
    "Bottom Left"  => position.bottom_left
    "Bottom Right" => position.bottom_right
    => position.top_right

divSz = switch divLblSizeInput
    "Tiny"   => size.tiny
    "Small"  => size.small
    "Normal" => size.normal
    => size.tiny

knnSz = switch knnSizeInput
    "Tiny"   => size.tiny
    "Small"  => size.small
    "Normal" => size.normal
    => size.small

// ══════════════════════════════════════════════════════════
// WARMUP & PROTECTION
// ══════════════════════════════════════════════════════════
int WARMUP_BARS = math.max(effLen * 3, 60)
bool isWarmedUp = bar_index >= WARMUP_BARS

// ══════════════════════════════════════════════════════════
// FOOTPRINT DELTA — real ask/bid volume from TradingView
// ══════════════════════════════════════════════════════════
footprint reqFootprint = request.footprint(footprintTicksPerRowInput, footprintVaPercentInput, footprintImbalancePercentInput)
bool fpAvailable = not na(reqFootprint)
float fpBarDelta = fpAvailable ? footprint.delta(reqFootprint) : na
float fpTotalVolume = na
if fpAvailable
    array<volume_row> fpRows = footprint.rows(reqFootprint)
    int fpRowCount = array.size(fpRows)
    float rowTotal = 0.0
    if fpRowCount > 0
        for ri = 0 to fpRowCount - 1
            volume_row row = array.get(fpRows, ri)
            rowTotal += nz(volume_row.total_volume(row), 0.0)
    fpTotalVolume := rowTotal
bool fpFlowAvailable = fpAvailable and not na(fpBarDelta) and not na(fpTotalVolume) and fpTotalVolume > 0
float fpCumDelta = fpFlowAvailable ? math.sum(fpBarDelta, deltaLookbackInput) : na
float fpAvgVolume = fpFlowAvailable ? ta.sma(fpTotalVolume, deltaLookbackInput) : na
float normCumDelta = fpFlowAvailable and not na(fpAvgVolume) and fpAvgVolume > 0 ? safeDiv(fpCumDelta, math.max(fpAvgVolume * deltaLookbackInput, 1.0), 0.0) : na
float deltaSlope = fpFlowAvailable ? normCumDelta - nz(normCumDelta[deltaSlopeLenInput], normCumDelta) : na
float barDeltaRatio = fpFlowAvailable ? safeDiv(fpBarDelta, fpTotalVolume, 0.0) : na
int deltaDir = not fpFlowAvailable or na(normCumDelta) ? 0 : normCumDelta > deltaFlipThresholdInput ? 1 : normCumDelta < -deltaFlipThresholdInput ? -1 : 0
bool gasOutBull = fpFlowAvailable and normCumDelta > 0.0 and deltaSlope < -gasoutThreshInput
bool gasOutBear = fpFlowAvailable and normCumDelta < 0.0 and deltaSlope > gasoutThreshInput
bool deltaBullConfirm = fpFlowAvailable and deltaDir == 1
bool deltaBearConfirm = fpFlowAvailable and deltaDir == -1

// ══════════════════════════════════════════════════════════
// ENGINE — Adaptive Momentum Fusion (AMF)
// ══════════════════════════════════════════════════════════
float roc = safeDiv(sourceInput - sourceInput[effLen], sourceInput[effLen], 0.0) * 100.0
float rocSmoothed = nz(uSmooth(roc, effLen, smoothTypeInput), 0.0)
float rocHigh = nz(ta.highest(rocSmoothed, effLen * 3), rocSmoothed)
float rocLow  = nz(ta.lowest(rocSmoothed, effLen * 3), rocSmoothed)
float nroc = nz(safeDiv(rocSmoothed - rocLow, rocHigh - rocLow, 0.5) * 100.0, 50.0)

float er = nz(calcER(sourceInput, effLen), 0.0)
float impulseRaw = nz(ta.change(sourceInput, 1), 0.0)
float impulseAbs = nz(ta.atr(effLen), math.abs(impulseRaw) + 0.0001)
float normalizedImpulse = safeDiv(impulseRaw, impulseAbs, 0.0) * er
float ewiSmoothed = nz(uSmooth(normalizedImpulse, effLen, smoothTypeInput), 0.0)
float ewiHigh = nz(ta.highest(ewiSmoothed, effLen * 4), ewiSmoothed)
float ewiLow  = nz(ta.lowest(ewiSmoothed, effLen * 4), ewiSmoothed)
float ewi = nz(safeDiv(ewiSmoothed - ewiLow, ewiHigh - ewiLow, 0.5) * 100.0, 50.0)

float stochHigh = nz(ta.highest(sourceInput, effLen), sourceInput)
float stochLow  = nz(ta.lowest(sourceInput, effLen), sourceInput)
float stochRaw  = safeDiv(sourceInput - stochLow, stochHigh - stochLow, 0.5) * 100.0
int   smpLen    = math.max(effLen / 2, 2)
float smp = nz(uSmooth(stochRaw, smpLen, "EMA"), 50.0)

float erSmoothed  = nz(uSmooth(er, effLen, "EMA"), 0.3)
float trendWeight = math.min(erSmoothed * 1.5, 0.75)
float rangeWeight = 1.0 - trendWeight

int   oscSmoothLen = math.max(effLen / 3, 2)
float oscRaw = trendWeight * (nroc * 0.55 + ewi * 0.45) + rangeWeight * smp
float oscVal = math.max(0.0, math.min(100.0, nz(uSmooth(oscRaw, oscSmoothLen, smoothTypeInput), 50.0)))
float sigVal = nz(uSmooth(oscVal, sigLenInput, sigTypeInput), oscVal)

// ══════════════════════════════════════════════════════════
// VOLUME FLOW — footprint-delta Volatility-Normalized Volume Flow (VNVF)
// ══════════════════════════════════════════════════════════
bool  volumeAvailable = fpFlowAvailable
float barVolume       = fpFlowAvailable ? fpTotalVolume : 0.0
float vfDeltaWeight = math.max(0.0, math.min(1.0, vfBodyWeightInput))
float rollingDeltaMean = fpFlowAvailable ? fpCumDelta / math.max(float(deltaLookbackInput), 1.0) : 0.0
float signedVol       = fpFlowAvailable ? fpBarDelta * vfDeltaWeight + rollingDeltaMean * (1.0 - vfDeltaWeight) : 0.0
float atrNorm     = nz(ta.atr(effLen), 1.0)
float avgVol      = math.max(nz(ta.sma(barVolume, effLen * 2), barVolume), 1.0)
float vnvfRaw     = fpFlowAvailable ? safeDiv(signedVol, atrNorm * avgVol, 0.0) : 0.0

int   vnvfFastLen = math.max(math.round(effLen * vfFastLenMultInput), 2)
int   vnvfSlowLen = math.max(math.round(effLen * vfSlowLenMultInput), 3)
float vnvfFast  = nz(ta.ema(vnvfRaw, vnvfFastLen), 0.0)
float vnvfSlow  = nz(ta.ema(vnvfRaw, vnvfSlowLen), 0.0)
float vfFastBlendWeight = math.max(0.0, math.min(1.0, vfFastBlendWeightInput))
float vnvfBlend = vnvfFast * vfFastBlendWeight + vnvfSlow * (1.0 - vfFastBlendWeight)

float vnvfAbsBlend = math.abs(vnvfBlend)
int   vnvfPeakLen = math.max(math.round(effLen * vfPeakLenMultInput), 1)
float vnvfPeak = nz(ta.highest(vnvfAbsBlend, vnvfPeakLen), vnvfAbsBlend + 0.0001)
float vnvfPeakSafe = math.max(vnvfPeak, 0.0001)
float vfRawVal = math.max(0.0, math.min(100.0, safeDiv(vnvfBlend, vnvfPeakSafe, 0.0) * 50.0 + 50.0))
float vfVal = volumeAvailable ? vfRawVal : na
float vfCalcVal = volumeAvailable ? vfRawVal : 50.0
float vfSignalBearThreshold = 100.0 - vfSignalThresholdInput
float vfGateBearThreshold = 100.0 - vfGateThresholdInput

// ══════════════════════════════════════════════════════════
// REGIME DETECTION — Efficiency Ratio + Composite Score
// ══════════════════════════════════════════════════════════
bool erTrending = erSmoothed > 0.3
int regimeScoreMax = volumeAvailable ? 4 : 3
int regimeScore = (oscVal > sigVal ? 1 : 0) + (oscVal > 50.0 ? 1 : 0) + (volumeAvailable and vfCalcVal > 50.0 ? 1 : 0) + (erTrending ? 1 : 0)

int regFdOb = math.max(regimeObAlpha - 20, 0)
int regFdOs = math.max(regimeOsAlpha - 20, 0)
color regObFill = not showRegimeInput ? na : regimeScore >= regimeScoreMax ? color.new(bullColorInput, 100 - regimeObAlpha) : regimeScore == regimeScoreMax - 1 ? color.new(bullColorInput, 100 - regFdOb) : na
color regOsFill = not showRegimeInput ? na : regimeScore == 0 ? color.new(bearColorInput, 100 - regimeOsAlpha) : regimeScore == 1 ? color.new(bearColorInput, 100 - regFdOs) : na

// ══════════════════════════════════════════════════════════
// OSCILLATOR MOMENTUM (acceleration)
// ══════════════════════════════════════════════════════════
float oscMom    = oscVal - nz(oscVal[3], oscVal)
bool  momAccel  = oscMom > 2.0
bool  momDecel  = oscMom < -2.0
string momStr   = momAccel ? "Accel ▲" : momDecel ? "Decel ▼" : "Steady"
color  momCol   = momAccel ? BULL_TEXT : momDecel ? BEAR_TEXT : NEUTRAL_TEXT

// ══════════════════════════════════════════════════════════
// MOMENTUM FATIGUE
// ══════════════════════════════════════════════════════════
bool fatigueObWeak = oscVal >= effOB and oscVal < nz(oscVal[1], oscVal)
bool fatigueOsStr  = oscVal <= effOS and oscVal > nz(oscVal[1], oscVal)

var int fatObCount = 0
var int fatOsCount = 0
fatObCount := fatigueObWeak ? fatObCount + 1 : 0
fatOsCount := fatigueOsStr  ? fatOsCount + 1 : 0

bool fatObSignal = showFatigueInput and fatObCount == fatigueBarsInput and isWarmedUp
bool fatOsSignal = showFatigueInput and fatOsCount == fatigueBarsInput and isWarmedUp

// ══════════════════════════════════════════════════════════
// KNN BIAS — Manhattan Distance + Inverse-Distance Weighting
// ══════════════════════════════════════════════════════════
var array<float> kF1 = array.new<float>()
var array<float> kF2 = array.new<float>()
var array<float> kF3 = array.new<float>()
var array<float> kF4 = array.new<float>()
var array<int>   kY  = array.new<int>()

float feat1 = oscVal / 100.0
float feat2 = vfCalcVal / 100.0
float feat3 = math.max(0.0, math.min(1.0, (oscVal - sigVal + 50.0) / 100.0))
float feat4 = math.max(0.0, math.min(1.0, erSmoothed))

float kAtr = nz(ta.atr(14), 0.0001)
var int kLabel = 0
int kOutcome = close > close[1] + kAtr * knnAtrLabelThresholdInput ? 1 : close < close[1] - kAtr * knnAtrLabelThresholdInput ? 0 : kLabel
kLabel := kOutcome

float feat1Prev = nz(feat1[1], feat1)
float feat2Prev = nz(feat2[1], feat2)
float feat3Prev = nz(feat3[1], feat3)
float feat4Prev = nz(feat4[1], feat4)

if bar_index > 2 and isWarmedUp
    array.push(kF1, feat1Prev)
    array.push(kF2, feat2Prev)
    array.push(kF3, feat3Prev)
    array.push(kF4, feat4Prev)
    array.push(kY, kOutcome)
    if array.size(kF1) > knnWindowInput
        array.shift(kF1)
        array.shift(kF2)
        array.shift(kF3)
        array.shift(kF4)
        array.shift(kY)

float knnVal = 50.0
int   kSize  = array.size(kF1)
if kSize >= knnKInput
    var array<float> kDist = array.new<float>()
    array.clear(kDist)
    float kSizeF = kSize * 1.0
    for i = 0 to kSize - 1
        float d = math.abs(feat1 - array.get(kF1, i)) + math.abs(feat2 - array.get(kF2, i)) + math.abs(feat3 - array.get(kF3, i)) + math.abs(feat4 - array.get(kF4, i))
        float recencyBonus = 1.0 + (i * 1.0 / kSizeF) * knnRecencyBoostInput
        array.push(kDist, d / recencyBonus)
    float kBullVotes   = 0.0
    float kTotalWeight = 0.0
    for _k = 0 to knnKInput - 1
        int   mi      = array.indexof(kDist, array.min(kDist))
        float distVal = array.get(kDist, mi)
        float w       = 1.0 / (distVal + 0.001)
        kBullVotes   += array.get(kY, mi) == 1 ? w : 0.0
        kTotalWeight += w
        array.set(kDist, mi, 9999.0)
    knnVal := safeDiv(kBullVotes, kTotalWeight, 0.5) * 100.0

bool  knnIsBull = knnVal >= knnBullThresholdInput
bool  knnIsBear = knnVal <= knnBearThresholdInput
int   knnConf   = knnIsBull ? math.round(knnVal) : knnIsBear ? math.round(100.0 - knnVal) : math.round(math.abs(knnVal - 50.0) * 2.0)
color knnCol    = knnIsBull ? BULL_TEXT : knnIsBear ? BEAR_TEXT : color.new(color.gray, 20)

var bool prevKnnBull = false
var bool prevKnnBear = false
bool knnFlipBull = knnIsBull and not prevKnnBull
bool knnFlipBear = knnIsBear and not prevKnnBear
prevKnnBull := knnIsBull
prevKnnBear := knnIsBear

// ══════════════════════════════════════════════════════════
// CONFLUENCE METER — weighted composite of all subsystems
// ══════════════════════════════════════════════════════════
int confBullVotes = 0
int confBearVotes = 0

bool confErTrending = erSmoothed > confErThresholdInput
confBullVotes += oscVal > confOscBullThresholdInput ? 1 : 0
confBearVotes += oscVal < confOscBearThresholdInput ? 1 : 0
confBullVotes += oscVal > sigVal ? 1 : 0
confBearVotes += oscVal < sigVal ? 1 : 0
confBullVotes += volumeAvailable and vfCalcVal > confVfBullThresholdInput ? 1 : 0
confBearVotes += volumeAvailable and vfCalcVal < confVfBearThresholdInput ? 1 : 0
confBullVotes += confErTrending and oscVal > 50.0 ? 1 : 0
confBearVotes += confErTrending and oscVal < 50.0 ? 1 : 0
confBullVotes += knnIsBull ? 1 : 0
confBearVotes += knnIsBear ? 1 : 0
int   confNet = confBullVotes - confBearVotes
float confSources = volumeAvailable ? 5.0 : 4.0
float confRaw = (confNet + confSources) / (confSources * 2.0) * 100.0
float confVal = math.max(0.0, math.min(100.0, nz(ta.ema(confRaw, confSmoothLenInput), 50.0)))

bool confHighCross = ta.crossover(confVal, confHighInput) and isWarmedUp
bool confLowCross  = ta.crossunder(confVal, confLowInput) and isWarmedUp

string confStr = confVal >= confHighInput ? "Strong Bull" : confVal <= confLowInput ? "Strong Bear" : confVal > 55.0 ? "Lean Bull" : confVal < 45.0 ? "Lean Bear" : "Mixed"
color confColor = confVal >= confHighInput ? BULL_TEXT : confVal <= confLowInput ? BEAR_TEXT : confVal > 55.0 ? color.new(BULL_TEXT, 40) : confVal < 45.0 ? color.new(BEAR_TEXT, 40) : NEUTRAL_TEXT

// ══════════════════════════════════════════════════════════
// OSCILLATOR LINE COLOR
// ══════════════════════════════════════════════════════════
color lineCol = oscVal >= effOB ? bullColorInput : oscVal <= effOS ? bearColorInput : adaptColorInput ? (oscVal >= 50.0 ? color.new(bullColorInput, 40) : color.new(bearColorInput, 40)) : color.new(bullColorInput, 60)
barcolor(lineCol, title = "Nexus Oscillator Bar Color")

// ══════════════════════════════════════════════════════════
// DIVERGENCE DETECTION
// ══════════════════════════════════════════════════════════
int   pivSpan = math.max(effLen / 2, 2)
float phRaw   = ta.pivothigh(high, pivSpan, pivSpan)
float plRaw   = ta.pivotlow(low, pivSpan, pivSpan)

var float prevHH_p = na
var float prevHH_o = na
var int   prevHH_b = na
var float prevLL_p = na
var float prevLL_o = na
var int   prevLL_b = na

float curHH_p = na
float curHH_o = na
float curLL_p = na
float curLL_o = na

if not na(phRaw)
    curHH_p := high[pivSpan]
    curHH_o := oscVal[pivSpan]

if not na(plRaw)
    curLL_p := low[pivSpan]
    curLL_o := oscVal[pivSpan]

bool dRegBull = false
bool dRegBear = false
bool dHidBull = false
bool dHidBear = false

if not na(curHH_p) and not na(prevHH_p)
    bool hhFresh = not na(prevHH_b) ? (bar_index[pivSpan] - prevHH_b) <= divMaxAgeInput : false
    if curHH_p > prevHH_p and curHH_o < prevHH_o and hhFresh
        dRegBear := true
    if curHH_p < prevHH_p and curHH_o > prevHH_o and hhFresh
        dHidBear := true

if not na(curLL_p) and not na(prevLL_p)
    bool llFresh = not na(prevLL_b) ? (bar_index[pivSpan] - prevLL_b) <= divMaxAgeInput : false
    if curLL_p < prevLL_p and curLL_o > prevLL_o and llFresh
        dRegBull := true
    if curLL_p > prevLL_p and curLL_o < prevLL_o and llFresh
        dHidBull := true

float sfPriceRange   = nz(ta.highest(high, effLen * 4) - ta.lowest(low, effLen * 4), 1.0)
float sfMinPriceAbs  = sfPriceRange * (divMinPctInput / 100.0)
float sfOscSwingLL   = not na(curLL_o) and not na(prevLL_o) ? math.abs(curLL_o - prevLL_o) : 0.0
float sfOscSwingHH   = not na(curHH_o) and not na(prevHH_o) ? math.abs(curHH_o - prevHH_o) : 0.0
float sfPriceSwingLL = not na(curLL_p) and not na(prevLL_p) ? math.abs(curLL_p - prevLL_p) : 0.0
float sfPriceSwingHH = not na(curHH_p) and not na(prevHH_p) ? math.abs(curHH_p - prevHH_p) : 0.0
bool sfVolPassBull = not divVolConfInput or not volumeAvailable[pivSpan] or vfCalcVal[pivSpan] > vfGateThresholdInput
bool sfVolPassBear = not divVolConfInput or not volumeAvailable[pivSpan] or vfCalcVal[pivSpan] < vfGateBearThreshold
bool sfPassBull = not divFilterInput or (sfOscSwingLL >= divMinOscInput and sfPriceSwingLL >= sfMinPriceAbs and sfVolPassBull)
bool sfPassBear = not divFilterInput or (sfOscSwingHH >= divMinOscInput and sfPriceSwingHH >= sfMinPriceAbs and sfVolPassBear)

color divRegBullCol = color.new(bullColorInput, 100 - divRegAlpha)
color divRegBearCol = color.new(bearColorInput, 100 - divRegAlpha)
color divHidBullCol = color.new(bullColorInput, 100 - divHidAlpha)
color divHidBearCol = color.new(bearColorInput, 100 - divHidAlpha)

if divRegInput and dRegBull and sfPassBull and isWarmedUp
    line.new(prevLL_b, prevLL_o, bar_index[pivSpan], curLL_o, color = divRegBullCol, width = 2, style = line.style_solid)
    label.new(bar_index[pivSpan], curLL_o, "D▲", style = label.style_label_up, color = divRegBullCol, textcolor = color.white, size = divSz, tooltip = "Regular Bullish Divergence\nPrice: Lower Low | Osc: Higher Low\nPotential reversal upward")

if divRegInput and dRegBear and sfPassBear and isWarmedUp
    line.new(prevHH_b, prevHH_o, bar_index[pivSpan], curHH_o, color = divRegBearCol, width = 2, style = line.style_solid)
    label.new(bar_index[pivSpan], curHH_o, "D▼", style = label.style_label_down, color = divRegBearCol, textcolor = color.white, size = divSz, tooltip = "Regular Bearish Divergence\nPrice: Higher High | Osc: Lower High\nPotential reversal downward")

if divHidInput and dHidBull and sfPassBull and isWarmedUp
    line.new(prevLL_b, prevLL_o, bar_index[pivSpan], curLL_o, color = divHidBullCol, width = 2, style = line.style_dashed)
    label.new(bar_index[pivSpan], curLL_o, "H▲", style = label.style_label_up, color = divHidBullCol, textcolor = color.white, size = divSz, tooltip = "Hidden Bullish Divergence\nPrice: Higher Low | Osc: Lower Low\nUptrend continuation")

if divHidInput and dHidBear and sfPassBear and isWarmedUp
    line.new(prevHH_b, prevHH_o, bar_index[pivSpan], curHH_o, color = divHidBearCol, width = 2, style = line.style_dashed)
    label.new(bar_index[pivSpan], curHH_o, "H▼", style = label.style_label_down, color = divHidBearCol, textcolor = color.white, size = divSz, tooltip = "Hidden Bearish Divergence\nPrice: Lower High | Osc: Higher High\nDowntrend continuation")

if not na(curHH_p)
    prevHH_p := curHH_p
    prevHH_o := curHH_o
    prevHH_b := bar_index[pivSpan]

if not na(curLL_p)
    prevLL_p := curLL_p
    prevLL_o := curLL_o
    prevLL_b := bar_index[pivSpan]

// ══════════════════════════════════════════════════════════
// PLOTS
// ══════════════════════════════════════════════════════════
color obFillCol = color.new(bullColorInput, 100 - obAlphaInput)
color osFillCol = color.new(bearColorInput, 100 - osAlphaInput)

p_vfUp   = plot(showVfInput and volumeAvailable ? math.max(vfCalcVal, 50.0) : na, "VF Bull", color.new(bullColorInput, 70), linewidth = 1)
p_vfDown = plot(showVfInput and volumeAvailable ? math.min(vfCalcVal, 50.0) : na, "VF Bear", color.new(bearColorInput, 70), linewidth = 1)
p_vfBase = plot(showVfInput and volumeAvailable ? 50.0 : na, "VF Base", color = na, editable = false)
fill(p_vfUp, p_vfBase, color.new(bullColorInput, 100 - vfAlphaInput), title = "VF Bull Fill")
fill(p_vfDown, p_vfBase, color.new(bearColorInput, 100 - vfAlphaInput), title = "VF Bear Fill")

p_osc = plot(oscVal, "NFE Oscillator", lineCol, linewidth = 3)
p_sig = plot(sigVal, "Signal Line", LINE_SUBTLE, linewidth = 1)

bool crossUp   = ta.crossover(oscVal, sigVal)
bool crossDown = ta.crossunder(oscVal, sigVal)
bool bullReversalSignal = crossUp and isWarmedUp and oscVal < 50.0 and knnIsBull and deltaBullConfirm
bool bearReversalSignal = crossDown and isWarmedUp and oscVal > 50.0 and knnIsBear and deltaBearConfirm
bool lowConvictionSignal = isWarmedUp and ((crossUp and oscVal < 50.0 and not bullReversalSignal) or (crossDown and oscVal > 50.0 and not bearReversalSignal))
float crossDotY = showCrossDotsInput and (crossUp or crossDown) ? sigVal : na
color crossDotColor = crossUp ? bullColorInput : bearColorInput
plotshape(crossDotY, "Cross Dot", shape.circle, location.absolute, crossDotColor, size = size.tiny)

float reversalY = bullReversalSignal ? math.max(0.0, oscVal - 8.0) : bearReversalSignal ? math.min(100.0, oscVal + 8.0) : na
color reversalColor = bullReversalSignal ? bullColorInput : bearColorInput
plotshape(reversalY, "Confirmed Reversal", shape.diamond, location.absolute, reversalColor, size = size.normal)
plotshape(lowConvictionSignal ? sigVal : na, "Low Conviction Signal", shape.circle, location.absolute, WARBIRD_YELLOW, size = size.tiny)
float fatigueY = fatObSignal ? math.min(100.0, oscVal + 6.0) : fatOsSignal ? math.max(0.0, oscVal - 6.0) : na
color fatigueColor = color.new(color.white, 50)
plotshape(fatigueY, "Momentum Fatigue", shape.diamond, location.absolute, fatigueColor, size = size.small)
float gasOutY = showGasOutInput and gasOutBull ? math.min(100.0, oscVal + gasOutOffsetInput) : showGasOutInput and gasOutBear ? math.max(0.0, oscVal - gasOutOffsetInput) : na
plotshape(gasOutY, "Delta Gas-Out", shape.diamond, location.absolute, color.new(color.white, 50), size = size.small)

color obLineCol  = color.new(bullColorInput, 50)
color osLineCol  = color.new(bearColorInput, 50)
color midLineCol = color.new(color.gray, 50)

p_ob  = plot(effOB, "OB Level", obLineCol, linewidth = 1, style = plot.style_circles)
p_mid = plot(50.0,  "Midline", midLineCol, linewidth = 1, style = plot.style_circles)
p_os  = plot(effOS, "OS Level", osLineCol, linewidth = 1, style = plot.style_circles)
p_top = plot(100.0, color = na, editable = false, display = display.none)
p_bot = plot(0.0,   color = na, editable = false, display = display.none)

fill(p_osc, p_ob, oscVal >= effOB ? obFillCol : na, title = "OB Fill")
fill(p_os, p_osc, oscVal <= effOS ? osFillCol : na, title = "OS Fill")
fill(p_osc, p_mid, effOB, 50.0, obFillCol, color.new(chart.bg_color, 100), title = "Bull Gradient")
fill(p_mid, p_osc, 50.0, effOS, color.new(chart.bg_color, 100), osFillCol, title = "Bear Gradient")
fill(p_top, p_ob, regObFill, title = "Regime OB State")
fill(p_os, p_bot, regOsFill, title = "Regime OS State")
plot(showConfluenceInput ? confVal : na, "Confluence", confColor, linewidth = 1, style = plot.style_stepline)
plot(fpFlowAvailable ? 1.0 : 0.0, "nexus_fp_available", display = display.none, editable = false)
plot(fpBarDelta, "nexus_fp_bar_delta", display = display.none, editable = false)
plot(fpTotalVolume, "nexus_fp_total_volume", display = display.none, editable = false)
plot(normCumDelta, "nexus_norm_cum_delta", display = display.none, editable = false)
plot(deltaSlope, "nexus_delta_slope", display = display.none, editable = false)
plot(barDeltaRatio, "nexus_bar_delta_ratio", display = display.none, editable = false)
plot(float(deltaDir), "nexus_delta_dir", display = display.none, editable = false)
plot(gasOutBull ? 1.0 : 0.0, "nexus_gasout_bull", display = display.none, editable = false)
plot(gasOutBear ? 1.0 : 0.0, "nexus_gasout_bear", display = display.none, editable = false)
plot(modeInput == "5m" ? 5.0 : modeInput == "15m" ? 15.0 : modeInput == "1H" ? 60.0 : 240.0, "nexus_mode_minutes", display = display.none, editable = false)
plot(bullReversalSignal ? 1.0 : bearReversalSignal ? -1.0 : lowConvictionSignal ? 0.5 : 0.0, "nexus_signal_tier", display = display.none, editable = false)

// ══════════════════════════════════════════════════════════
// DASHBOARD
// ══════════════════════════════════════════════════════════
bool wCrossUp   = crossUp and isWarmedUp
bool wCrossDown = crossDown and isWarmedUp

string trendStr    = oscVal > 60.0 ? "Bullish" : oscVal < 40.0 ? "Bearish" : "Neutral"
color  trendCol    = oscVal > 60.0 ? BULL_TEXT : oscVal < 40.0 ? BEAR_TEXT : NEUTRAL_TEXT
string signalStr   = wCrossUp ? "Bull Cross" : wCrossDown ? "Bear Cross" : oscVal >= effOB ? "Overbought" : oscVal <= effOS ? "Oversold" : "—"
color  signalCol   = wCrossUp ? BULL_TEXT : wCrossDown ? BEAR_TEXT : oscVal >= effOB ? BULL_TEXT : oscVal <= effOS ? BEAR_TEXT : TEXT_COLOR
string strengthStr = oscVal >= 70.0 or oscVal <= 30.0 ? "Strong" : oscVal >= 60.0 or oscVal <= 40.0 ? "Medium" : "Weak"
color  strengthCol = oscVal >= 70.0 or oscVal <= 30.0 ? BULL_TEXT : oscVal >= 60.0 or oscVal <= 40.0 ? NEUTRAL_TEXT : TEXT_MUTED
string vfStr       = not volumeAvailable ? "N/A" : vfCalcVal > vfSignalThresholdInput ? "Inflow" : vfCalcVal < vfSignalBearThreshold ? "Outflow" : "Neutral"
color  vfCol       = not volumeAvailable ? TEXT_MUTED : vfCalcVal > vfSignalThresholdInput ? BULL_TEXT : vfCalcVal < vfSignalBearThreshold ? BEAR_TEXT : NEUTRAL_TEXT
string regimeStr   = erTrending ? "Trending" : "Ranging"
color  regimeCol   = erTrending ? BULL_TEXT : NEUTRAL_TEXT
string knnStr      = knnIsBull ? "Bullish" : knnIsBear ? "Bearish" : "Neutral"
string tfModeStr   = modeInput + " Native"
color  tfModeCol   = TEXT_MUTED

// ══════════════════════════════════════════════════════════
// WATERMARK — WillyAlgoTrader
// ══════════════════════════════════════════════════════════
if barstate.islast and showWatermarkInput
    var wmTable = table.new(position = position.bottom_center, columns = 2, rows = 1, bgcolor = color.new(color.black, 100), border_color = color.new(color.black, 100), border_width = 0, frame_color = color.new(color.black, 100), frame_width = 0)
    table.cell(wmTable, 0, 0, "WARBIRD", text_color = WM_COLOR, text_size = size.large, text_halign = text.align_right, bgcolor = color.new(color.black, 100), text_formatting = text.format_bold)
    table.cell(wmTable, 1, 0, "PRO", text_color = color.new(WARBIRD_BEAR, 35), text_size = size.large, text_halign = text.align_left, bgcolor = color.new(color.black, 100))

// ══════════════════════════════════════════════════════════
// ALERTS
// ══════════════════════════════════════════════════════════
string symbolLabel = syminfo.ticker
string symbolJson  = syminfo.prefix + ":" + syminfo.ticker
string tf          = timeframe.isintraday ? timeframe.period + "m" : timeframe.period
string priceStr    = str.tostring(close, format.mintick)
string oscStr      = str.tostring(oscVal, "#.#")
string sigStr      = str.tostring(sigVal, "#.#")
string vfValueStr  = volumeAvailable ? str.tostring(vfCalcVal, "#.#") : "N/A"
string vfJsonStr   = volumeAvailable ? str.tostring(vfCalcVal, "#.#") : "null"
string vfAvailJson = volumeAvailable ? "true" : "false"
string confValStr  = str.tostring(confVal, "#.#")
string knnConfStr  = str.tostring(knnConf)
string tfModeAlertStr = modeInput + " Native"
bool alertReady    = barstate.isconfirmed and isWarmedUp

bool aCrossUp   = ta.crossover(oscVal, sigVal) and alertReady
bool aCrossDown = ta.crossunder(oscVal, sigVal) and alertReady
bool aExitOs    = ta.crossover(oscVal, effOS) and alertReady
bool aExitOb    = ta.crossunder(oscVal, effOB) and alertReady
bool aVfIn      = volumeAvailable and ta.crossover(vfCalcVal, vfSignalThresholdInput) and alertReady
bool aVfOut     = volumeAvailable and ta.crossunder(vfCalcVal, vfSignalBearThreshold) and alertReady

bool tradeTriggerBull = alCrossInput and bullReversalSignal
bool tradeTriggerBear = alCrossInput and bearReversalSignal
bool exhaustionBull   = alZoneInput and aExitOs
bool exhaustionBear   = alZoneInput and aExitOb
bool knnAlertBull     = alKnnInput and knnFlipBull and alertReady
bool knnAlertBear     = alKnnInput and knnFlipBear and alertReady
bool fatigueAlertOb   = alFatigueInput and fatObSignal and alertReady
bool fatigueAlertOs   = alFatigueInput and fatOsSignal and alertReady
bool gasOutAlertBull  = alFatigueInput and showGasOutInput and gasOutBull and alertReady
bool gasOutAlertBear  = alFatigueInput and showGasOutInput and gasOutBear and alertReady

alertcondition(tradeTriggerBull, "NFE Bull Trigger", "NFE Bull Trigger | {{ticker}} | {{interval}} | Close {{close}}")
alertcondition(tradeTriggerBear, "NFE Bear Trigger", "NFE Bear Trigger | {{ticker}} | {{interval}} | Close {{close}}")
alertcondition(exhaustionBull, "NFE Exit Oversold", "NFE Exit Oversold | {{ticker}} | {{interval}} | Close {{close}}")
alertcondition(exhaustionBear, "NFE Exit Overbought", "NFE Exit Overbought | {{ticker}} | {{interval}} | Close {{close}}")
alertcondition(knnAlertBull, "NFE KNN Bull Flip", "NFE KNN Bull Flip | {{ticker}} | {{interval}} | Close {{close}}")
alertcondition(knnAlertBear, "NFE KNN Bear Flip", "NFE KNN Bear Flip | {{ticker}} | {{interval}} | Close {{close}}")
alertcondition(fatigueAlertOb, "NFE OB Fatigue", "NFE OB Fatigue | {{ticker}} | {{interval}} | Close {{close}}")
alertcondition(fatigueAlertOs, "NFE OS Fatigue", "NFE OS Fatigue | {{ticker}} | {{interval}} | Close {{close}}")
alertcondition(gasOutAlertBull, "NFE Delta Gas-Out Bull", "NFE Delta Gas-Out Bull | {{ticker}} | {{interval}} | Close {{close}}")
alertcondition(gasOutAlertBear, "NFE Delta Gas-Out Bear", "NFE Delta Gas-Out Bear | {{ticker}} | {{interval}} | Close {{close}}")

if tradeTriggerBull
    string jsonMsg = '{"signal":"bull_cross","ticker":"' + symbolJson + '","tf":"' + tf + '","price":' + priceStr + ',"osc":' + oscStr + ',"sig":' + sigStr + ',"vf":' + vfJsonStr + ',"vf_available":' + vfAvailJson + ',"conf":' + confValStr + ',"knn_conf":' + knnConfStr + '}'
    string textMsg = "NFE Bull Trigger | " + symbolLabel + " " + tf + " | Osc " + oscStr + " > Sig " + sigStr + " | Conf " + confValStr + " | KNN " + knnConfStr + "%"
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)

if tradeTriggerBear
    string jsonMsg = '{"signal":"bear_cross","ticker":"' + symbolJson + '","tf":"' + tf + '","price":' + priceStr + ',"osc":' + oscStr + ',"sig":' + sigStr + ',"vf":' + vfJsonStr + ',"vf_available":' + vfAvailJson + ',"conf":' + confValStr + ',"knn_conf":' + knnConfStr + '}'
    string textMsg = "NFE Bear Trigger | " + symbolLabel + " " + tf + " | Osc " + oscStr + " < Sig " + sigStr + " | Conf " + confValStr + " | KNN " + knnConfStr + "%"
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)

if exhaustionBull
    string jsonMsg = '{"signal":"exit_oversold","ticker":"' + symbolJson + '","tf":"' + tf + '","price":' + priceStr + ',"osc":' + oscStr + ',"vf":' + vfJsonStr + ',"vf_available":' + vfAvailJson + ',"conf":' + confValStr + '}'
    string textMsg = "NFE Exit Oversold | " + symbolLabel + " " + tf + " | Osc " + oscStr + " | VF " + vfValueStr + " | " + tfModeAlertStr
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)

if exhaustionBear
    string jsonMsg = '{"signal":"exit_overbought","ticker":"' + symbolJson + '","tf":"' + tf + '","price":' + priceStr + ',"osc":' + oscStr + ',"vf":' + vfJsonStr + ',"vf_available":' + vfAvailJson + ',"conf":' + confValStr + '}'
    string textMsg = "NFE Exit Overbought | " + symbolLabel + " " + tf + " | Osc " + oscStr + " | VF " + vfValueStr + " | " + tfModeAlertStr
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)

if alDivRegAlertInput and dRegBull and sfPassBull and alertReady
    string jsonMsg = '{"signal":"regular_bull_div","ticker":"' + symbolJson + '","tf":"' + tf + '","price":' + priceStr + ',"osc":' + oscStr + ',"vf":' + vfJsonStr + ',"vf_available":' + vfAvailJson + '}'
    string textMsg = "NFE Regular Bull Div | " + symbolLabel + " " + tf + " | Osc " + oscStr + " | VF " + vfValueStr
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)

if alDivRegAlertInput and dRegBear and sfPassBear and alertReady
    string jsonMsg = '{"signal":"regular_bear_div","ticker":"' + symbolJson + '","tf":"' + tf + '","price":' + priceStr + ',"osc":' + oscStr + ',"vf":' + vfJsonStr + ',"vf_available":' + vfAvailJson + '}'
    string textMsg = "NFE Regular Bear Div | " + symbolLabel + " " + tf + " | Osc " + oscStr + " | VF " + vfValueStr
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)

if alDivHidAlertInput and dHidBull and sfPassBull and alertReady
    string jsonMsg = '{"signal":"hidden_bull_div","ticker":"' + symbolJson + '","tf":"' + tf + '","price":' + priceStr + ',"osc":' + oscStr + ',"vf":' + vfJsonStr + ',"vf_available":' + vfAvailJson + '}'
    string textMsg = "NFE Hidden Bull Div | " + symbolLabel + " " + tf + " | Osc " + oscStr + " | VF " + vfValueStr
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)

if alDivHidAlertInput and dHidBear and sfPassBear and alertReady
    string jsonMsg = '{"signal":"hidden_bear_div","ticker":"' + symbolJson + '","tf":"' + tf + '","price":' + priceStr + ',"osc":' + oscStr + ',"vf":' + vfJsonStr + ',"vf_available":' + vfAvailJson + '}'
    string textMsg = "NFE Hidden Bear Div | " + symbolLabel + " " + tf + " | Osc " + oscStr + " | VF " + vfValueStr
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)

if alVolFlowInput and aVfIn
    string jsonMsg = '{"signal":"volume_inflow","ticker":"' + symbolJson + '","tf":"' + tf + '","price":' + priceStr + ',"osc":' + oscStr + ',"vf":' + vfJsonStr + ',"conf":' + confValStr + '}'
    string textMsg = "NFE Volume Inflow | " + symbolLabel + " " + tf + " | VF " + vfValueStr + " | Osc " + oscStr
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)

if alVolFlowInput and aVfOut
    string jsonMsg = '{"signal":"volume_outflow","ticker":"' + symbolJson + '","tf":"' + tf + '","price":' + priceStr + ',"osc":' + oscStr + ',"vf":' + vfJsonStr + ',"conf":' + confValStr + '}'
    string textMsg = "NFE Volume Outflow | " + symbolLabel + " " + tf + " | VF " + vfValueStr + " | Osc " + oscStr
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)

if fatigueAlertOb
    string jsonMsg = '{"signal":"ob_fatigue","ticker":"' + symbolJson + '","tf":"' + tf + '","price":' + priceStr + ',"osc":' + oscStr + ',"vf":' + vfJsonStr + ',"vf_available":' + vfAvailJson + ',"conf":' + confValStr + ',"bars":' + str.tostring(fatigueBarsInput) + '}'
    string textMsg = "NFE OB Fatigue | " + symbolLabel + " " + tf + " | Osc " + oscStr + " | " + str.tostring(fatigueBarsInput) + " bars weakening | Conf " + confValStr
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)

if fatigueAlertOs
    string jsonMsg = '{"signal":"os_fatigue","ticker":"' + symbolJson + '","tf":"' + tf + '","price":' + priceStr + ',"osc":' + oscStr + ',"vf":' + vfJsonStr + ',"vf_available":' + vfAvailJson + ',"conf":' + confValStr + ',"bars":' + str.tostring(fatigueBarsInput) + '}'
    string textMsg = "NFE OS Fatigue | " + symbolLabel + " " + tf + " | Osc " + oscStr + " | " + str.tostring(fatigueBarsInput) + " bars strengthening | Conf " + confValStr
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)

if gasOutAlertBull
    string jsonMsg = '{"signal":"delta_gasout_bull","ticker":"' + symbolJson + '","tf":"' + tf + '","price":' + priceStr + ',"osc":' + oscStr + ',"delta_slope":' + str.tostring(deltaSlope, "#.####") + ',"vf_available":' + vfAvailJson + '}'
    string textMsg = "NFE Delta Gas-Out Bull | " + symbolLabel + " " + tf + " | Osc " + oscStr + " | DeltaSlope " + str.tostring(deltaSlope, "#.####")
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)

if gasOutAlertBear
    string jsonMsg = '{"signal":"delta_gasout_bear","ticker":"' + symbolJson + '","tf":"' + tf + '","price":' + priceStr + ',"osc":' + oscStr + ',"delta_slope":' + str.tostring(deltaSlope, "#.####") + ',"vf_available":' + vfAvailJson + '}'
    string textMsg = "NFE Delta Gas-Out Bear | " + symbolLabel + " " + tf + " | Osc " + oscStr + " | DeltaSlope " + str.tostring(deltaSlope, "#.####")
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)

if knnAlertBull
    string jsonMsg = '{"signal":"knn_bull_flip","ticker":"' + symbolJson + '","tf":"' + tf + '","price":' + priceStr + ',"osc":' + oscStr + ',"vf":' + vfJsonStr + ',"vf_available":' + vfAvailJson + ',"conf":' + confValStr + ',"knn_conf":' + knnConfStr + '}'
    string textMsg = "NFE KNN Bull Flip | " + symbolLabel + " " + tf + " | Confidence " + knnConfStr + "% | Osc " + oscStr + " | Conf " + confValStr
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)

if knnAlertBear
    string jsonMsg = '{"signal":"knn_bear_flip","ticker":"' + symbolJson + '","tf":"' + tf + '","price":' + priceStr + ',"osc":' + oscStr + ',"vf":' + vfJsonStr + ',"vf_available":' + vfAvailJson + ',"conf":' + confValStr + ',"knn_conf":' + knnConfStr + '}'
    string textMsg = "NFE KNN Bear Flip | " + symbolLabel + " " + tf + " | Confidence " + knnConfStr + "% | Osc " + oscStr + " | Conf " + confValStr
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)

if alConfInput and confHighCross and alertReady
    string jsonMsg = '{"signal":"confluence_high","ticker":"' + symbolJson + '","tf":"' + tf + '","price":' + priceStr + ',"osc":' + oscStr + ',"vf":' + vfJsonStr + ',"vf_available":' + vfAvailJson + ',"conf":' + confValStr + ',"knn_conf":' + knnConfStr + '}'
    string textMsg = "NFE Confluence High | " + symbolLabel + " " + tf + " | Score " + confValStr + " | Bullish alignment"
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)

if alConfInput and confLowCross and alertReady
    string jsonMsg = '{"signal":"confluence_low","ticker":"' + symbolJson + '","tf":"' + tf + '","price":' + priceStr + ',"osc":' + oscStr + ',"vf":' + vfJsonStr + ',"vf_available":' + vfAvailJson + ',"conf":' + confValStr + ',"knn_conf":' + knnConfStr + '}'
    string textMsg = "NFE Confluence Low | " + symbolLabel + " " + tf + " | Score " + confValStr + " | Bearish alignment"
    alert(webhookInput ? jsonMsg : textMsg, alert.freq_once_per_bar_close)
