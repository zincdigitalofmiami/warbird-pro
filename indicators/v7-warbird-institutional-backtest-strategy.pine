// Warbird Pro Optuna — MES Fib Structure + AG Contract Surface
// Base: v6-warbird-complete.pine (2026-03-26)
// Upgrade: v6 migration + 5 target extensions + AG hidden export surface
// Date: 2026-04-13
//
// NO-REPAINT AUDIT:
// - All structure conditions gated by barstate.isconfirmed — signals fire at bar close only
// - request.security(): lookahead_off on all calls
// - Structure conditions: close-based, bar-close semantics
// - Last verified: 2026-03-30
//
// VWAP CODE: +2=reclaim, +1=above, 0=in-band, -1=below, -2=reject. Band=5% ATR around VWAP.
//
// REQUEST BUDGET:
// HTF fib (1H):        [high, low] tuple                 = 1 call
// HTF fib (4H):        [high, low] tuple                 = 1 call
// HTF fib (1D):        [high, low] tuple                 = 1 call
// Parent fib override: request.security(fibAnchorTimeframe) = 1 conditional call (default OFF; 5m native)
// NYSE A-D Line (D):   close                             = 1 call
// Footprint (chart):    request.footprint()              = 1 call
// TOTAL:                                                 = 6 request.* paths
//
// PLOT BUDGET: 53 plot = 53/64 (11 headroom); label.new slots are outside 64-slot counter
// TA Core Pack exports (7 plots) are AG server-side computable — cut candidates if slots needed.
// Momentum Oscillators (5 plots: ml_vf_bull, ml_vf_bear, ml_nfe, ml_rsi_knn, ml_confluence) added 2026-04-20.
strategy("Warbird Pro Optuna Backtest", shorttitle="WB Opt BT", overlay=true, max_lines_count=200, max_labels_count=200, max_boxes_count=100, pyramiding=0, process_orders_on_close=false, use_bar_magnifier=true, fill_orders_on_standard_ohlc=true, slippage=1, default_qty_type=strategy.fixed, default_qty_value=1, initial_capital=50000, currency=currency.USD, margin_long=25, margin_short=25, commission_type=strategy.commission.cash_per_contract, commission_value=1.00)

const int DRAW_HISTORY_BARS = 5000
const int TF_SECONDS_15M = 900
const int TF_SECONDS_1H = 3600
const int TF_SECONDS_4H = 14400
const int FIB_SCANNER_MIN_RIGHT_ROOM_BARS = 1
const int FIB_SCANNER_MIN_LOOKBACK_BARS = 5
const int FIB_SCANNER_ATR_LEN = 10
max_bars_back(time, DRAW_HISTORY_BARS)

//=====================
// FIBONACCI ENGINE SETTINGS
//=====================
string groupFibEngine = "Fibonacci Engine"
bool autoTuneZZ = input.bool(true, "Auto-tune ZigZag by Timeframe", group=groupFibEngine,
  tooltip="ON: 4H+ uses Deviation=4, 1H uses Deviation=3.5, 15m uses Deviation=4, below 15m uses Deviation=3. Turn OFF to set value manually.")
float fibDeviationManual = input.float(4.0, "ZigZag Deviation (manual)",
  minval=0.5, maxval=20.0, step=0.5, group=groupFibEngine,
  tooltip="Only used when Auto-tune is OFF.")
float fibConfluenceTolPct = input.float(0.05, "Confluence Tolerance (%)", minval=0.01, maxval=2.00, step=0.01, group=groupFibEngine)
float fibThresholdFloorPct = input.float(0.50, "ZigZag Threshold Floor (%)", minval=0.0, maxval=5.0, step=0.05, group=groupFibEngine,
  tooltip="Minimum percent move required by the ZigZag after ATR scaling.")
int fibPivotRightRoomBars = input.int(4, "Pivot Right Room (bars)", minval=1, maxval=20, group=groupFibEngine,
  tooltip="Bars after a candidate pivot before the fib leg may re-anchor. This keeps anchors off the latest bar while allowing the most recent confirmed major leg.")
int fibRecentLegLookbackBars = input.int(20, "Recent Leg Lookback (bars)", minval=5, maxval=120, group=groupFibEngine,
  tooltip="Bars scanned for the active major move after excluding Pivot Right Room. This control is applied on all timeframes.")
float minFibRangeAtr = input.float(0.5, "Min Fib Range (ATR)", minval=0.5, maxval=10.0, step=0.1, group=groupFibEngine)
bool useParentFibTimeframe = input.bool(false, "Use Parent Fib Timeframe", group=groupFibEngine,
  tooltip="OFF keeps fib ownership on the chart timeframe. ON uses Parent Fib Timeframe ownership (equal or higher timeframe; lower timeframe selections are ignored).")
string fibAnchorTimeframe = input.timeframe("5", "Parent Fib Timeframe", group=groupFibEngine,
  tooltip="Fib owner when Use Parent Fib Timeframe is ON. Equal timeframe applies scanner logic natively; higher timeframe projects parent ladders.")

int _chartTfSec = timeframe.in_seconds(timeframe.period)
int _parentTfSec = timeframe.in_seconds(fibAnchorTimeframe)
bool parentFibTfUsable = _parentTfSec > 0 and _parentTfSec >= _chartTfSec
bool useParentFibTimeframeActive = useParentFibTimeframe and parentFibTfUsable
string fibCalcTimeframe = useParentFibTimeframeActive ? fibAnchorTimeframe : timeframe.period
bool useFibAnchorTimeframeOverride = fibCalcTimeframe != timeframe.period
int _tfSec = timeframe.in_seconds(fibCalcTimeframe)
float fibDeviation = autoTuneZZ
  ? (_tfSec >= TF_SECONDS_4H ? 4.0 : _tfSec >= TF_SECONDS_1H ? 3.5 : _tfSec >= TF_SECONDS_15M ? 4.0 : 3.0)
  : fibDeviationManual

barsForMinutes(float minutes, int fallbackBars) =>
    _chartTfSec > 0 ? int(math.max(1.0, math.round(minutes * 60.0 / _chartTfSec))) : fallbackBars

