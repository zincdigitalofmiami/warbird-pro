// ── AG LABEL SURFACE ──
// ml_last_exit_outcome: 0=none, 1=TP1_HIT, 2=TP2_HIT, 3=STOPPED, 4=EXPIRED, 5=TP3_HIT, 6=TP4_HIT, 7=TP5_HIT
