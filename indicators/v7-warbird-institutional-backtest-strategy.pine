int nfeLenInput        = input.int(14, "NFE Length", minval=5, maxval=100, group=groupMomentum)
int rsiKnnWindow       = input.int(20, "RSI KNN Window", minval=5, maxval=100, group=groupMomentum)

f_line_style(string styleName) =>
    styleName == "Dashed" ? line.style_dashed : styleName == "Dotted" ? line.style_dotted : line.style_solid

f_label_size(string sizeName) =>
    sizeName == "Tiny" ? size.tiny : sizeName == "Normal" ? size.normal : sizeName == "Large" ? size.large : size.small

//=====================
// REGIME DETECTION (from session-checkpoint research: ADX/ER/VIX-vol)
// These are computed values for sidebar + AG features, NOT chart markers
//=====================

// --- ADX(14) + signed DI spread + ADX slope ---
int adxLen = 14
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)

// --- VIX/VVIX intermarket path removed from active Pine runtime ---

// --- ATR percentage (normalized volatility) ---
float atrRaw = ta.atr(20)

//=====================
// TA CORE PACK (15-metric feature set for ML training capture)
// Deterministic, point-in-time safe, no lookahead, no external dependencies.
//=====================
float ema9 = ta.ema(close, 9)
float ema21 = ta.ema(close, 21)
float ema50 = ta.ema(close, 50)
float ema200 = ta.ema(close, 200)
float ema100 = ta.ema(close, 100)
[_macdFast, _macdSlow, macdHist] = ta.macd(close, 12, 26, 9)
float rsi14 = ta.rsi(close, 14)
float atr14 = ta.atr(14)

//=====================
// OPENING RANGE (first 30 min of RTH: 8:30-9:00 CT)
// State: 1 = above OR, -1 = below OR, 0 = inside OR
// Distance: (close - OR midpoint) / ATR — normalized
//=====================
bool isRTHOpen = (hour == 8 and minute >= 30) or (hour == 9 and minute == 0)
var float orHigh = na
var float orLow = na
var bool orLocked = false

if hour == 8 and minute == 30 and (hour[1] != 8 or minute[1] != 30)
    orHigh := high
    orLow := low
    orLocked := false

if isRTHOpen and not orLocked
    orHigh := math.max(nz(orHigh, high), high)
    orLow := math.min(nz(orLow, low), low)

if hour == 9 and minute > 0 and not orLocked
    orLocked := true

int orState = orLocked ? (close > orHigh ? 1 : close < orLow ? -1 : 0) : 0
float orMid = orLocked ? (orHigh + orLow) / 2.0 : na
float orDistNorm = (orLocked and not na(orMid) and atr14 > 0) ? (close - orMid) / atr14 : 0.0

//=====================
// ECONOMIC EVENT DAY PROXY (NFP / FOMC / CPI approximation)
// NFP:  first Friday of month (dayofmonth <= 7)
// FOMC: 8x/year, always a Wednesday — approximate 2nd or 3rd Wed of month (dayofmonth 8-21)
// CPI:  usually 2nd Tuesday of month (dayofmonth 8-14)
// Zero security calls. Correctly identifies ~80% of high-impact macro days.
// For exact dates, join FRED economic calendar server-side in the AG pipeline.
// Data floor: 2018-01-01. Pre-2018 data excluded from AG training (regime mismatch).
//=====================
bool isNFPDay   = dayofweek == dayofweek.friday    and dayofmonth <= 7
bool isFOMCDay  = dayofweek == dayofweek.wednesday and dayofmonth >= 8 and dayofmonth <= 21
bool isCPIDay   = dayofweek == dayofweek.tuesday   and dayofmonth >= 8 and dayofmonth <= 14
bool isEventDay = isNFPDay or isFOMCDay or isCPIDay

//=====================
// LIQUIDITY SWEEP DETECTION (ICT methodology)
// Bull sweep: price wicks below prior swing low, closes back above — stop hunt below
// Bear sweep: price wicks above prior swing high, closes back below — stop hunt above
//=====================
int swingLookback = liqSweepLookbackBarsInput
float swingHigh = ta.highest(high, swingLookback)[1]
float swingLow = ta.lowest(low, swingLookback)[1]
bool liqSweepBull = low < swingLow and close > swingLow   // swept below, closed back inside
bool liqSweepBear = high > swingHigh and close < swingHigh // swept above, closed back inside

//=====================
// FAIR VALUE GAP (FVG) — ICT methodology
// Bull FVG: candle[2].high < candle[0].low (gap up, unfilled demand zone)
// Bear FVG: candle[2].low > candle[0].high (gap down, unfilled supply zone)
// Distance: ATR-normalized distance from current close to nearest FVG midpoint
//=====================
bool fvgBull = high[2] < low    // gap between bar 2 high and current bar low
bool fvgBear = low[2] > high    // gap between bar 2 low and current bar high

// Track nearest active FVG midpoint
var float nearestFvgBullMid = na
var float nearestFvgBearMid = na
if fvgBull
    nearestFvgBullMid := (high[2] + low) / 2.0
if fvgBear
    nearestFvgBearMid := (low[2] + high) / 2.0

// Invalidate filled FVGs
if not na(nearestFvgBullMid) and low < nearestFvgBullMid
    nearestFvgBullMid := na
if not na(nearestFvgBearMid) and high > nearestFvgBearMid
    nearestFvgBearMid := na

// ATR-normalized distance to nearest FVG
float fvgBullDist = (not na(nearestFvgBullMid) and atr14 > 0) ? (close - nearestFvgBullMid) / atr14 : 0.0
float fvgBearDist = (not na(nearestFvgBearMid) and atr14 > 0) ? (nearestFvgBearMid - close) / atr14 : 0.0

//=====================
// HTF FIB CONFLUENCE (1H, 4H, Daily)
//=====================
float htfConfTolPct = 0.15

[htf1hHigh, htf1hLow] = request.security(syminfo.tickerid, "60", [ta.highest(high, 55), ta.lowest(low, 55)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
[htf4hHigh, htf4hLow] = request.security(syminfo.tickerid, "240", [ta.highest(high, 55), ta.lowest(low, 55)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
[htf1dHigh, htf1dLow] = request.security(syminfo.tickerid, "D", [ta.highest(high, 55), ta.lowest(low, 55)], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

float htf1hRange = nz(htf1hHigh - htf1hLow)
float htf4hRange = nz(htf4hHigh - htf4hLow)
float htf1dRange = nz(htf1dHigh - htf1dLow)

htfFibPrice(float htfHigh, float htfLow, float htfRng, float ratio) =>
    htfRng <= 0 ? na : htfLow + htfRng * ratio

float htf1hP382 = htfFibPrice(htf1hHigh, htf1hLow, htf1hRange, FIB_382)
float htf1hP500 = htfFibPrice(htf1hHigh, htf1hLow, htf1hRange, FIB_PIVOT)
float htf1hP618 = htfFibPrice(htf1hHigh, htf1hLow, htf1hRange, FIB_618)

float htf4hP382 = htfFibPrice(htf4hHigh, htf4hLow, htf4hRange, FIB_382)
float htf4hP500 = htfFibPrice(htf4hHigh, htf4hLow, htf4hRange, FIB_PIVOT)
float htf4hP618 = htfFibPrice(htf4hHigh, htf4hLow, htf4hRange, FIB_618)

float htf1dP382 = htfFibPrice(htf1dHigh, htf1dLow, htf1dRange, FIB_382)
float htf1dP500 = htfFibPrice(htf1dHigh, htf1dLow, htf1dRange, FIB_PIVOT)
float htf1dP618 = htfFibPrice(htf1dHigh, htf1dLow, htf1dRange, FIB_618)

htfConfluenceCheck(float level15m, float currentFibRange) =>
    if na(level15m) or na(currentFibRange) or currentFibRange <= 0
        0
    else
        float tol = currentFibRange * htfConfTolPct * 0.01
        int hits = 0
        if not na(htf1hP382) and math.abs(level15m - htf1hP382) <= tol
            hits += 1
        if not na(htf1hP500) and math.abs(level15m - htf1hP500) <= tol
            hits += 1
        if not na(htf1hP618) and math.abs(level15m - htf1hP618) <= tol
            hits += 1
        if not na(htf4hP382) and math.abs(level15m - htf4hP382) <= tol
            hits += 1
        if not na(htf4hP500) and math.abs(level15m - htf4hP500) <= tol
            hits += 1
        if not na(htf4hP618) and math.abs(level15m - htf4hP618) <= tol
            hits += 1
        if not na(htf1dP382) and math.abs(level15m - htf1dP382) <= tol
            hits += 1
        if not na(htf1dP500) and math.abs(level15m - htf1dP500) <= tol
            hits += 1
        if not na(htf1dP618) and math.abs(level15m - htf1dP618) <= tol
            hits += 1
        hits

// NOTE: htfConfluenceCheck() is called AFTER fib prices are computed (below the AUTO FIB ENGINE)

//=====================
// AUTO FIB ENGINE — ZigZag confirmed pivots (non-repainting)
//=====================
fibHtfSnapshot(float deviationPct, int lookbackBars, int rightRoomBars, float thresholdFloorPct) =>
    int legRightBars = math.max(FIB_SCANNER_MIN_RIGHT_ROOM_BARS, rightRoomBars)
    int legLookbackBars = math.max(FIB_SCANNER_MIN_LOOKBACK_BARS, lookbackBars)
    float shiftedHigh = high[legRightBars]
    float shiftedLow = low[legRightBars]
    float recentHigh = ta.highest(shiftedHigh, legLookbackBars)
    float recentLow = ta.lowest(shiftedLow, legLookbackBars)
    int recentHighOffset = ta.highestbars(shiftedHigh, legLookbackBars)
    int recentLowOffset = ta.lowestbars(shiftedLow, legLookbackBars)
    var float legHigh = na
    var float legLow = na
    var int legHighTime = na
    var int legLowTime = na
    var int legDir = 0
    bool newPivot = false
    if not na(recentHigh) and not na(recentLow) and recentHigh > recentLow and not na(recentHighOffset) and not na(recentLowOffset)
        int highBarsBack = legRightBars - recentHighOffset
        int lowBarsBack = legRightBars - recentLowOffset
        int candidateHighTime = time[highBarsBack]
        int candidateLowTime = time[lowBarsBack]
        float candidateRange = recentHigh - recentLow
        float refPrice = math.max(math.abs(recentLow), syminfo.mintick)
        float movePct = candidateRange / refPrice * 100.0
        float candidateClose = close[legRightBars]
        float candidateAtr = ta.atr(FIB_SCANNER_ATR_LEN)[legRightBars]
        float dynThreshold = not na(candidateAtr) and candidateClose != 0 ? math.max(candidateAtr / candidateClose * 100.0 * deviationPct, thresholdFloorPct) : thresholdFloorPct
        if movePct >= dynThreshold
            int candidateDir = candidateHighTime > candidateLowTime ? 1 : candidateLowTime > candidateHighTime ? -1 : 0
            bool changedLeg = na(legHighTime) or na(legLowTime) or candidateHighTime != legHighTime or candidateLowTime != legLowTime or recentHigh != legHigh or recentLow != legLow
            if changedLeg
                legHigh := recentHigh
                legLow := recentLow
                legHighTime := candidateHighTime
                legLowTime := candidateLowTime
                legDir := candidateDir
                newPivot := true
    [newPivot, legHigh, legLow, legHighTime, legLowTime, legDir]

fibZzSource() =>
    if useFibAnchorTimeframeOverride
        request.security(syminfo.tickerid, fibCalcTimeframe, fibHtfSnapshot(fibDeviation, fibRecentLegLookbackBars, fibPivotRightRoomBars, fibThresholdFloorPct), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
    else
        fibHtfSnapshot(fibDeviation, fibRecentLegLookbackBars, fibPivotRightRoomBars, fibThresholdFloorPct)

[zzNewPivot, zzHighPrice, zzLowPrice, zzHighTime, zzLowTime, zzSwingDir] = fibZzSource()

var float fibAnchorHigh = na
var float fibAnchorLow = na
var int anchorHighTime = na
var int anchorLowTime = na
var int lastBreakBar = na
bool htfSnapshotReady = not na(zzHighPrice) and not na(zzLowPrice) and not na(zzHighTime) and not na(zzLowTime) and zzHighPrice > zzLowPrice and zzHighTime != zzLowTime
bool anchorSnapshotChanged = useFibAnchorTimeframeOverride
  ? htfSnapshotReady and ((na(anchorHighTime) or zzHighTime != anchorHighTime) or (na(anchorLowTime) or zzLowTime != anchorLowTime))
  : zzNewPivot

if anchorSnapshotChanged
    fibAnchorHigh := zzHighPrice
    fibAnchorLow  := zzLowPrice
    anchorHighTime := zzHighTime
    anchorLowTime  := zzLowTime
    lastBreakBar  := na

anchorBarFromTime(int anchorTime) =>
    if na(anchorTime) or _chartTfSec <= 0
        int(na)
    else
        float elapsedBars = float(time - anchorTime) / (float(_chartTfSec) * 1000.0)
        int barsAgo = int(math.min(float(DRAW_HISTORY_BARS), math.max(0.0, math.round(elapsedBars))))
        int(math.max(0, bar_index - barsAgo))

int anchorHighBar = anchorBarFromTime(anchorHighTime)
int anchorLowBar = anchorBarFromTime(anchorLowTime)

// Pre-compute rolling high/low at each confluence period at global scope.
// ta.highest/ta.lowest require a compile-time-constant length — they cannot
// be called inside a loop with a variable length argument.
float _cqH8  = ta.highest(high, 8)
float _cqL8  = ta.lowest(low,  8)
float _cqH13 = ta.highest(high, 13)
float _cqL13 = ta.lowest(low,  13)
float _cqH21 = ta.highest(high, 21)
float _cqL21 = ta.lowest(low,  21)
float _cqH34 = ta.highest(high, 34)
float _cqL34 = ta.lowest(low,  34)
float _cqH55 = ta.highest(high, 55)
float _cqL55 = ta.lowest(low,  55)

float confluenceQuality = na
if not na(fibAnchorHigh) and not na(fibAnchorLow)
    float anchorRange = fibAnchorHigh - fibAnchorLow
    if anchorRange > 0
        float tol = anchorRange * fibConfluenceTolPct * 0.01
        int confHits = 0
        // Iterate over the five pre-computed period pairs
        array<float> _cqPairs = array.from(_cqH8, _cqL8, _cqH13, _cqL13, _cqH21, _cqL21, _cqH34, _cqL34, _cqH55, _cqL55)
        for pairIdx = 0 to 4
            float rollingH = array.get(_cqPairs, pairIdx * 2)
            float rollingL = array.get(_cqPairs, pairIdx * 2 + 1)
            float rollingRange = rollingH - rollingL
            if rollingRange > 0
                for ratioIdx = 0 to 2
                    float ratio = ratioIdx == 0 ? 0.382 : ratioIdx == 1 ? 0.5 : 0.618
                    float anchorLevel = fibAnchorLow + anchorRange * ratio
                    float rollingLevel = rollingL + rollingRange * ratio
                    if math.abs(anchorLevel - rollingLevel) <= tol
                        confHits += 1
        confluenceQuality := float(confHits) * anchorRange

float fibRange = fibAnchorHigh - fibAnchorLow
float minFibRange = minFibRangeAtr * atr14
bool isValid = not na(fibAnchorHigh) and not na(fibAnchorLow) and fibRange >= minFibRange

float fibMidpoint = fibAnchorLow + fibRange * 0.5
float fibHystBand = fibRange * 0.02

// Price hysteresis keeps the visual ladder responsive without flipping on every
// midpoint tick. This matches the working fib-only Warbird surface.
var bool fibBull = true
if isValid
    if close >= fibMidpoint + fibHystBand
        fibBull := true
    else if close <= fibMidpoint - fibHystBand
        fibBull := false
else
    fibBull := true

float fibBase = fibBull ? fibAnchorLow : fibAnchorHigh
float fibDir = fibBull ? 1.0 : -1.0
fibPrice(float ratio) =>
    fibRange <= 0 ? na : (fibBase + fibDir * fibRange * ratio)

float pZero   = fibPrice(FIB_ZERO)
float pNeg236 = fibPrice(-FIB_236)
float p236    = fibPrice(FIB_236)
float p382    = fibPrice(FIB_382)
float pPivot  = fibPrice(FIB_PIVOT)
float p618    = fibPrice(FIB_618)
float p786    = fibPrice(FIB_786)
float pOne    = fibPrice(FIB_ONE)
float pT1     = fibPrice(FIB_T1)
float p1382   = fibPrice(FIB_W1382)
float p150    = fibPrice(FIB_W150)
float pT2     = fibPrice(FIB_T2)
float p1786   = fibPrice(FIB_W1786)
float pT3     = fibPrice(FIB_T3)
float pT4     = fibPrice(FIB_T4)
float pT5     = fibPrice(FIB_T5)

float entryZoneUpper = math.max(pPivot, p786)
float entryZoneLower = math.min(pPivot, p786)
float zoneUpper = math.max(p618, p786)
float zoneLower = math.min(p618, p786)

float zoneFillUpper = math.max(p382, p618)
float zoneFillLower = math.min(p382, p618)

int htfConfPivot = htfConfluenceCheck(pPivot, fibRange)
int htfConf382   = htfConfluenceCheck(p382, fibRange)
int htfConf618   = htfConfluenceCheck(p618, fibRange)
int htfConfTotal = htfConfPivot + htfConf382 + htfConf618

//=====================
// FOOTPRINT (moved up — all volume decisions use footprint delta, never standard volume)
// Single request.footprint() call, cached per bar.
//=====================
footprint reqFootprint = request.footprint(footprintTicksPerRow, footprintVaPercent, footprintImbalancePercent)
bool fpAvailable = not na(reqFootprint)
float fpDelta = fpAvailable ? footprint.delta(reqFootprint) : na

//=====================
// FOOTPRINT DELTA AT FIB TOUCHES
//=====================
float barRange = high - low
float volDeltaTolPts = 2.0

fibTouchCheck(float level) =>
    not na(level) and math.abs(close - level) <= volDeltaTolPts

bool isTouchingFib = fibTouchCheck(p236) or fibTouchCheck(p382) or fibTouchCheck(pPivot) or fibTouchCheck(p618) or fibTouchCheck(p786) or fibTouchCheck(pT1) or fibTouchCheck(pT2) or fibTouchCheck(pT3) or fibTouchCheck(pT4) or fibTouchCheck(pT5)

// Footprint delta at fib touch: positive = buyers dominant, negative = sellers dominant
float fibTouchVolDelta = isTouchingFib and fpAvailable and not na(fpDelta) ? fpDelta : na

//=====================
// CANDLESTICK PATTERN DETECTION — EMPIRICALLY VALIDATED ON MES 15m
// Source: "Candlestick Patterns on Backtest" indicator, 5+ years of MES data.
// ONLY patterns with positive returns at multiple R:R ratios are included.
// Everything else is a losing trade on MES 15m. No guessing. Data only.
//=====================
float bodySize = math.abs(close - open)
float bodyRatio = barRange > 0 ? bodySize / barRange : 0.0
bool bullishCandle = close > open
bool bearishCandle = close < open
float upperWickSize = high - math.max(open, close)
float lowerWickSize = math.min(open, close) - low
float upperWickRatio = barRange > 0 ? upperWickSize / barRange : 0.0
float lowerWickRatio = barRange > 0 ? lowerWickSize / barRange : 0.0

// ── PROVEN BULLISH PATTERNS ─────────────────────────────────────────────
// Long Lower Shadow (+3.9% at 1:6 R:R — STRONGEST bullish pattern on MES 15m)
// Long lower wick, close in upper portion of bar. Buyers absorbed selling.
bool longLowerShadow = lowerWickRatio >= 0.55 and upperWickRatio <= 0.25

// Dragonfly Doji (+1.2% at 1:6 R:R — consistent winner)
// Open and close near high, long lower wick. Pure buyer rejection of lows.
bool dragonflyDoji = lowerWickRatio >= 0.60 and bodyRatio <= 0.15

// Rising Window / Gap Up (+0.9% at 1:6 — moderate, gap continuation)
bool risingWindow = low > high[1]

// ── PROVEN BEARISH PATTERNS ─────────────────────────────────────────────
// Long Upper Shadow (-7.7% at 1:6 R:R — STRONGEST bearish pattern on MES 15m)
// Long upper wick, close in lower portion. Sellers absorbed buying.
bool longUpperShadow = upperWickRatio >= 0.55 and lowerWickRatio <= 0.25

// Shooting Star (-5.6% at 1:6 R:R — strong)
// Upper wick >= 50% of range, small body, bearish close.
bool shootingStar = upperWickRatio >= 0.50 and bodyRatio <= 0.35 and bearishCandle

// Bearish Engulfing (-6.6% at 1:6 R:R — strong at high R:R)
// Current bearish body fully engulfs prior bullish body.
bool bearishEngulfing = bearishCandle and bullishCandle[1] and close < open[1] and open > close[1]

// Falling Window / Gap Down (-1.5% at 1:6 — moderate)
bool fallingWindow = high < low[1]

// ── PATTERNS PROVEN TO LOSE ON MES 15m (DO NOT USE) ─────────────────────
// Hammer: -1.0% to -2.0% at all R:R. LOSING PATTERN.
// Bullish Engulfing: -1.4% to -5.3%. LOSING PATTERN.
// Inverted Hammer: -1.0% to -3.0%. LOSING PATTERN.
// Doji Star (Bull): -1.2% to -2.3%. LOSING PATTERN.

// ── COMPOSITE SIGNALS ───────────────────────────────────────────────────
bool provenBullishPattern = longLowerShadow or dragonflyDoji or risingWindow
bool provenBearishPattern = longUpperShadow or shootingStar or bearishEngulfing or fallingWindow

//=====================
// FIB LEVEL CONFIRMATION STACK — Footprint + Proven Candlestick Patterns
// No RSI. No generic indicators. Footprint delta + empirically validated patterns only.
//=====================

// Footprint delta confirmation: delta must agree with trade direction
bool fpDeltaConfirmLong  = fpAvailable and not na(fpDelta) and fpDelta > 0
bool fpDeltaConfirmShort = fpAvailable and not na(fpDelta) and fpDelta < 0

// Wick rejection at fib zone: price pierces zone then closes back outside
bool wickRejectBull = not na(zoneLower) and low < zoneLower and close > zoneLower and bullishCandle
bool wickRejectBear = not na(zoneUpper) and high > zoneUpper and close < zoneUpper and bearishCandle

// Combined confirmation: footprint delta + (proven pattern OR wick rejection OR sweep)
bool longConfirmed = (fpDeltaConfirmLong or not fpAvailable) and (
    provenBullishPattern or
    wickRejectBull or
    liqSweepBull)

bool shortConfirmed = (fpDeltaConfirmShort or not fpAvailable) and (
    provenBearishPattern or
    wickRejectBear or
    liqSweepBear)

//=====================
// NYSE BREADTH + EXECUTION CONTEXT
//=====================
f_ema_dir(float emaVal) =>
    close > emaVal and emaVal > nz(emaVal[1], emaVal) ? 1 : close < emaVal and emaVal < nz(emaVal[1], emaVal) ? -1 : 0

f_ema_dist_pct(float emaVal) =>
    emaVal != 0 ? (close - emaVal) / emaVal * 100.0 : 0.0

f_rsi_knn(float src, int window) =>
    float sumW = 0.0
    float sumV = 0.0
    for i = 1 to window
        float d = math.abs(src - src[i])
        float w = 1.0 / (d + 0.001)
        sumW += w
        sumV += src[i] * w
    sumW > 0 ? sumV / sumW : src

// NYSE Advance-Decline issues (daily breadth): leading exhaustion signal for MES
// Rising MES + falling AD = breadth divergence (exhaustion). Falling MES + rising AD = accumulation.
float adLineRaw   = request.security("USI:ADD", "D", close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
float adSlope     = adLineRaw - nz(adLineRaw[3])
float adSlopeSma  = ta.sma(math.abs(adSlope), 20)
float adSlopeNorm = adSlopeSma > 0 ? adSlope / adSlopeSma : 0.0

//=====================
// ES EXECUTION QUALITY (chart-native, zero security calls)
//=====================
float vwapVal = ta.vwap(hlc3)
float vwapBand = atrRaw * 0.05
// VWAP state: +1 above band, -1 below band, 0 inside tolerance
int vwapState = close > vwapVal + vwapBand ? 1 : close < vwapVal - vwapBand ? -1 : 0
int prevVwapSt = nz(vwapState[1], 0)
// VWAP code: +2 reclaim (was below, now above), -2 reject (was above, now below)
// Tolerance band ALWAYS outputs 0. Reclaim/reject only fire when close is clearly outside band.
int vwapCode = vwapState == 0 ? 0 : vwapState == 1 ? (prevVwapSt == -1 ? 2 : 1) : (prevVwapSt == 1 ? -2 : -1)
// barRange already defined in volume delta section (line ~497)
float avgRange5 = ta.sma(barRange, 5)
float rangeExpansion = barRange / math.max(avgRange5, syminfo.mintick)
float rangeExpClamped = math.min(rangeExpansion, 5.0)
float barEfficiency = math.abs(close - open) / math.max(barRange, syminfo.mintick)
float execDir = vwapCode == 2 ? 1.0 : vwapCode == -2 ? -1.0 : vwapCode == 1 ? 0.5 : vwapCode == -1 ? -0.5 : 0.0
float execQual = 0.5 * barEfficiency + 0.5 * math.min(rangeExpClamped / 3.0, 1.0)
float execScore = execDir * (0.5 + 0.5 * execQual)
bool bullishTrendBlocksShorts = gateShortsInBullTrend and (
    adxVal >= shortTrendGateAdx and
    diPlus > diMinus and
    close > ema100 and
    ema100 > nz(ema100[1], ema100) and
    vwapCode >= 0 and
    adSlopeNorm >= 0)

//=====================
// STRUCTURE CONDITIONS (direction-aware)
//=====================
// All signals gated to bar close — no mid-bar firing
bool confirmed = barstate.isconfirmed
int dir = fibBull ? 1 : -1
bool zoneReady = not na(zoneUpper) and not na(zoneLower) and not na(pPivot)
bool breakInDir = zoneReady and confirmed ? (dir == 1 ? (close > zoneUpper and close[1] <= zoneUpper) : (close < zoneLower and close[1] >= zoneLower)) : false
if breakInDir
    lastBreakBar := bar_index
int barsSinceBreak = na(lastBreakBar) ? int(na) : bar_index - lastBreakBar
bool acceptInDir = (
 zoneReady and confirmed and
 not na(barsSinceBreak) and barsSinceBreak > 0 and barsSinceBreak <= retestBars and
    (dir == 1 ? (low <= zoneUpper and close > zoneUpper) : (high >= zoneLower and close < zoneLower))
)
bool rejectAtZone = (
 zoneReady and confirmed and
    (rejectWick ?
        (dir == 1 ? (high >= zoneLower and close < zoneLower) : (low <= zoneUpper and close > zoneUpper)) :
        (dir == 1 ? (close < zoneLower) : (close > zoneUpper)))
)
bool breakAgainst = zoneReady and confirmed ? (dir == 1 ? (close < pPivot and close[1] >= pPivot) : (close > pPivot and close[1] <= pPivot)) : false
bool tagT1 = confirmed and not na(pT1) and (dir == 1 ? high >= pT1 : low <= pT1)
bool tagT2 = confirmed and not na(pT2) and (dir == 1 ? high >= pT2 : low <= pT2)
bool tagT3 = confirmed and not na(pT3) and (dir == 1 ? high >= pT3 : low <= pT3)
bool acceptConfirmed = acceptInDir
bool rejectConfirmed = rejectAtZone
bool breakAgainstConfirmed = breakAgainst
bool acceptEvent = oneShotEvent ? (acceptConfirmed and not acceptConfirmed[1]) : acceptConfirmed
bool rejectEvent = oneShotEvent ? (rejectConfirmed and not rejectConfirmed[1]) : rejectConfirmed
bool breakAgainstEvent = oneShotEvent ? (breakAgainstConfirmed and not breakAgainstConfirmed[1]) : breakAgainstConfirmed
bool tagT1Event = oneShotEvent ? (tagT1 and not tagT1[1]) : tagT1
bool tagT2Event = oneShotEvent ? (tagT2 and not tagT2[1]) : tagT2
bool tagT3Event = oneShotEvent ? (tagT3 and not tagT3[1]) : tagT3
bool tagT4 = confirmed and not na(pT4) and (dir == 1 ? high >= pT4 : low <= pT4)
bool tagT5 = confirmed and not na(pT5) and (dir == 1 ? high >= pT5 : low <= pT5)
bool tagT4Event = oneShotEvent ? (tagT4 and not tagT4[1]) : tagT4
bool tagT5Event = oneShotEvent ? (tagT5 and not tagT5[1]) : tagT5

var bool ladderInvalidated = false
if zzNewPivot
    ladderInvalidated := false
if breakAgainstConfirmed
    ladderInvalidated := true

bool pivotNearZone = isValid and close <= zoneUpper and close >= zoneLower
int eventPivotInteractionCode = breakInDir ? 4 : rejectAtZone ? 3 : acceptInDir ? 1 : breakAgainst ? 2 : pivotNearZone ? 5 : 0

bool setupAcceptContinuation = acceptConfirmed
bool setupZoneRejection = rejectConfirmed
bool setupPivotContinuation = breakInDir
bool setupFailedMoveReversal = breakAgainstConfirmed
bool setupReentryAfterTp1 = tagT1 and acceptInDir
int setupArchetypeCode = setupAcceptContinuation ? 1 : setupZoneRejection ? 2 : setupPivotContinuation ? 3 : setupFailedMoveReversal ? 4 : setupReentryAfterTp1 ? 5 : 0

int fibLevelTouched = 0
if isValid
    float nearest = math.abs(close - p236)
    fibLevelTouched := 236
    float d382 = math.abs(close - p382)
    if d382 < nearest
        nearest := d382
        fibLevelTouched := 382
    float d500 = math.abs(close - pPivot)
    if d500 < nearest
        nearest := d500
        fibLevelTouched := 500
    float d618 = math.abs(close - p618)
    if d618 < nearest
        nearest := d618
        fibLevelTouched := 618
    float d786 = math.abs(close - p786)
    if d786 < nearest
        nearest := d786
        fibLevelTouched := 786
    float d100 = math.abs(close - pOne)
    if d100 < nearest
        fibLevelTouched := 100

//=====================
// EXHAUSTION DIAMOND — Footprint + Proven Candlestick Patterns ONLY
// NO RSI. NO standard volume. NO generic oscillators.
//
// Source: "Candlestick Patterns on Backtest" indicator on MES1! 15m chart +
//         footprint delta/POC/imbalance from request.footprint().
//
// PROVEN BULLISH: Long Lower Shadow (+3.9%), Dragonfly Doji (+1.2%)
// PROVEN BEARISH: Long Upper Shadow (-7.7%), Shooting Star (-5.6%), Bearish Engulfing (-6.6%)
// LOSING patterns EXCLUDED: Hammer, Bullish Engulfing, Inverted Hammer, Doji Star
//=====================

bool mlExhFootprintAvailable = fpAvailable
float footprintRowSize = footprintTicksPerRow * syminfo.mintick
float footprintDelta = fpDelta

// ── FOOTPRINT ANALYSIS ──────────────────────────────────────────────────
volume_row pocRow = fpAvailable ? footprint.poc(reqFootprint) : na
float pocRowVol = not na(pocRow) ? volume_row.total_volume(pocRow) : na

float p1272 = fibPrice(FIB_1272)
float exhaustionTol = atr14 * exhaustionLevelAtrTol
bool exhAt1272 = not na(p1272) and (dir == 1 ? high >= p1272 - exhaustionTol : low <= p1272 + exhaustionTol)
bool exhAt1618 = not na(pT2) and (dir == 1 ? high >= pT2 - exhaustionTol : low <= pT2 + exhaustionTol)
bool mlExhGeomConfluence = isValid and confirmed and (exhAt1272 or exhAt1618)
float exhaustionTriggerPrice = exhAt1618 ? pT2 : exhAt1272 ? p1272 : (dir == 1 ? high : low)

// Z-score removed from active exhaustion contract. Keep export fields as placeholders.
float mlExhZScore = na
bool mlExhZExtreme = false

// Footprint row-level evidence (ML exports + diamond enrichment)
volume_row triggerRow = fpAvailable and not na(exhaustionTriggerPrice) ? footprint.get_row_by_price(reqFootprint, exhaustionTriggerPrice) : na
volume_row extremeRow = fpAvailable ? footprint.get_row_by_price(reqFootprint, close > open ? high : low) : na
float extremeRowVol = not na(extremeRow) ? volume_row.total_volume(extremeRow) : na
float extremeRowVolRatio = not na(pocRowVol) and pocRowVol > 0 and not na(extremeRowVol) ? extremeRowVol / pocRowVol : na

// Delta divergence: price goes one way, footprint delta goes the other
bool mlExhDeltaDiv = fpAvailable and not na(fpDelta) and ((close > open and fpDelta <= 0) or (close < open and fpDelta >= 0))
// Absorption: POC pinned at the extreme, rejection candle
bool mlExhAbsorption = fpAvailable and not na(pocRow) and (
    (high - volume_row.up_price(pocRow) <= footprintRowSize and close < open) or
    (volume_row.down_price(pocRow) - low <= footprintRowSize and close > open))
// Zero print: no volume at the extreme row on one side (finished auction)
bool mlExhZeroPrint = mlExhFootprintAvailable and not na(extremeRowVolRatio) and extremeRowVolRatio <= zeroPrintVolRatio and not na(extremeRow) and (volume_row.buy_volume(extremeRow) == 0 or volume_row.sell_volume(extremeRow) == 0)
int footprintEvidenceCount = (mlExhDeltaDiv ? 1 : 0) + (mlExhAbsorption ? 1 : 0) + (mlExhZeroPrint ? 1 : 0)

// ── SWING EXTREME ───────────────────────────────────────────────────────
bool isSwingHighBar = high >= ta.highest(high, exhaustionSwingLookbackBarsInput)
bool isSwingLowBar = low <= ta.lowest(low, exhaustionSwingLookbackBarsInput)

// ── COOLDOWN: 8 bars (2 hours on 15m) ──────────────────────────────────
var int lastBearDiamondBar = na
var int lastBullDiamondBar = na
int exhCooldown = exhaustionCooldownBarsInput
bool bearCooldownOk = na(lastBearDiamondBar) or bar_index - lastBearDiamondBar >= exhCooldown
bool bullCooldownOk = na(lastBullDiamondBar) or bar_index - lastBullDiamondBar >= exhCooldown

int hourEt = hour(time, "America/New_York")
bool mlExhSessionValid = hourEt != 17

// ── 3 TYPES OF FOOTPRINT VOLUME (all from request.footprint()) ──────────
// 1. DELTA: net buy vs sell pressure — who won the bar
bool fpDeltaBullish = fpAvailable and not na(fpDelta) and fpDelta > 0   // buyers won
bool fpDeltaBearish = fpAvailable and not na(fpDelta) and fpDelta < 0   // sellers won

// 2. POC POSITION: where the heaviest trading clustered in the bar
//    POC near the HIGH = institutions loaded up top (distribution)
//    POC near the LOW = institutions loaded down low (accumulation)
float pocPrice = not na(pocRow) ? (volume_row.up_price(pocRow) + volume_row.down_price(pocRow)) / 2.0 : na
float pocPosition = not na(pocPrice) and barRange > 0 ? (pocPrice - low) / barRange : na
bool pocNearLow = not na(pocPosition) and pocPosition <= 0.40   // accumulation zone
bool pocNearHigh = not na(pocPosition) and pocPosition >= 0.60  // distribution zone

// 3. IMBALANCE: stacked buy or sell imbalances showing aggressive one-sided flow
int stackedBuyCount = 0
int stackedSellCount = 0
if fpAvailable
    array<volume_row> fpRows = footprint.rows(reqFootprint)
    int fpRowCount = array.size(fpRows)
    int rowsCheck = math.min(optImbalanceRows, fpRowCount)
    if rowsCheck > 0
        for ri = 0 to rowsCheck - 1
            volume_row topR = array.get(fpRows, fpRowCount - 1 - ri)
            if volume_row.has_buy_imbalance(topR)
                stackedBuyCount += 1
            volume_row botR = array.get(fpRows, ri)
            if volume_row.has_sell_imbalance(botR)
                stackedSellCount += 1
bool stackedBuyImbalance = stackedBuyCount >= optImbalanceRows
bool stackedSellImbalance = stackedSellCount >= optImbalanceRows

// ── DIAMOND TRIGGER ─────────────────────────────────────────────────────
// THREE REQUIREMENTS, all mandatory:
//   1. PROVEN candlestick pattern (backtester validated on MES 15m)
//   2. FOOTPRINT DELTA confirms direction (buyers/sellers won the bar)
//   3. FOOTPRINT POC OR IMBALANCE confirms institutional positioning
// PLUS: swing extreme + cooldown + session filter
//
// BULLISH: proven pattern + delta positive + (POC near low OR no stacked sell imbalance)
bool bullFpTriple = fpDeltaBullish and (pocNearLow or not stackedSellImbalance)
bool bullCandleProven = longLowerShadow or dragonflyDoji
bool bullishExhaustion = mlExhSessionValid and confirmed and isSwingLowBar and bullCooldownOk and bullFpTriple and bullCandleProven

// BEARISH: proven pattern + delta negative + (POC near high OR no stacked buy imbalance)
bool bearFpTriple = fpDeltaBearish and (pocNearHigh or not stackedBuyImbalance)
bool bearCandleProven = longUpperShadow or shootingStar or bearishEngulfing
bool bearishExhaustion = mlExhSessionValid and confirmed and isSwingHighBar and bearCooldownOk and bearFpTriple and bearCandleProven

int mlExhConfidenceTier = bullishExhaustion or bearishExhaustion ? 1 : 0
int exhaustionSignalDir = bearishExhaustion ? -1 : bullishExhaustion ? 1 : 0

if confirmed and bearishExhaustion
    lastBearDiamondBar := bar_index
if confirmed and bullishExhaustion
    lastBullDiamondBar := bar_index

//=====================
// TRADE STATE MACHINE (setup -> active -> TP progress -> final resolution)
//=====================
var int TRADE_NONE    = 0
var int TRADE_SETUP   = 1
var int TRADE_ACTIVE  = 2
var int TRADE_HIT_TP1 = 3
var int TRADE_HIT_TP2 = 4
var int TRADE_STOPPED = 5
var int TRADE_EXPIRED = 6
var int TRADE_HIT_TP3 = 7
var int TRADE_HIT_TP4 = 8
var int TRADE_HIT_TP5 = 9

var int tradeState = TRADE_NONE
var float entryPrice = na
var float slPrice = na
var float tp1Price = na
var float tp2Price = na
var float tp3Price = na
var float tp4Price = na
var float tp5Price = na
var float entryAtr = na
var int setupBar = na
var int entryBar = na
var int lastExitBar = na
var int tradeDir = 0          // direction captured at SETUP→ACTIVE (safe: not affected by anchor updates at exit)
// AG LABEL SOURCE: 0=none, 1=TP1_HIT, 2=TP2_HIT, 3=STOPPED, 4=EXPIRED, 5=TP3_HIT, 6=TP4_HIT, 7=TP5_HIT
// This remains the resolved-path export. trade_state can stay in TP1-TP4 progress while the trade is still live.
var int lastExitOutcome = 0
var int highestTargetHit = 0   // 0=none, 1=TP1, 2=TP2, 3=TP3, 4=TP4, 5=TP5
var int lastExhTriggerBar = na
var int lastExhTriggerDir = 0
var int lastTier1ExhBar = na
var int lastTier1ExhDir = 0
var int mlContConfidenceTier = 0
int cooldownLen = cooldownBarsInput
int barsSinceExit = not na(lastExitBar) ? bar_index - lastExitBar : 999
bool cooldownActive = barsSinceExit < cooldownLen
int setupExpiryBars = barsForMinutes(float(setupExpiryMinutesInput), 12)
int backtestExitTargetIndex = backtestExitTargetInput == "TP5" ? 5 : backtestExitTargetInput == "TP4" ? 4 : backtestExitTargetInput == "TP3" ? 3 : backtestExitTargetInput == "TP2" ? 2 : 1

roundToTick(float price) =>
    na(price) ? na : math.round(price / syminfo.mintick) * syminfo.mintick

float optEntryRatio = optEntryLevelInput == "0.500" ? FIB_PIVOT : optEntryLevelInput == "0.786" ? FIB_786 : FIB_618
int stopFamilyCode = 3  // ATR-only contract retained for downstream export compatibility.

// entryLevel stays on the fib-defined execution line. The indicator overlay should follow that line,
// not the accept-bar close, so the visual remains anchored to the actual setup logic.
float entryLevel = fibPrice(optEntryRatio)
float slLevel    = not isValid or na(entryLevel) ? na : roundToTick(fibBull ? entryLevel - atr14 * optStopAtrMult : entryLevel + atr14 * optStopAtrMult)
float tp1Level   = pT1
float tp2Level   = pT2
float tp3Level   = pT3
float tp4Level   = pT4
float tp5Level   = pT5

// Stop geometry is exported for AG and diagnostics, but not used as a live Pine gate.
float slDistPts = math.abs(entryLevel - slLevel)
float slDistAtr = atr14 > 0 ? slDistPts / atr14 : 0.0
bool trendBiasLong = ema9 > ema21 and close >= ema50 and close >= vwapVal
bool trendBiasShort = ema9 < ema21 and close <= ema50 and close <= vwapVal
// 5m execution gates on the selected fib anchor/reclaim, not on a broad .500-.786 zone touch.
bool entryZoneTouched = not na(entryZoneUpper) and not na(entryZoneLower) and high >= entryZoneLower and low <= entryZoneUpper
bool entryAnchorBullTrigger = confirmed and not na(entryLevel) and low <= entryLevel and close >= entryLevel
bool entryAnchorBearTrigger = confirmed and not na(entryLevel) and high >= entryLevel and close <= entryLevel
float localBreakHigh = ta.highest(high, valueReclaimBreakoutLookbackBarsInput)[1]
float localBreakLow = ta.lowest(low, valueReclaimBreakoutLookbackBarsInput)[1]
bool footprintLongTrigger = fpAvailable and fpDeltaBullish and (pocNearLow or mlExhAbsorption or mlExhZeroPrint or stackedBuyImbalance)
bool footprintShortTrigger = fpAvailable and fpDeltaBearish and (pocNearHigh or mlExhAbsorption or mlExhZeroPrint or stackedSellImbalance)
bool footprintBacktestFallback = not fpAvailable and not requireFootprintForBacktestInput
bool footprintLongGate = footprintLongTrigger or footprintBacktestFallback
bool footprintShortGate = footprintShortTrigger or footprintBacktestFallback
bool atrRiskAcceptable = not na(slLevel) and atr14 > 0 and slDistAtr <= optMaxRiskAtr
bool microTrendLong = trendBiasLong or (ema9 >= ema21 and vwapCode >= 0)
bool microTrendShort = trendBiasShort or (ema9 <= ema21 and vwapCode <= 0)
bool footprintValueReclaimLong = useMicroValueReclaimInput and footprintLongTrigger and not na(pocPrice) and close >= pocPrice and (low <= pocPrice or close > localBreakHigh or vwapCode >= 0)
bool footprintValueReclaimShort = useMicroValueReclaimInput and footprintShortTrigger and not na(pocPrice) and close <= pocPrice and (high >= pocPrice or close < localBreakLow or vwapCode <= 0)
bool longTargetRoom = not na(tp1Level) and close < tp1Level
bool shortTargetRoom = not na(tp1Level) and close > tp1Level
bool longPivotSafety = not na(pPivot) and close >= pPivot
bool shortPivotSafety = not na(pPivot) and close <= pPivot
bool fibAnchorSetupLong = longPivotSafety and (entryAnchorBullTrigger or footprintValueReclaimLong)
bool fibAnchorSetupShort = shortPivotSafety and (entryAnchorBearTrigger or footprintValueReclaimShort)
bool footprintEntryLong = footprintLongGate and longTargetRoom and fibAnchorSetupLong
bool footprintEntryShort = footprintShortGate and shortTargetRoom and fibAnchorSetupShort
bool setupContextLong = dir == 1 and microTrendLong and atrRiskAcceptable and fibAnchorSetupLong
bool setupContextShort = dir == -1 and microTrendShort and atrRiskAcceptable and fibAnchorSetupShort
bool setupContextActive = setupContextLong or setupContextShort
bool longTriggerCore = setupContextLong and footprintEntryLong
bool shortTriggerCore = setupContextShort and footprintEntryShort
bool longTriggerEvent = longTriggerCore and (oneShotEvent ? not longTriggerCore[1] : true)
bool shortTriggerEvent = shortTriggerCore and (oneShotEvent ? not shortTriggerCore[1] : true)
bool directBacktestLongEvent = dir == 1 and entryAnchorBullTrigger and longPivotSafety
bool directBacktestShortEvent = dir == -1 and entryAnchorBearTrigger and shortPivotSafety
bool directBacktestLongTrigger = backtestFibAnchorOnlyInput and atrRiskAcceptable and directBacktestLongEvent and (oneShotEvent ? not directBacktestLongEvent[1] : true)
bool directBacktestShortTrigger = backtestFibAnchorOnlyInput and atrRiskAcceptable and directBacktestShortEvent and (oneShotEvent ? not directBacktestShortEvent[1] : true)
bool entryLongTrigger = backtestFibAnchorOnlyInput ? directBacktestLongTrigger : (longTriggerEvent and not ladderInvalidated)
bool entryShortTrigger = backtestFibAnchorOnlyInput ? directBacktestShortTrigger : (shortTriggerEvent and not ladderInvalidated and not bullishTrendBlocksShorts)
bool setupSeedActive = backtestFibAnchorOnlyInput ? (directBacktestLongTrigger or directBacktestShortTrigger) : setupContextActive
bool setupLadderAllowed = backtestFibAnchorOnlyInput or not ladderInvalidated

if enableDebugLogs and barstate.isconfirmed and (acceptEvent or rejectEvent or breakAgainstEvent or entryLongTrigger or entryShortTrigger)
    log.info(str.format("WBDBG_EVENT bar={0} dir={1} accept={2} reject={3} breakAgainst={4} longTrig={5} shortTrig={6} shortGate={7} fpCount={8} setupCtx={9}", bar_index, dir, acceptEvent, rejectEvent, breakAgainstEvent, entryLongTrigger, entryShortTrigger, bullishTrendBlocksShorts, footprintEvidenceCount, setupContextActive))

if enableDebugLogs and confirmed and setupContextActive
    log.info(str.format("WBDBG_GATE bar={0} dir={1} fpAvail={2} fpFallback={3} fpL={4} fpS={5} fpGateL={6} fpGateS={7} anchorL={8} anchorS={9} reclaimL={10} reclaimS={11} roomL={12} roomS={13} longCore={14} shortCore={15}", bar_index, dir, fpAvailable, footprintBacktestFallback, footprintLongTrigger, footprintShortTrigger, footprintLongGate, footprintShortGate, entryAnchorBullTrigger, entryAnchorBearTrigger, footprintValueReclaimLong, footprintValueReclaimShort, longTargetRoom, shortTargetRoom, longTriggerCore, shortTriggerCore))

bool tradeSetupWasActive = tradeState == TRADE_SETUP
if confirmed
    if exhaustionSignalDir != 0
        lastExhTriggerBar := bar_index
        lastExhTriggerDir := exhaustionSignalDir
        if mlExhConfidenceTier == 1
            lastTier1ExhBar := bar_index
            lastTier1ExhDir := exhaustionSignalDir

    if tradeState == TRADE_NONE and setupSeedActive and not cooldownActive and setupLadderAllowed
        tradeState := TRADE_SETUP
        setupBar := bar_index

    if tradeState == TRADE_SETUP and (entryLongTrigger or entryShortTrigger)
        entryPrice := entryLevel
        slPrice := slLevel
        tp1Price := tp1Level
        tp2Price := tp2Level
        tp3Price := tp3Level
        tp4Price := tp4Level
        tp5Price := tp5Level
        entryAtr := atr14
        tradeDir  := dir      // lock direction here — anchor may shift by exit bar
        highestTargetHit := 0
        tradeState := TRADE_ACTIVE
        entryBar := bar_index

    bool tradeInFlight = tradeState == TRADE_ACTIVE or tradeState == TRADE_HIT_TP1 or tradeState == TRADE_HIT_TP2 or tradeState == TRADE_HIT_TP3 or tradeState == TRADE_HIT_TP4

    float activeTradeStopPrice = tradeInFlight ? slPrice : na
    // Ratchet stop with realized target progress. The stop only tightens: never widens risk.
    if tradeInFlight and not na(slPrice) and not na(entryPrice)
        if tradeDir == 1
            float longRatchet = slPrice
            if highestTargetHit >= 1
                longRatchet := math.max(longRatchet, roundToTick(entryPrice))
            if highestTargetHit >= 2 and not na(tp1Price)
                longRatchet := math.max(longRatchet, tp1Price)
            if highestTargetHit >= 3 and not na(tp2Price)
                longRatchet := math.max(longRatchet, tp2Price)
            if highestTargetHit >= 4 and not na(tp3Price)
                longRatchet := math.max(longRatchet, tp3Price)
            activeTradeStopPrice := longRatchet
        else if tradeDir == -1
            float shortRatchet = slPrice
            if highestTargetHit >= 1
                shortRatchet := math.min(shortRatchet, roundToTick(entryPrice))
            if highestTargetHit >= 2 and not na(tp1Price)
                shortRatchet := math.min(shortRatchet, tp1Price)
            if highestTargetHit >= 3 and not na(tp2Price)
                shortRatchet := math.min(shortRatchet, tp2Price)
            if highestTargetHit >= 4 and not na(tp3Price)
                shortRatchet := math.min(shortRatchet, tp3Price)
            activeTradeStopPrice := shortRatchet

    if tradeInFlight and not na(activeTradeStopPrice)
        slPrice := activeTradeStopPrice

    bool canResolveTrade = tradeInFlight and not na(entryBar) and bar_index > entryBar
    if canResolveTrade
        if tradeDir == 1
            int targetHitNow = high >= tp5Price ? 5 : high >= tp4Price ? 4 : high >= tp3Price ? 3 : high >= tp2Price ? 2 : high >= tp1Price ? 1 : 0
            if low <= activeTradeStopPrice
                tradeState := TRADE_STOPPED
            else if targetHitNow > highestTargetHit
                highestTargetHit := targetHitNow
                tradeState := targetHitNow == 5 ? TRADE_HIT_TP5 : targetHitNow == 4 ? TRADE_HIT_TP4 : targetHitNow == 3 ? TRADE_HIT_TP3 : targetHitNow == 2 ? TRADE_HIT_TP2 : TRADE_HIT_TP1
        else
            int targetHitNow = low <= tp5Price ? 5 : low <= tp4Price ? 4 : low <= tp3Price ? 3 : low <= tp2Price ? 2 : low <= tp1Price ? 1 : 0
            if high >= activeTradeStopPrice
                tradeState := TRADE_STOPPED
            else if targetHitNow > highestTargetHit
                highestTargetHit := targetHitNow
                tradeState := targetHitNow == 5 ? TRADE_HIT_TP5 : targetHitNow == 4 ? TRADE_HIT_TP4 : targetHitNow == 3 ? TRADE_HIT_TP3 : targetHitNow == 2 ? TRADE_HIT_TP2 : TRADE_HIT_TP1

    if tradeState == TRADE_SETUP and not na(setupBar) and bar_index - setupBar > setupExpiryBars
        lastExitOutcome := 4  // EXPIRED — setup timed out, no fill
        tradeState := TRADE_EXPIRED

    bool selectedTargetResolved = highestTargetHit >= backtestExitTargetIndex and highestTargetHit > 0
    bool tradeResolved = tradeState == TRADE_STOPPED or tradeState == TRADE_EXPIRED or selectedTargetResolved
    if tradeResolved
        // Resolve outcome BEFORE resetting state — if a trade stopped after TP1-TP4, preserve the highest target reached.
        lastExitOutcome := tradeState == TRADE_EXPIRED ? 4 : highestTargetHit == 5 ? 7 : highestTargetHit == 4 ? 6 : highestTargetHit == 3 ? 5 : highestTargetHit == 2 ? 2 : highestTargetHit == 1 ? 1 : 3
        lastExitBar := bar_index
        tradeState := TRADE_NONE
        entryPrice := na
        slPrice := na
        tp1Price := na
        tp2Price := na
        tp3Price := na
        tp4Price := na
        tp5Price := na
        entryAtr := na
        setupBar := na
        entryBar := na
        highestTargetHit := 0

bool tradeInFlightNow = tradeState == TRADE_ACTIVE or tradeState == TRADE_HIT_TP1 or tradeState == TRADE_HIT_TP2 or tradeState == TRADE_HIT_TP3 or tradeState == TRADE_HIT_TP4
float activeStopPrice = tradeInFlightNow ? slPrice : na

float backtestTargetPrice = na
if tradeInFlightNow
    backtestTargetPrice := backtestExitTargetIndex == 5 ? tp5Price : backtestExitTargetIndex == 4 ? tp4Price : backtestExitTargetIndex == 3 ? tp3Price : backtestExitTargetIndex == 2 ? tp2Price : tp1Price

// Fire TradingView Strategy Tester orders exactly on state-machine activation edges.
bool setupLevelsValid = not na(slLevel) and not na(tp1Level) and not na(tp2Level) and not na(tp3Level) and not na(tp4Level) and not na(tp5Level)
bool activeTradeLevelsValid = tradeInFlightNow and not na(activeStopPrice) and not na(tp1Price) and not na(tp2Price) and not na(tp3Price) and not na(tp4Price) and not na(tp5Price)
bool levelsValid = setupLevelsValid or activeTradeLevelsValid
bool canTradeBar = levelsValid and confirmed
float strategyStop = not na(activeStopPrice) ? activeStopPrice : slLevel
bool exitOrdersArmed = tradeInFlightNow and not na(entryBar)
bool strategyLongArm = confirmed and tradeState == TRADE_ACTIVE and entryBar == bar_index and tradeDir == 1
bool strategyShortArm = confirmed and tradeState == TRADE_ACTIVE and entryBar == bar_index and tradeDir == -1

if strategyLongArm and canTradeBar and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, qty=1, comment="WB_LONG")

if strategyShortArm and canTradeBar and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, qty=1, comment="WB_SHORT")

if (strategy.position_size > 0 or strategyLongArm) and canTradeBar and exitOrdersArmed and not na(strategyStop) and not na(backtestTargetPrice)
    strategy.exit("Long TP", "Long", stop=strategyStop, limit=backtestTargetPrice, qty=1)

if (strategy.position_size < 0 or strategyShortArm) and canTradeBar and exitOrdersArmed and not na(strategyStop) and not na(backtestTargetPrice)
    strategy.exit("Short TP", "Short", stop=strategyStop, limit=backtestTargetPrice, qty=1)

if not tradeInFlightNow and strategy.position_size != 0
    strategy.close_all(comment="WB_STATE_SYNC")

// Turnover surface (execution churn): absolute contract delta per bar and notional equivalent.
float turnoverContractsBar = math.abs(strategy.position_size - nz(strategy.position_size[1], 0.0))
float turnoverNotionalUsdBar = turnoverContractsBar * close * syminfo.pointvalue
var float turnoverContractsCum = 0.0
var float turnoverNotionalCumUsd = 0.0
if confirmed
    turnoverContractsCum += turnoverContractsBar
    turnoverNotionalCumUsd += turnoverNotionalUsdBar

float mlExhBarsSinceTrigger = not na(lastExhTriggerBar) ? float(bar_index - lastExhTriggerBar) : na
fibLineStyle = f_line_style(fibLineStyleInput)
tradeLabelSize = f_label_size(tradeLabelSizeInput)

bool tradeVisible = tradeState == TRADE_SETUP or tradeState == TRADE_ACTIVE or tradeState == TRADE_HIT_TP1 or tradeState == TRADE_HIT_TP2 or tradeState == TRADE_HIT_TP3 or tradeState == TRADE_HIT_TP4
bool tradeSetupVisible = tradeState == TRADE_SETUP and not na(setupBar) and not na(entryLevel) and not na(slLevel) and not na(tp1Level) and not na(tp2Level) and not na(tp3Level) and not na(tp4Level) and not na(tp5Level)
bool tradeActiveVisible = tradeInFlightNow and not na(entryPrice) and not na(activeStopPrice) and not na(tp1Price) and not na(tp2Price) and not na(tp3Price) and not na(tp4Price) and not na(tp5Price)
bool tradeProjectionVisible = tradeSetupVisible or tradeActiveVisible
bool showTradeLevels = showTradeLabelsInput and tradeProjectionVisible
bool showFibLabelsNow = showFibLevelLabelsInput and not showTradeLevels
float tradeLabelEntryPrice = tradeActiveVisible ? entryPrice : tradeSetupVisible ? entryLevel : na
float tradeLabelSlPrice = tradeActiveVisible ? activeStopPrice : tradeSetupVisible ? slLevel : na
float tradeLabelTp1Price = tradeActiveVisible ? tp1Price : tradeSetupVisible ? tp1Level : na
float tradeLabelTp2Price = tradeActiveVisible ? tp2Price : tradeSetupVisible ? tp2Level : na
float tradeLabelTp3Price = tradeActiveVisible ? tp3Price : tradeSetupVisible ? tp3Level : na
float tradeLabelTp4Price = tradeActiveVisible ? tp4Price : tradeSetupVisible ? tp4Level : na
float tradeLabelTp5Price = tradeActiveVisible ? tp5Price : tradeSetupVisible ? tp5Level : na
// The institutional chart surface now relies only on the canonical fib ladder.
// Trade labels appear only when a setup qualifies or a trade is live.

//=====================
// DRAW ALL FIB LEVELS
//=====================
var line lineZero  = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineNeg236 = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line236   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line382   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line linePivot = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line line618   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line786   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineOne   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineT1    = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line line1382  = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line line150   = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineT2    = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line line1786  = line.new(bar_index, close, bar_index, close, color=color(na), width=1)
var line lineT3    = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line lineT4    = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var line lineT5    = line.new(bar_index, close, bar_index, close, color=color(na), width=2)
var box zoneBox = box.new(bar_index, close, bar_index, close, bgcolor=color(na), border_color=color(na))

var label _lblEntry = label.new(bar_index, close, "", style=label.style_label_left, color=color(na), textcolor=color.new(color.white, 20), size=size.small)
var label _lblSl    = label.new(bar_index, close, "", style=label.style_label_left, color=color(na), textcolor=color.new(COLOR_STOP, 20),   size=size.small)
var label _lblT1    = label.new(bar_index, close, "", style=label.style_label_left, color=color(na), textcolor=color.new(COLOR_TARGET, 20),  size=size.small)
var label _lblT2    = label.new(bar_index, close, "", style=label.style_label_left, color=color(na), textcolor=color.new(COLOR_TARGET, 20),  size=size.small)
var label _lblT3    = label.new(bar_index, close, "", style=label.style_label_left, color=color(na), textcolor=color.new(COLOR_TARGET, 20),  size=size.small)
var label _lblT4    = label.new(bar_index, close, "", style=label.style_label_left, color=color(na), textcolor=color.new(COLOR_TARGET, 20),  size=size.small)
var label _lblT5    = label.new(bar_index, close, "", style=label.style_label_left, color=color(na), textcolor=color.new(COLOR_TARGET, 20),  size=size.small)
var label _fibLblZero = na
var label _fibLblNeg236 = na
var label _fibLbl236 = na
var label _fibLbl382 = na
var label _fibLblPivot = na
var label _fibLbl618 = na
var label _fibLbl786 = na
var label _fibLblOne = na
var label _fibLblT1 = na
var label _fibLbl1382 = na
var label _fibLbl150 = na
var label _fibLblT2 = na
var label _fibLbl1786 = na
var label _fibLblT3 = na
var label _fibLblT4 = na
var label _fibLblT5 = na
var table webWatermarkTable = table.new(position.middle_center, 2, 1, bgcolor=color.new(color.black, 100), border_color=color.new(color.black, 100), border_width=0, frame_color=color.new(color.black, 100), frame_width=0)

int fallbackLeftBar = int(math.max(0, bar_index - targetLookbackBars))
int anchorLeftBar = int(math.max(0, na(anchorHighBar) or na(anchorLowBar) ? fallbackLeftBar : math.min(anchorHighBar, anchorLowBar)))
int drawLeftBar = useConfluenceAnchorSpan ? anchorLeftBar : fallbackLeftBar
int tradeLabelX = bar_index + tradeLabelOffsetBarsInput
var float tradeProjectionEntryPrice = na
var float tradeProjectionSlPrice = na
var float tradeProjectionTp1Price = na
var float tradeProjectionTp2Price = na
var float tradeProjectionTp3Price = na
var float tradeProjectionTp4Price = na
var float tradeProjectionTp5Price = na
tradeProjectionEntryPrice := tradeLabelEntryPrice
tradeProjectionSlPrice := tradeLabelSlPrice
tradeProjectionTp1Price := tradeLabelTp1Price
tradeProjectionTp2Price := tradeLabelTp2Price
tradeProjectionTp3Price := tradeLabelTp3Price
tradeProjectionTp4Price := tradeLabelTp4Price
tradeProjectionTp5Price := tradeLabelTp5Price

var float snapPZero = na
var float snapP236 = na
var float snapP382 = na
var float snapPPivot = na
var float snapP618 = na
var float snapP786 = na
var float snapPOne = na
var float snapP1382 = na
var float snapP150 = na
var float snapP1786 = na
var float snapPT1 = na
var float snapPT2 = na
var float snapPT3 = na
var float snapPT4 = na
var float snapPT5 = na
var int snapDrawLeftBar = na
bool snapCaptureEdge = tradeInFlightNow and not tradeInFlightNow[1]
bool snapReleaseEdge = not tradeInFlightNow and tradeInFlightNow[1]
if snapCaptureEdge
    snapPZero := pZero
    snapP236 := p236
    snapP382 := p382
    snapPPivot := pPivot
    snapP618 := p618
    snapP786 := p786
    snapPOne := pOne
    snapP1382 := p1382
    snapP150 := p150
    snapP1786 := p1786
    snapPT1 := pT1
    snapPT2 := pT2
    snapPT3 := pT3
    snapPT4 := pT4
    snapPT5 := pT5
    snapDrawLeftBar := drawLeftBar
else if snapReleaseEdge
    snapPZero := na
    snapP236 := na
    snapP382 := na
    snapPPivot := na
    snapP618 := na
    snapP786 := na
    snapPOne := na
    snapP1382 := na
    snapP150 := na
    snapP1786 := na
    snapPT1 := na
    snapPT2 := na
    snapPT3 := na
    snapPT4 := na
    snapPT5 := na
    snapDrawLeftBar := na
bool tradeFibFrozen = tradeInFlightNow and not na(snapPZero)
float effectivePZero  = tradeFibFrozen ? snapPZero  : pZero
float effectiveP236   = tradeFibFrozen ? snapP236   : p236
float effectiveP382   = tradeFibFrozen ? snapP382   : p382
float effectivePPivot = tradeFibFrozen ? snapPPivot : pPivot
float effectiveP618   = tradeFibFrozen ? snapP618   : p618
float effectiveP786   = tradeFibFrozen ? snapP786   : p786
float effectivePOne   = tradeFibFrozen ? snapPOne   : pOne
float effectiveP1382  = tradeFibFrozen ? snapP1382  : p1382
float effectiveP150   = tradeFibFrozen ? snapP150   : p150
float effectiveP1786  = tradeFibFrozen ? snapP1786  : p1786
float effectivePT1    = tradeFibFrozen ? snapPT1    : pT1
float effectivePT2    = tradeFibFrozen ? snapPT2    : pT2
float effectivePT3    = tradeFibFrozen ? snapPT3    : pT3
float effectivePT4    = tradeFibFrozen ? snapPT4    : pT4
float effectivePT5    = tradeFibFrozen ? snapPT5    : pT5
float effectiveZoneFillUpper = math.max(effectiveP382, effectiveP618)
float effectiveZoneFillLower = math.min(effectiveP382, effectiveP618)
int effectiveDrawLeftBar = tradeFibFrozen ? snapDrawLeftBar : drawLeftBar

drawAnchoredLine(line id, bool visible, float price, color col, int width_, int leftBar) =>
    if visible and not na(price)
        int rightBar = extendLevelsRight ? bar_index + tradeLabelOffsetBarsInput : bar_index
        line.set_xy1(id, leftBar, price)
        line.set_xy2(id, rightBar, price)
        line.set_color(id, col)
        line.set_width(id, width_)
        line.set_style(id, fibLineStyle)
        line.set_extend(id, extend.none)
    else
        line.set_color(id, color(na))

setFibLevelLabel(label idIn, bool visible, float price, string levelName, color col) =>
    label id = idIn
    if visible and isValid and not na(price)
        int labelX = tradeLabelX
        string labelText = levelName + "  " + str.tostring(price, format.mintick)
        if na(id)
            id := label.new(labelX, price, labelText, style=label.style_label_left, color=color.new(color.black, tradeLabelBgTransparencyInput), textcolor=col, size=tradeLabelSize)
        label.set_xy(id, labelX, price)
        label.set_text(id, labelText)
        label.set_color(id, color.new(color.black, tradeLabelBgTransparencyInput))
        label.set_textcolor(id, col)
        label.set_size(id, tradeLabelSize)
    else if not na(id)
        label.delete(id)
        id := na
    id

drawAnchoredLine(lineZero,  true, effectivePZero,  fibAnchorColorInput,             fibAnchorWidthInput,             effectiveDrawLeftBar)
drawAnchoredLine(lineNeg236, false, pNeg236, fibStopColorInput,            fibStopWidthInput,               drawLeftBar)
drawAnchoredLine(line236,   true, effectiveP236,   fibRetracementColorInput,        fibRetracementWidthInput,        effectiveDrawLeftBar)
drawAnchoredLine(line382,   true, effectiveP382,   fibRetracementAccentColorInput,  fibRetracementAccentWidthInput,  effectiveDrawLeftBar)
drawAnchoredLine(linePivot, true, effectivePPivot, fibAnchorColorInput,             fibPivotWidthInput,              effectiveDrawLeftBar)
drawAnchoredLine(line618,   true, effectiveP618,   fibRetracementAccentColorInput,  fibRetracementAccentWidthInput,  effectiveDrawLeftBar)
drawAnchoredLine(line786,   true, effectiveP786,   fibRetracementColorInput,        fibRetracementWidthInput,        effectiveDrawLeftBar)
drawAnchoredLine(lineOne,   true, effectivePOne,   fibAnchorColorInput,             fibAnchorWidthInput,             effectiveDrawLeftBar)
drawAnchoredLine(lineT1,    true, effectivePT1,    fibTargetColorInput,             fibTargetWidthInput,             effectiveDrawLeftBar)
drawAnchoredLine(line1382,  true, effectiveP1382,  fibRetracementColorInput,        fibRetracementWidthInput,        effectiveDrawLeftBar)
drawAnchoredLine(line150,   true, effectiveP150,   fibRetracementColorInput,        fibRetracementWidthInput,        effectiveDrawLeftBar)
drawAnchoredLine(lineT2,    true, effectivePT2,    fibTargetColorInput,             fibTargetWidthInput,             effectiveDrawLeftBar)
drawAnchoredLine(line1786,  true, effectiveP1786,  fibRetracementColorInput,        fibRetracementWidthInput,        effectiveDrawLeftBar)
drawAnchoredLine(lineT3,    true, effectivePT3,    fibTargetColorInput,             fibTargetWidthInput,             effectiveDrawLeftBar)
drawAnchoredLine(lineT4,    true, effectivePT4,    fibTargetColorInput,             fibTargetWidthInput,             effectiveDrawLeftBar)
drawAnchoredLine(lineT5,    true, effectivePT5,    fibTargetColorInput,             fibTargetWidthInput,             effectiveDrawLeftBar)

float tradeSlVisualLevel = tradeLabelSlPrice

if barstate.islastconfirmedhistory
    _fibLblZero := setFibLevelLabel(_fibLblZero, showFibLabelsNow, effectivePZero, "0", fibAnchorColorInput)
    _fibLblNeg236 := setFibLevelLabel(_fibLblNeg236, false, pNeg236, "-.236", fibStopColorInput)
    _fibLbl236 := setFibLevelLabel(_fibLbl236, showFibLabelsNow, effectiveP236, ".236", fibRetracementColorInput)
    _fibLbl382 := setFibLevelLabel(_fibLbl382, showFibLabelsNow, effectiveP382, ".382", fibRetracementAccentColorInput)
    _fibLblPivot := setFibLevelLabel(_fibLblPivot, showFibLabelsNow, effectivePPivot, ".500", fibAnchorColorInput)
    _fibLbl618 := setFibLevelLabel(_fibLbl618, showFibLabelsNow, effectiveP618, ".618", fibRetracementAccentColorInput)
    _fibLbl786 := setFibLevelLabel(_fibLbl786, showFibLabelsNow, effectiveP786, ".786", fibRetracementColorInput)
    _fibLblOne := setFibLevelLabel(_fibLblOne, showFibLabelsNow, effectivePOne, "1.000", fibAnchorColorInput)
    _fibLblT1 := setFibLevelLabel(_fibLblT1, showFibLabelsNow, effectivePT1, "T1", fibTargetColorInput)
    _fibLbl1382 := setFibLevelLabel(_fibLbl1382, showFibLabelsNow, effectiveP1382, "1.382", fibRetracementColorInput)
    _fibLbl150 := setFibLevelLabel(_fibLbl150, showFibLabelsNow, effectiveP150, "1.500", fibRetracementColorInput)
    _fibLblT2 := setFibLevelLabel(_fibLblT2, showFibLabelsNow, effectivePT2, "T2", fibTargetColorInput)
    _fibLbl1786 := setFibLevelLabel(_fibLbl1786, showFibLabelsNow, effectiveP1786, "1.786", fibRetracementColorInput)
    _fibLblT3 := setFibLevelLabel(_fibLblT3, showFibLabelsNow, effectivePT3, "T3", fibTargetColorInput)
    _fibLblT4 := setFibLevelLabel(_fibLblT4, showFibLabelsNow, effectivePT4, "T4", fibTargetColorInput)
    _fibLblT5 := setFibLevelLabel(_fibLblT5, showFibLabelsNow, effectivePT5, "T5", fibTargetColorInput)

if barstate.islast and showTradeLevels and not na(_lblEntry) and not na(_lblSl) and not na(_lblT1) and not na(_lblT2) and not na(_lblT3) and not na(_lblT4) and not na(_lblT5) and not na(tradeProjectionEntryPrice) and not na(tradeSlVisualLevel) and not na(tradeProjectionTp1Price) and not na(tradeProjectionTp2Price) and not na(tradeProjectionTp3Price) and not na(tradeProjectionTp4Price) and not na(tradeProjectionTp5Price)
    label.set_xy(_lblEntry, tradeLabelX, tradeProjectionEntryPrice)
    label.set_text(_lblEntry, "ENTRY " + str.tostring(tradeProjectionEntryPrice, format.mintick))
    label.set_color(_lblEntry, color.new(entryLabelColorInput, tradeLabelBgTransparencyInput))
    label.set_textcolor(_lblEntry, tradeLabelTextColorInput)
    label.set_size(_lblEntry, tradeLabelSize)
    label.set_xy(_lblSl, tradeLabelX, tradeSlVisualLevel)
    label.set_text(_lblSl, "SL " + str.tostring(tradeSlVisualLevel, format.mintick))
    label.set_color(_lblSl, color.new(stopLabelColorInput, tradeLabelBgTransparencyInput))
    label.set_textcolor(_lblSl, tradeLabelTextColorInput)
    label.set_size(_lblSl, tradeLabelSize)
    label.set_xy(_lblT1, tradeLabelX, tradeProjectionTp1Price)
    label.set_text(_lblT1, "T1 " + str.tostring(tradeProjectionTp1Price, format.mintick))
    label.set_color(_lblT1, color.new(targetLabelColorInput, tradeLabelBgTransparencyInput))
    label.set_textcolor(_lblT1, tradeLabelTextColorInput)
    label.set_size(_lblT1, tradeLabelSize)
    label.set_xy(_lblT2, tradeLabelX, tradeProjectionTp2Price)
    label.set_text(_lblT2, "T2 " + str.tostring(tradeProjectionTp2Price, format.mintick))
    label.set_color(_lblT2, color.new(targetLabelColorInput, tradeLabelBgTransparencyInput))
    label.set_textcolor(_lblT2, tradeLabelTextColorInput)
    label.set_size(_lblT2, tradeLabelSize)
    label.set_xy(_lblT3, tradeLabelX, tradeProjectionTp3Price)
    label.set_text(_lblT3, "T3 " + str.tostring(tradeProjectionTp3Price, format.mintick))
    label.set_color(_lblT3, color.new(targetLabelColorInput, tradeLabelBgTransparencyInput))
    label.set_textcolor(_lblT3, tradeLabelTextColorInput)
    label.set_size(_lblT3, tradeLabelSize)
    label.set_xy(_lblT4, tradeLabelX, tradeProjectionTp4Price)
    label.set_text(_lblT4, "T4 " + str.tostring(tradeProjectionTp4Price, format.mintick))
    label.set_color(_lblT4, color.new(targetLabelColorInput, tradeLabelBgTransparencyInput))
    label.set_textcolor(_lblT4, tradeLabelTextColorInput)
    label.set_size(_lblT4, tradeLabelSize)
    label.set_xy(_lblT5, tradeLabelX, tradeProjectionTp5Price)
    label.set_text(_lblT5, "T5 " + str.tostring(tradeProjectionTp5Price, format.mintick))
    label.set_color(_lblT5, color.new(targetLabelColorInput, tradeLabelBgTransparencyInput))
    label.set_textcolor(_lblT5, tradeLabelTextColorInput)
    label.set_size(_lblT5, tradeLabelSize)
else if barstate.islast
    label.set_text(_lblEntry, "")
    label.set_text(_lblSl, "")
    label.set_text(_lblT1, "")
    label.set_text(_lblT2, "")
    label.set_text(_lblT3, "")
    label.set_text(_lblT4, "")
    label.set_text(_lblT5, "")
    label.set_color(_lblEntry, color(na))
    label.set_color(_lblSl, color(na))
    label.set_color(_lblT1, color(na))
    label.set_color(_lblT2, color(na))
    label.set_color(_lblT3, color(na))
    label.set_color(_lblT4, color(na))
    label.set_color(_lblT5, color(na))

if not na(effectiveZoneFillUpper) and not na(effectiveZoneFillLower)
    box.set_left(zoneBox, effectiveDrawLeftBar)
    box.set_right(zoneBox, bar_index)
    box.set_top(zoneBox, effectiveZoneFillUpper)
    box.set_bottom(zoneBox, effectiveZoneFillLower)
    box.set_bgcolor(zoneBox, color.new(fibPivotColorInput, zoneFillTransparencyInput))
    box.set_border_color(zoneBox, color.new(fibPivotColorInput, 100))
else
    box.set_bgcolor(zoneBox, color(na))
    box.set_border_color(zoneBox, color(na))

if barstate.islast
    table.cell(webWatermarkTable, 0, 0, showWebWatermarkInput ? "WARBIRD" : "", text_color=webWatermarkWarbirdColorInput, text_size=size.huge, text_halign=text.align_right, bgcolor=color.new(color.black, 100), text_formatting=text.format_bold)
    table.cell(webWatermarkTable, 1, 0, showWebWatermarkInput ? "PRO" : "", text_color=webWatermarkProColorInput, text_size=size.huge, text_halign=text.align_left, bgcolor=color.new(color.black, 100))
plot(showEma9Input ? ema9 : na, "EMA 9", ema9ColorInput, ema9WidthInput, display=display.all)
plot(showEma21Input ? ema21 : na, "EMA 21", ema21ColorInput, ema21WidthInput, display=display.all)
plot(showEma50Input ? ema50 : na, "EMA 50", ema50ColorInput, ema50WidthInput, display=display.all)
plot(showVwapInput ? vwapVal : na, "VWAP", vwapColorInput, vwapWidthInput, display=display.all)

//=====================
// MOMENTUM OSCILLATORS (VF + NFE + RSI KNN — ported from Layout surface)
// All OHLCV-derivable. Exported here so TV CSV capture delivers them alongside
// fib/footprint features in a single pull. Optuna tunes weights as hyperparameters.
// No barstate.isconfirmed gate needed — values are bar-close stable scalars.
//=====================
float _vfBodyNorm  = barRange > syminfo.mintick ? (close - open) / barRange : 0.0
float _vfVolMean   = ta.sma(volume, vfLenInput)
float _vfVolStd    = ta.stdev(volume, vfLenInput)
float _vfVolZ      = _vfVolStd > 0 ? (volume - _vfVolMean) / _vfVolStd : 0.0
float mlVfBull     = math.max(0.0, math.min(100.0, 50.0 + _vfBodyNorm * vfFlowWeight + _vfVolZ * vfVolWeight))
float mlVfBear     = math.max(0.0, math.min(100.0, 50.0 - _vfBodyNorm * vfFlowWeight - _vfVolZ * vfVolWeight))
float mlNfe        = ta.ema(ta.rsi(close, nfeLenInput), 3)
float mlRsiKnn     = f_rsi_knn(rsi14, rsiKnnWindow)
float mlConfluence = math.max(0.0, math.min(100.0, (mlNfe + (mlVfBull - mlVfBear + 100.0) * 0.5 + mlRsiKnn) / 3.0))

//=====================
// AG FEATURE EXPORT (Pine-exclusive hidden plots — display=display.none)
// AG OWNS (server-side computable from Databento OHLCV — not emitted here):
//   TA Core Pack (di_spread, adx_slope, er_10, atr_pct, clv, signed_vol, vol_delta),
//   EMA dist_pct (21/50/200), RVOL, exhaustion_score, range_expansion, efficiency,
//   event_day (date-based).
// PINE OWNS (emit here — cannot be reconstructed server-side without Pine state):
//   fib engine geometry, trade state machine, HTF confluence, structure/ICT, VWAP code,
//   OR state, NYSE A/D slope.
//=====================

// ── FIB ENGINE ──
plot(fibRange, "fib_range", display=display.none, editable=false)
plot(pNeg236, "ml_fib_neg_0236", display=display.none, editable=false)
plot(nz(confluenceQuality), "confluence_quality", display=display.none, editable=false)
plot(float(htfConfPivot), "htf_conf_pivot", display=display.none, editable=false)
plot(float(htfConf382), "htf_conf_382", display=display.none, editable=false)
plot(float(htfConf618), "htf_conf_618", display=display.none, editable=false)
plot(float(htfConfTotal), "htf_conf_total", display=display.none, editable=false)

